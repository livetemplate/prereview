{{define "blockComments" -}}
{{$bs := .StartLine}}{{$be := .EndLine}}
{{- range $.FileComments -}}
  {{- if and (ge .ToLine $bs) (le .ToLine $be)}}{{template "commentCardFull" .}}{{end -}}
{{- end -}}
{{- if and (ne $.SelectionEndMax 0) (ge $.SelectionEndMax $bs) (le $.SelectionEndMax $be) -}}
{{template "composer" $}}
{{- end}}
{{- end}}

{{/* blockSuggestions — the suggestion parallel of blockComments for the rendered
     Markdown / HTML block views (#98). Same shape: `.` is the block (StartLine/
     EndLine), `$` stays the root state, so it inlines each of $.FileSuggestions
     whose ToLine falls in the block's source range. */}}
{{define "blockSuggestions" -}}
{{$bs := .StartLine}}{{$be := .EndLine}}
{{- range $.FileSuggestions -}}
  {{- if and (ge .ToLine $bs) (le .ToLine $be)}}{{template "suggestionCard" .}}{{end -}}
{{- end -}}
{{- end}}

{{/* The comment composer — one block shared by every mode. Branches on $.CommentMode
     (region / file / area / else = line-or-block selection) for the container class,
     heading, and textarea placeholder; the tail (draft form + cancel form + Cancel/Save)
     is identical everywhere. Reads only $ (root state), so invoke as {{template "composer" $}}. */}}
{{define "composer" -}}
<div
  class="composer{{if eq $.CommentMode "region"}} ext-composer{{end}}"
  data-key="composer"
  {{- if eq $.CommentMode "region"}} lvt-fx:scroll="into-view"{{end}}
>
  {{- /* heading — varies by comment mode */ -}}
  <strong>
  {{- if eq $.CommentMode "region" -}}
    {{if $.EditingCommentID}}Editing comment on {{else}}Comment on {{end}}region · <small>{{$.CurrentURL}}</small>
  {{- else if eq $.CommentMode "file" -}}
    {{if $.EditingCommentID}}Editing comment on file{{else}}Comment on file{{end}} <code>{{$.CurrentDiff.Path}}</code>
  {{- else if eq $.CommentMode "area" -}}
    {{if $.EditingCommentID}}Editing comment on area of{{else}}Comment on area of{{end}} <code>{{$.CurrentDiff.Path}}</code>
  {{- else if eq $.CommentMode "text" -}}
    {{if $.EditingCommentID}}Editing comment on {{else}}Comment on {{end}}{{$.SelectionLabel}} · “<span class="selection-snippet">{{$.SelectionText}}</span>”
  {{- else -}}
    {{if $.ReanchorCommentID}}Re-anchoring comment to {{else if $.EditingCommentID}}Editing comment on {{else}}Comment on {{end}}{{$.SelectionLabel}}
  {{- end -}}
  </strong>
  {{- /* the "extend the selection" hint shows ONLY in the code/line view, not the rendered
         markdown/html block view; both have CommentMode=="" and can have SelectionAnchor==
         SelectionEnd (a single-line block), so gate on the view too */ -}}
  {{- if and
      (eq $.CommentMode "")
      (ne $.SelectionAnchor 0)
      (eq $.SelectionAnchor $.SelectionEnd)
      (not $.EditingCommentID)
      (not $.ShowRenderedMarkdown)
      (not $.ShowRenderedHTML)
  }} <small class="selection-hint">tap another line to extend, or save now for a single line</small>{{end}}
  {{- /* draft textarea (content kept inline — whitespace-significant) */ -}}
  <form
    method="POST"
    lvt-form:preserve
    class="composer-add"
    id="composer-add-form"
    {{/* Cmd/Ctrl+Enter saves from inside the textarea: the keydown bubbles
         to the form, so the action carries the form's body. lvt-key="Mod+Enter"
         (metaKey||ctrlKey) leaves a plain Enter free for newlines; the client
         preventDefaults the chord so it doesn't also insert one. NOTE: no
         {{- -}} trims here — they would delete the whitespace separating these
         attributes from id=, fusing them into one invalid attribute. */}}
    lvt-on:keydown="addComment"
    lvt-key="Mod+Enter"
  >
    <textarea
      name="body"
      placeholder="
      {{- if eq $.CommentMode "region"}}What's wrong with this region?
      {{- else if eq $.CommentMode "file"}}What's wrong with this file?
      {{- else if eq $.CommentMode "area"}}What's wrong with this region?
      {{- else if eq $.CommentMode "text"}}What's wrong with this text?
      {{- else}}What's wrong with these lines?{{end}}"
      required
      lvt-autofocus
      {{- /* Autosave to DraftBody as you type (debounced) so unsaved text is
             materialized as a draft when you navigate away without Save (#105). */}}
      lvt-on:input="saveDraft"
      lvt-mod:debounce="150"
    >{{$.DraftBody}}</textarea>
  </form>
  {{- /* cancel-form target */ -}}
  <form method="POST" class="composer-cancel" id="composer-cancel-form"></form>
  {{- /* cancel / save */ -}}
  <div class="c-actions">
    <button
      type="submit"
      name="clearSelection"
      form="composer-cancel-form"
      class="cancel-btn"
    >Cancel{{with index $.KeyHint "clearSelection"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</button>
    <button
      type="submit"
      name="addComment"
      form="composer-add-form"
      class="save-btn"
    >Save{{with index $.KeyHint "addComment"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</button>
  </div>
{{- /* close composer */ -}}
</div>
{{- end}}

{{/* Region-select toggle button — identical in the external-site view and the rendered-HTML
     view (only the caller's dot differs), so read $.RegionSelectArmed and invoke as
     {{template "regionToggle" $}}. The region-overlay element (whose selectRegion/selectBlock
     action differs) lives outside this form and is unaffected. */}}
{{define "regionToggle" -}}
<form method="POST" class="region-toggle">
  <button
    type="submit"
    name="toggleRegionSelect"
    class="{{if $.RegionSelectArmed}}contrast{{else}}outline secondary{{end}}"
    aria-pressed="{{if $.RegionSelectArmed}}true{{else}}false{{end}}"
  >{{if $.RegionSelectArmed}}Selecting region — tap to cancel{{else}}▭ Select a region to comment{{end}}</button>
</form>
{{- end}}

{{define "deleteDialog" -}}
<dialog id="confirm-delete-{{.ID}}"><article>
  {{- /* */ -}}
  <header><strong>Delete comment?</strong></header>
  {{- /* */ -}}
  <p><small><code>{{.File}}</code> {{.LineSpan}}</small></p>
  {{- /* */ -}}
  <footer>
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <fieldset role="group">
        <button
          type="button"
          command="close"
          commandfor="confirm-delete-{{.ID}}"
          class="secondary"
        >Cancel</button>
        <button
          type="submit"
          name="deleteComment"
          class="contrast"
        >Delete</button>
      </fieldset>
    </form>
  </footer>
{{- /* */ -}}
</article></dialog>
{{- end}}

{{define "deleteDialogTagged" -}}
<dialog id="confirm-delete-{{.ID}}"><article>
  {{- /* */ -}}
  <header><strong>Delete comment?</strong></header>
  {{- /* */ -}}
  <p><small>
    {{- if .IsRegionLevel}}<code>{{.URL}}</code> · region
    {{- else if .IsAreaLevel}}<code>{{.File}}</code> · area
    {{- else}}<code>{{.File}}</code> · file{{end -}}
  </small></p>
  {{- /* */ -}}
  <footer>
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <fieldset role="group">
        <button
          type="button"
          command="close"
          commandfor="confirm-delete-{{.ID}}"
          class="secondary"
        >Cancel</button>
        <button
          type="submit"
          name="deleteComment"
          class="contrast"
        >Delete</button>
      </fieldset>
    </form>
  </footer>
{{- /* */ -}}
</article></dialog>
{{- end}}

{{/* Confirm dialogs for the irreversible session terminators (issue #58). Same
     no-JS native-<dialog> pattern as deleteDialog: a trigger button elsewhere
     opens it with command="show-modal"; Cancel closes it with command="close";
     the confirm button submits the real action. These MUST render at the page
     top level (outside any <form>) — a <form> nested in a <form> is invalid and
     the inner POST misbehaves, and the toolbar triggers already sit in forms. */}}
{{define "endSessionDialog" -}}
<dialog id="confirm-end-session"><article>
  {{- /* */ -}}
  <header><strong>End session?</strong></header>
  {{- /* */ -}}
  <p><small>Emits the final <code>session_end</code> event and stops the prereview server — your agent stops consuming the stream. This can't be undone.</small></p>
  {{- /* #171: accepting an edit only records a verdict — prereview never writes your files;
         the agent applies it and acks with `prereview applied`. End the session with accepts
         outstanding and nothing ever applies them: the document is left inconsistent with the
         review. Warn, but still allow it — a hard block would deadlock a session with no agent
         running (which is exactly how you get here). */ -}}
  {{- if .AwaitingApplyCount}}
  <p class="end-warn" role="alert"><small><strong>{{.AwaitingApplyCount}} accepted edit{{if ne .AwaitingApplyCount 1}}s{{end}} not yet applied.</strong> The agent still has to write {{if eq .AwaitingApplyCount 1}}it{{else}}them{{end}} to the file (<code>prereview applied</code>). Ending now leaves the document without {{if eq .AwaitingApplyCount 1}}that change{{else}}those changes{{end}}.</small></p>
  {{- end}}
  {{- /* */ -}}
  <footer>
    <form method="POST">
      <fieldset role="group">
        <button
          type="button"
          command="close"
          commandfor="confirm-end-session"
          class="secondary"
        >Cancel</button>
        <button
          type="submit"
          name="endSession"
          class="contrast"
        >End session</button>
      </fieldset>
    </form>
  </footer>
{{- /* */ -}}
</article></dialog>
{{- end}}

{{define "quitDialog" -}}
<dialog id="confirm-quit"><article>
  {{- /* */ -}}
  <header><strong>Quit prereview?</strong></header>
  {{- /* */ -}}
  <p><small>Stops the prereview server and closes the review. Saved comments are already written to the CSV; this can't be undone from the browser.</small></p>
  {{- /* */ -}}
  <footer>
    <form method="POST">
      <fieldset role="group">
        <button
          type="button"
          command="close"
          commandfor="confirm-quit"
          class="secondary"
        >Cancel</button>
        <button
          type="submit"
          name="quit"
          class="contrast"
        >Quit</button>
      </fieldset>
    </form>
  </footer>
{{- /* */ -}}
</article></dialog>
{{- end}}

{{define "commentCardFull" -}}
<div class="inline-comment{{if .Resolved}} is-resolved{{end}}{{if .AnchorOutdated}} is-outdated{{end}}"
     data-key="{{.ID}}"
     lvt-fx:animate="fade"
     {{- /* the targeted comment (just saved, or jumped to via n/p) scrolls into
            view AND takes focus, so after the composer closes the keyboard user
            lands on their comment instead of <body>. tabindex=-1 = programmatically
            focusable, not in the Tab order. GATED on "no composer open" — else this
            lvt-autofocus re-fires on every debounced saveDraft re-render and yanks
            focus/scroll OUT of a composer you just opened (a prior comment stealing
            focus while you type the next one). */ -}}
     {{- if and (eq $.ScrollToCommentID .ID) (eq $.SelectionAnchor 0) (eq $.CommentMode "")}} lvt-fx:scroll="into-view" tabindex="-1" lvt-autofocus{{end}}>
  {{- /* line span · side · status badges */ -}}
  <header><span>{{.LineSpan}} · <small>{{.Side}}</small>
    {{- if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}
    {{- if .AnchorMoved}} · <small class="moved-badge">moved</small>{{end}}
    {{- if .AnchorOutdated}} · <small class="outdated-badge">outdated</small>{{end}}
    {{- if .Draft}} · <small class="draft-badge">draft</small>{{end}}
    {{- if .Processed}} · <small class="processed-badge">worked on</small>{{end}}
    {{- if eq .QueueState "queued"}} · <small class="queued-badge" title="queued for the agent">queued</small>{{end}}
    {{- if index $.AwaitingAgent .ID}} · <small class="awaiting-badge" title="you replied — waiting on the agent">awaiting agent</small>{{end -}}
  </span></header>
  {{- /* selected phrase (kind=text) — shows what the comment is about, esp. for
         rendered-view comments that anchor line-level */ -}}
  {{- if .Snippet}}<div class="ic-snippet">{{.Snippet}}</div>{{end -}}
  {{- /* comment text */ -}}
  <div class="body">{{.Body}}</div>
  {{- if .AnchorOutdated -}}
  <details class="anchor-orig"><summary>⚠ the document changed here — originally anchored to:</summary><pre>{{.Anchor.Text}}</pre></details>
  {{- end -}}
  {{- /* #149 conversation thread — the agent's replies ("what I did") + the
         reviewer's follow-ups, rendered under the body. Empty → nothing renders. */ -}}
  {{- template "thread" (index $.Threads .ID) -}}
  {{- /* #149 reviewer reply — the inline form when open on this card. */ -}}
  {{- if eq $.ReplyingID .ID -}}
  <form method="POST" class="reply-form" lvt-on:keydown="postReply" lvt-key="Mod+Enter">
    <input type="hidden" name="id" value="{{.ID}}">
    <textarea
      name="body"
      placeholder="Reply to the agent…"
      lvt-on:input="saveReplyDraft"
      lvt-mod:debounce="200"
      lvt-autofocus
    >{{$.ReplyDraft}}</textarea>
    <div class="reply-actions">
      <button type="submit" name="cancelReply" class="secondary outline">Cancel</button>
      <button type="submit" name="postReply">Send reply</button>
    </div>
  </form>
  {{- end -}}
  {{- /* resolve / re-anchor / edit / delete / reply */ -}}
  <div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="toggleResolved"
        class="outline"
      >{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>
    {{- /* #149 Reply — opens the inline reply form to steer the agent. */ -}}
    {{- if ne $.ReplyingID .ID -}}
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="openReply" class="outline">Reply</button></form>
    {{- end -}}
    {{- /* Re-enqueue a WORKED-ON comment (#119): put it back on the agent's queue to
           redo. This is the only per-card queue action — a draft is enqueued simply
           by saving it, and a plain queued comment is already on the queue. Agent
           mode, open comments only. */ -}}
    {{- if and $.AgentMode (not .Resolved) (not .AnchorOutdated) .Processed -}}
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="enqueueComment" class="outline enqueue-btn" title="Re-enqueue — ask the agent to redo this">Re-enqueue</button>
    </form>
    {{- end}}
    {{- if .Resolved -}}
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="hideComment"
        class="outline"
      >Hide</button>
    </form>
    {{- end -}}
    {{- if and (not .Resolved) .AnchorOutdated -}}
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="reanchorComment"
        class="outline"
      >Re-anchor</button>
    </form>
    {{- end -}}
    {{- if and (not .Resolved) (not .AnchorOutdated) -}}
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="editComment"
        class="outline"
      >Edit</button>
    </form>
    {{- end -}}
    <button
      type="button"
      class="secondary outline"
      command="show-modal"
      commandfor="confirm-delete-{{.ID}}"
    >Delete</button>
    {{- template "deleteDialog" . -}}
  </div></div>
{{- end}}

{{/* thread — the #149 conversation on a comment or suggestion. Receives the target's
     []ThreadEntry (or nil). Renders nothing when empty, so a target with no replies is
     unchanged. Each entry shows its author (agent/reviewer) + a compact time + body. */}}
{{define "thread" -}}
{{- if . -}}
<div class="thread">
  {{- range . -}}
  <div class="thread-entry thread-{{.Author}}">
    <div class="thread-meta"><span class="thread-author">{{.Author}}</span>{{if .When}} · <small class="thread-when">{{.When}}</small>{{end}}</div>
    <div class="thread-body">{{.Body}}</div>
  </div>
  {{- end -}}
</div>
{{- end -}}
{{- end}}

{{/* suggestionCard — one LLM-proposed edit (issue #98), rendered inline like a
     comment but visually distinct (sparkle icon, accent-tinted chrome, a
     before→after mini-diff). Phase 2 adds the reviewer's decision: accept / reject /
     request-revision (with a note), shown as a verdict badge + action row. $d is the
     live decision (fingerprint-matched via $.DecisionsBySuggestion) or a zero value
     (undecided). Nothing is applied to files — a decision is pending until hand-off
     (Phase 3). The <pre> bodies are whitespace-significant, so the value actions are
     trim-wrapped to hold exactly the original/proposed text. */}}
{{define "suggestionCard" -}}
{{$d := index $.DecisionsBySuggestion .ID -}}
{{$applied := index $.Applied .ID -}}
{{$g := index $.SuggestionGroups .ID -}}
<div class="inline-suggestion{{if .AnchorOutdated}} is-outdated{{end}}{{if $g.Total}} is-grouped{{end}}{{if $d.Verdict}} is-decided sg-{{$d.Verdict}}{{end}}{{if $applied}} is-applied{{end}}"
     data-key="sg-{{.ID}}"
     lvt-fx:animate="fade">
  {{- /* sparkle label · group tag · line span · drift status · verdict */ -}}
  <header><span class="sg-label">{{template "iconSuggestion"}} suggestion</span>
    {{- if $g.Total}} <small class="sg-group-tag" title="{{$g.Total}} alternatives for this text — accepting one auto-rejects the rest">alternative {{$g.Index}} of {{$g.Total}}</small>{{end}} · <small>{{.LineSpan}}</small>
    {{- if .AnchorMoved}} · <small class="moved-badge">moved</small>{{end}}
    {{- if and .AnchorOutdated (not $applied)}} · <small class="outdated-badge">outdated</small>{{end}}
    {{- if eq $d.Verdict "accept"}} · <small class="sg-verdict-badge sg-accept">{{if $applied}}applied{{else}}accepted{{end}}</small>{{end}}
    {{- if eq $d.Verdict "reject"}} · <small class="sg-verdict-badge sg-reject" title="{{if $d.Auto}}not chosen — you accepted another alternative for this text{{else}}rejected by you{{end}}">{{if $d.Auto}}not chosen{{else}}rejected{{end}}</small>{{end}}
    {{- if index $.AwaitingAgent .ID}} · <small class="awaiting-badge" title="you replied — waiting on the agent">awaiting agent</small>{{end -}}
    {{- /* Hide controls — a pure declutter, always available (even for a decided or
           outdated card), separate from the accept/reject flow. Hiding never counts
           as a reject and never reaches the LLM. */ -}}
    <span class="sg-hide-actions">
      {{- if $g.Total}}<form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="hideSuggestionGroup" class="sg-hide-btn" title="Hide all {{$g.Total}} alternatives for this text">Hide all</button></form>{{end -}}
      <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="hideSuggestion" class="sg-hide-btn" title="Hide this suggestion from view">Hide</button></form>
    </span>
  </header>
  {{- if .Note}}<div class="sg-note">{{.Note}}</div>{{end -}}
  {{- /* before → after; the original is omitted for a pure insertion */ -}}
  <div class="sg-diff">
    {{- if .OriginalText}}<pre class="sg-old">{{- .OriginalText -}}</pre>{{end -}}
    <pre class="sg-new">{{- .ProposedText -}}</pre>
  </div>
  {{- if and .AnchorOutdated (not $applied) -}}
  <details class="anchor-orig"><summary>⚠ the document changed here — the original text is gone</summary><pre>{{- .OriginalText -}}</pre></details>
  {{- end -}}
  {{- /* #149 conversation thread — the agent's replies + reviewer follow-ups. */ -}}
  {{- template "thread" (index $.Threads .ID) -}}
  {{- /* #149 reviewer reply — inline form when open, else a Reply button. */ -}}
  {{- if eq $.ReplyingID .ID -}}
  <form method="POST" class="reply-form" lvt-on:keydown="postReply" lvt-key="Mod+Enter">
    <input type="hidden" name="id" value="{{.ID}}">
    <textarea
      name="body"
      placeholder="Reply to the agent…"
      lvt-on:input="saveReplyDraft"
      lvt-mod:debounce="200"
      lvt-autofocus
    >{{$.ReplyDraft}}</textarea>
    <div class="reply-actions">
      <button type="submit" name="cancelReply" class="secondary outline">Cancel</button>
      <button type="submit" name="postReply">Send reply</button>
    </div>
  </form>
  {{- else -}}
  <div class="sg-reply-open"><form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="openReply" class="outline">Reply</button></form></div>
  {{- end -}}
  {{- /* decision surface. The applied branch is FIRST and OUTSIDE the not-outdated
         gate: an applied edit is always anchor-outdated, so it'd otherwise be hidden
         by that gate (as it silently was before M4.3b). It shows the applied status +
         a collapse-to-✦-badge control; Undo is intentionally absent — undoing an
         applied edit must REVERT the file (agent inverse-apply, M4.2), not a plain
         decision-clear that desyncs file vs. state. The rest is hidden for outdated
         suggestions (can't act on a stale target; the LLM re-derives it on hand-off). */ -}}
  {{- if $applied -}}
  {{- /* Applied surface. No collapse button — the right-margin ✦ badge is the sole
         expand/collapse toggle. #159 M4.2: while a revert is pending (Revert set, agent
         hasn't restored yet) show a waiting note; otherwise the applied status + a Revert
         button that asks the agent to restore the original (the agent writes the file,
         never prereview). */ -}}
  {{- if $d.Revert -}}
  <div class="sg-actions"><small class="sg-applied-status sg-reverting">Reverting — the agent will restore the original text.</small></div>
  {{- else -}}
  <div class="sg-actions">
    <small class="sg-applied-status">Edit applied to the file.</small>
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="requestRevert" class="outline sg-revert-btn">Revert</button></form>
  </div>
  {{- end -}}
  {{- else if not .AnchorOutdated -}}
  {{- if $d.Verdict -}}
  <div class="sg-actions">
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="clearSuggestionDecision" class="outline">Undo</button></form>
  </div>
  {{- else -}}
  <div class="sg-actions">
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="acceptSuggestion" class="outline sg-accept-btn">Accept</button></form>
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="rejectSuggestion" class="outline sg-reject-btn">Reject</button></form>
  </div>
  {{- end -}}
  {{- end -}}
</div>
{{- end}}

{{define "commentCardSimple" -}}
<div
  class="inline-comment{{if .Resolved}} is-resolved{{end}}"
  data-key="{{.ID}}"
  {{- /* GATED on "no composer open" (same reason as commentCardFull): don't let a
         prior comment's lvt-autofocus steal focus/scroll from an open composer on
         each saveDraft re-render. */ -}}
  lvt-fx:animate="fade"{{if and (eq $.ScrollToCommentID .ID) (eq $.SelectionAnchor 0) (eq $.CommentMode "")}}
  lvt-fx:scroll="into-view" tabindex="-1" lvt-autofocus{{end}}
>
  {{- /* line span · resolved badge */ -}}
  <header><span>{{.LineSpan}}{{if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}{{if .Draft}} · <small class="draft-badge">draft</small>{{end}}{{if .Processed}} · <small class="processed-badge">worked on</small>{{end}}{{if eq .QueueState "queued"}} · <small class="queued-badge" title="queued for the agent">queued</small>{{end}}{{if index $.AwaitingAgent .ID}} · <small class="awaiting-badge" title="you replied — waiting on the agent">awaiting agent</small>{{end}}</span></header>
  {{- /* comment text */ -}}
  <div class="body">{{.Body}}</div>
  {{- /* #149 conversation thread + reviewer reply — the same pair commentCardFull
         renders. A file/area comment has no line anchor, but its thread is keyed by
         comment ID like any other, so the agent's "what I did" replies and the
         reviewer's follow-ups belong here too (#167). */ -}}
  {{- template "thread" (index $.Threads .ID) -}}
  {{- if eq $.ReplyingID .ID -}}
  <form method="POST" class="reply-form" lvt-on:keydown="postReply" lvt-key="Mod+Enter">
    <input type="hidden" name="id" value="{{.ID}}">
    <textarea
      name="body"
      placeholder="Reply to the agent…"
      lvt-on:input="saveReplyDraft"
      lvt-mod:debounce="200"
      lvt-autofocus
    >{{$.ReplyDraft}}</textarea>
    <div class="reply-actions">
      <button type="submit" name="cancelReply" class="secondary outline">Cancel</button>
      <button type="submit" name="postReply">Send reply</button>
    </div>
  </form>
  {{- end -}}
  {{- /* resolve / reply / edit / delete */ -}}
  <div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="toggleResolved"
        class="outline"
      >{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>
    {{- if ne $.ReplyingID .ID -}}
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="openReply" class="outline">Reply</button></form>
    {{- end -}}
    {{- if .Resolved -}}
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="hideComment"
        class="outline"
      >Hide</button>
    </form>
    {{- end -}}
    {{- if not .Resolved -}}
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="editComment"
        class="outline"
      >Edit</button>
    </form>
    {{- end -}}
    <button
      type="button"
      class="secondary outline"
      command="show-modal"
      commandfor="confirm-delete-{{.ID}}"
    >Delete</button>
    {{- template "deleteDialogTagged" . -}}
  </div></div>
{{- end}}

{{- /* #155: a version's diff STAT (+add/−del) — the scalable floor shown under the
       agent's changelog (or alone when there's no changelog). Counts only, never the
       raw diff lines, so it stays compact for a large change. */ -}}
{{define "versionSummary" -}}
{{- if .Initial}}<span class="vs-note">Initial version — the starting point.</span>
{{- else if .Deleted}}<span class="vs-note">File removed at this version.</span>
{{- else if .Binary}}<span class="vs-note">Binary file changed.</span>
{{- else -}}
<span class="vs-stat"><span class="vs-add">+{{.Added}}</span> <span class="vs-rem">−{{.Removed}}</span></span>
{{- end -}}
{{- end}}
{{define "quizCard"}}<div class="quiz-card{{if .Answered}} is-answered{{end}}" data-key="quiz-{{.ID}}">
  <div class="quiz-card-head"><span class="quiz-probe quiz-probe-{{.Probe}}">{{.Probe}}</span>{{if .Ungrounded}}<span class="quiz-ungrounded" title="This question cites {{.AnchorLabel}}, which is not in this diff — treat it with suspicion">⚠ cites {{.AnchorLabel}}, not in this diff</span>{{end}}</div>
  <p class="quiz-prompt">{{.Prompt}}</p>
  <ul class="quiz-options">
    {{$item := .}}
    {{range $i, $opt := .Options}}
    <li>
      {{if $item.Answered}}
      <div class="quiz-option{{if eq $i $item.Answer}} is-correct{{end}}{{if and (eq $i $item.Choice) (ne $i $item.Answer)}} is-wrong{{end}}"><span class="quiz-mark">{{if eq $i $item.Answer}}✓{{else if eq $i $item.Choice}}✗{{else}} {{end}}</span>{{$opt}}</div>
      {{else}}
      <form method="POST" style="margin:0"><input type="hidden" name="quizId" value="{{$item.QuizID}}"><input type="hidden" name="questionId" value="{{$item.ID}}"><input type="hidden" name="choice" value="{{$i}}"><button type="submit" name="answerQuestion" class="quiz-option quiz-option-btn">{{$opt}}</button></form>
      {{end}}
    </li>
    {{end}}
  </ul>
  {{if .Answered}}<p class="quiz-why{{if .Correct}} is-correct{{else}} is-wrong{{end}}"><small>{{.Why}}</small></p>{{end}}
  {{- /* #191 conversation on the question itself: ask the agent to clarify a
         confusing option, or to revise a question you think is wrong. Same
         thread machinery comments and suggestions use — the only new part is the
         composite target id, since a question id is unique only within its quiz. */ -}}
  {{- template "thread" .Thread -}}
  {{if .Replying}}
  <form method="POST" class="reply-form" lvt-on:keydown="postReply" lvt-key="Mod+Enter">
    <input type="hidden" name="id" value="{{.ThreadID}}">
    <textarea
      name="body"
      placeholder="Ask the agent to clarify or revise this question…"
      lvt-on:input="saveReplyDraft"
      lvt-mod:debounce="200"
      lvt-autofocus
    >{{.ReplyDraft}}</textarea>
    <div class="reply-actions">
      <button type="submit" name="cancelReply" class="secondary outline">Cancel</button>
      <button type="submit" name="postReply">Send reply</button>
    </div>
  </form>
  {{else}}
  <form method="POST" class="quiz-card-actions"><input type="hidden" name="id" value="{{.ThreadID}}"><button type="submit" name="openReply" class="outline quiz-reply-btn">Reply</button></form>
  {{end}}
</div>
{{end}}
