{{/* FORMATTING — read before reflowing.
     This renders through html/template, which copies static whitespace verbatim
     into the output. Most of the markup is normal-flow HTML where whitespace
     between elements collapses, so it can be broken across lines freely. A few
     spots ARE whitespace-sensitive — a generic formatter (prettier, djlint)
     corrupts them, so do not run one over this file:
       1. the highlighted code text — .content / .chroma is `white-space:
          pre-wrap`, so a newline inside it shows as a real line break;
       2. textarea draft bodies — a newline there is literal draft text;
       3. significant single spaces — e.g. the diff gutter's trailing space;
       4. runs of inline elements — whitespace between them renders as a space.
     Long lines are kept readable two ways, both of which leave the rendered DOM
     unchanged (the only byte differences are whitespace HTML already ignores):
       - attribute-heavy tags are split one attribute per line (whitespace
         between attributes inside a start tag is collapsed by the parser);
       - element structure is broken with Go's whitespace-trim markers; an empty
         trim-trimmed comment between two pure-HTML siblings such as a </form>
         and the next <form> is a "trim carrier" that emits nothing.
     SVG icons live in iconX define blocks at the bottom, inlined at parse. */ -}}
<!DOCTYPE html>
{{/* data-scheme selects the coordinated color scheme (Solarized today;
     gruvbox/catppuccin attach to the same [data-scheme] CSS later).
     data-theme=light forces Pico's light-mode palette for now; the
     Light/Dark/System toggle makes it dynamic alongside the dark token
     block + a dark chroma syntax sheet. All colors derive from these two
     attributes — see [data-scheme="solarized"] in prereview.css. */}}
<html lang="en" data-scheme="solarized" data-theme="light">
<head>
<meta charset="utf-8">
<meta
  name="viewport"
  content="width=device-width, initial-scale=1, viewport-fit=cover"
>
<title>prereview · {{.RepoPath}}</title>
<link rel="stylesheet" href="/pico.min.css">
<link rel="stylesheet" href="/livetemplate.css">
<link rel="stylesheet" href="/syntax.css">
<link rel="stylesheet" href="/prereview.css">
</head>
<body
  data-lvt-loading-debounce-ms="200"
>
{{/* Global cancel. Esc clears any selection, closes the composer, and
     dismisses the keyboard-help overlay. A guard-free window binding (NOT
     skip-when-typing) so it fires even while the composer textarea is focused,
     and a direct child of <body> — not gated by the external/repo split — so
     it works in both modes. The window scan finds it because it's a descendant
     of the wrapper; a binding on <body> itself would be missed. Listed in the
     help overlay via the keymap (Esc has Action ""). */}}
<span class="kbd-esc" hidden aria-hidden="true"
  lvt-on:window:keydown="clearSelection"
  lvt-key="Escape"
></span>

{{if .ExternalMode}}
{{/* --external (live-site) view. The proxied site renders in a cross-origin
     iframe (src = the second-origin proxy); the region overlay is toggle-
     armed (same UX as the HTML preview) so the live page stays interactive
     when off and captures a drawn box when on. lvt-fx:proxy-bridge wires the
     injected beacon's nav (→ setProxyURL) + scroll (→ pin-layer transform).
     Annotations anchor to URL + region (kind=region); the pin layer re-pins
     them on the live page, the sidebar lists them across pages. */}}
<header class="bar bar-external">
  <span class="ext-target">prereview · annotating <code>{{.TargetURL}}</code>
    {{- if .CurrentURL}} <span class="ext-page">{{.CurrentURL}}</span>{{end -}}
  </span>
  <span class="bar-actions">
    {{- /* annotation-count toggle */ -}}
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="toggleAnnotations"
        class="outline secondary anno-toggle"
        aria-pressed="{{if .AnnoDrawerOpen}}true{{else}}false{{end}}"
        title="Show/hide annotations"
      >💬 {{len $.AllRegionComments}}</button>
    </form>
    {{- if .StreamMode -}}
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="handOff"
        class="contrast"
        title="Send the current annotations to your agent as a handoff event (session stays open)"
      >Hand off →</button>
    </form>
    {{- /* session terminator */ -}}
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="endSession"
        class="contrast"
        title="Emit session_end and stop the server — your agent stops consuming the stream"
      >End session</button>
    </form>
    {{- else if .SkillMode -}}
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="handOff"
        class="contrast"
        title="Stop the server and signal your agent to read the CSV"
      >Hand off →</button>
    </form>
    {{- else -}}
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="quit"
        class="contrast"
        title="Stop the prereview server"
      >Quit</button>
    </form>
    {{- end -}}
  </span>
</header>
<div class="layout layout-external">
  <main class="viewer ext-viewer">
    {{template "regionToggle" $}}
    <div class="preview-stage ext-stage"
         lvt-fx:proxy-bridge="setProxyURL"
         data-key="ext-stage"
         {{- with $.FocusedComment}} data-focus-token="{{$.FocusSeq}}" data-focus-url="{{.URL}}" data-focus-y="{{.Area.Y}}"{{end}}>
      {{/* lvt-ignore: morphdom must never re-process this iframe. Its src is
           set once (SSR); as the user navigates the live site in-app the
           content moves while the src attribute stays put. Without this, any
           server render re-emits src={{`{{.ProxyBaseURL}}`}} and morphdom
           resets the iframe back to the home page. (lvt-ignore-attrs is NOT
           enough — it only back-fills dropped attrs; the template always has
           src, so morphdom would still sync it.) */}}
      <iframe
        class="ext-frame"
        src="{{.ProxyBaseURL}}"
        title="Live preview of {{.TargetURL}}"
        lvt-ignore
      ></iframe>
      <div class="pin-layer" data-pin-layer data-key="pin-layer">
        {{- range $.RegionComments -}}
        <button type="button"
                class="area-overlay pin-btn
                {{- if .Resolved}} is-resolved{{end}}
                {{- if eq $.FocusedCommentID .ID}} is-focused{{end -}}
                "
                lvt-on:click="editComment"
                data-id="{{.ID}}"
                data-key="pin-{{.ID}}"
                style="left:{{.Area.PercentX}};top:{{.Area.PercentY}};width:{{.Area.PercentW}};height:{{.Area.PercentH}};"
                title="{{.Body}}"
                aria-label="Edit annotation"></button>
        {{- end -}}
        {{- if eq $.CommentMode "region" -}}
        <div class="area-overlay area-overlay-pending"
             data-key="pin-pending"
             style="left:{{$.SelectionArea.PercentX}};top:{{$.SelectionArea.PercentY}};width:{{$.SelectionArea.PercentW}};height:{{$.SelectionArea.PercentH}};"></div>
        {{- end -}}
      </div>
      {{if .RegionSelectArmed}}<div
        class="region-overlay"
        lvt-fx:region-select="selectRegion"
        data-surface="page"
        data-key="ext-region-overlay"
      ></div>{{end}}
    </div>
    {{if eq $.CommentMode "region"}}{{template "composer" $}}{{end}}
  </main>
  <aside
    class="ext-sidebar{{if .AnnoDrawerOpen}} is-open{{end}}"
    aria-label="Annotations"
  >
    <header class="ext-sidebar-head"><strong>Annotations ({{len $.AllRegionComments}})</strong>
      {{- /* close annotations */ -}}
      <form method="POST" style="margin:0">
        <button
          type="submit"
          name="toggleAnnotations"
          class="outline secondary close-btn"
          aria-label="Close annotations"
        >{{template "iconClose16"}}</button>
      </form>
    {{- /* */ -}}
    </header>
    <div class="ext-sidebar-body">
      {{- range $.AllRegionComments -}}
      <div
        class="inline-comment ext-anno
        {{- if .Resolved}} is-resolved{{end}}
        {{- if eq $.FocusedCommentID .ID}} is-focused{{end -}}
        "
        data-key="{{.ID}}"
        lvt-fx:animate="fade"
      >
        {{- /* locate form */ -}}
        <form method="POST" class="anno-locate-form">
          <input type="hidden" name="id" value="{{.ID}}">
          <button
            type="submit"
            name="focusComment"
            class="anno-locate"
            title="Locate this region on the page"
          ><span class="ext-page-link">📍 {{.URL}}</span>
          {{- if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}
          {{- /* */ -}}<span class="anno-body">{{.Body}}</span></button>
        </form>
        {{- /* resolve / edit / delete */ -}}
        <div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="toggleResolved"
        class="outline"
      >{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>
          {{- if not .Resolved -}}
          <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="editComment"
        class="outline"
      >Edit</button>
    </form>
          {{- end -}}
          <button
      type="button"
      class="secondary outline"
      command="show-modal"
      commandfor="confirm-delete-{{.ID}}"
    >Delete</button>
          {{- template "deleteDialogTagged" . -}}
        </div></div>
      {{- else -}}
      <p class="empty"><small>No annotations yet — tap “Select a region”, then drag a box on the page.</small></p>
      {{- end -}}
    </div>
  </aside>
</div>
<footer class="app-footer" role="contentinfo"><small>prereview
  {{- if ne .Version "dev"}} v{{.Version}}{{end}} · external mode · <code>{{.TargetURL}}</code></small></footer>
{{else}}
{{/* Keyboard shortcuts — single-sourced from KeyBindings (internal/review/keymap.go),
     which also feeds the help overlay below so the two can't drift. Each global shortcut
     is a hidden window keydown binding carrying lvt-mod:skip-when-typing, so a shortcut
     letter typed into the composer or file filter types the letter instead of firing the
     shortcut. Esc — which must fire while typing to cancel — stays on <body>, not here. */}}
<div class="kbd-bindings" hidden aria-hidden="true">
  {{- range .KeyBindings}}{{$b := .}}{{range $b.Keys}}{{if $b.Action}}<span
    lvt-on:window:keydown="{{$b.Action}}"
    lvt-key="{{.}}"
    lvt-mod:skip-when-typing
  ></span>{{end}}{{end}}{{end -}}
</div>
<header
  class="bar{{if .FileDrawerOpen}} files-collapsed{{end}}"
  lvt-fx:url-hash="setURLHash"
  data-lvt-url-hash="{{.URLHash}}"
>
  <form method="POST">
    <button
      type="submit"
      name="toggleFiles"
      class="hamburger outline contrast"
      aria-label="Toggle files"
    >{{template "iconHamburger"}}</button>
  </form>
  <div class="title">
    <span class="title-main">
      {{- if .ShowAllComments}}{{/* No title in all-comments mode — the "Show all comments (N) ☑" checkbox in the toolbar already conveys the view. */}}
      {{- else if .CurrentDiff}}<span class="title-file">{{.CurrentDiff.Path}}</span>
      {{- else}}<small>Pick a file from {{len .Files}} file{{if ne (len .Files) 1}}s{{end}}</small>
      {{- end -}}
    </span>
  </div>
  {{/* Desktop-only inline chip group. On mobile these same actions live
       in the 3-dots overflow menu below — single source of truth, just
       presented in the layout that fits.

       Grouped into .tb-group segments (counters | view toggles) with
       a CSS divider between them; the prev/next and Quit forms below
       form their own groups via .tb-group-divider on first-of-group. */}}
  <div class="toolbar-inline">
    <div class="tb-group tb-counters">
      <small class="auto-saved-long">{{len .Files}} files{{if gt .ChangedFilesCount 0}} · {{.ChangedFilesCount}} changed{{end}} · {{.ViewedCount}}/{{len .Files}} viewed</small>
      {{/* "Show resolved" is a FILTER — modifies which comments appear
           in the current view, semantically a checkbox on/off. The
           view-change "All comments" used to share this row but lived
           an entire UI level apart (replaces the file viewer); it now
           lives in the file drawer as a clearly-distinct button so the
           two semantics don't get conflated under identical chrome.
           change events flow through the existing toggleShowResolved
           action unchanged. */}}
      {{if gt .ResolvedCount 0}}
      <form method="POST">
        <label
          class="tb-checkbox"
          title="Include resolved comments in the view"
        ><input
          type="checkbox"
          {{if .ShowResolved}}checked{{end}}
          lvt-on:change="toggleShowResolved"
        >Show resolved comments ({{.ResolvedCount}})</label>
      </form>
      {{end}}
      {{if and (gt .OutdatedCount 0) (not .ShowAllComments)}}
      <form method="POST">
        <button
          type="submit"
          name="toggleCommentList"
          class="contrast"
          title="{{.OutdatedCount}} comment{{if ne .OutdatedCount 1}}s{{end}} need re-anchoring — open the list to fix"
        >⚠ {{.OutdatedCount}} outdated</button>
      </form>
      {{end}}
    </div>
    {{if .CurrentDiff}}
    <div class="tb-group tb-toggles">
      {{/* Native HTML radio groups for view-mode toggles. Auto-submit
           on change via livetemplate's `lvt-on:change` (same pattern as
           the Base picker <select> in the file drawer). Setters
           (SetMarkdownView / SetFileViewMode) read the form's `view`
           field — idempotent, so clicking the already-active radio is a
           genuine no-op (vs. the old toggle action which would have
           flipped). Browser-native radio visuals beat any custom
           segmented control: clear "one of N" affordance, no squish
           bugs, accent-color matches the toolbar contrast. */}}
      {{if .IsMarkdown}}
      <form method="POST" class="tb-radios" aria-label="Markdown view">
        <label><input
          type="radio"
          name="view"
          value="rendered"
          {{if not .RawMarkdown}}checked{{end}}
          lvt-on:change="setMarkdownView"
        >Preview</label>
        <label><input
          type="radio"
          name="view"
          value="raw"
          {{if .RawMarkdown}}checked{{end}}
          lvt-on:change="setMarkdownView"
        >Raw</label>
      </form>
      {{end}}
      {{if .IsHTML}}
      <form method="POST" class="tb-radios" aria-label="HTML view">
        <label><input
          type="radio"
          name="view"
          value="rendered"
          {{if not .RawHTML}}checked{{end}}
          lvt-on:change="setHTMLView"
        >Preview</label>
        <label><input
          type="radio"
          name="view"
          value="raw"
          {{if .RawHTML}}checked{{end}}
          lvt-on:change="setHTMLView"
        >Raw</label>
      </form>
      {{end}}
      {{if and (not .ShowRenderedMarkdown) (not .ShowRenderedHTML)}}
      <form method="POST" class="tb-radios" aria-label="File view">
        <label><input
          type="radio"
          name="view"
          value="diff"
          {{if not .FileView}}checked{{end}}
          lvt-on:change="setFileViewMode"
        >Diff</label>
        <label><input
          type="radio"
          name="view"
          value="file"
          {{if .FileView}}checked{{end}}
          lvt-on:change="setFileViewMode"
        >File</label>
      </form>
      {{end}}
    </div>
    {{end}}
    {{/* Focus mode — desktop-only reading toggle. Hides both side columns
         (file drawer + TOC) via a class on .layout so the center surface
         gets full width. The button is the restore affordance too (label
         flips), so no separate reopen rail is needed. Gated on a file
         being open (matches the sibling tb-toggles group): with no file
         selected the drawer is the only way to pick one, so hiding it
         would strand the user — focus is a "while reading" affordance. */}}
    {{if .CurrentDiff}}
    <div class="tb-group tb-focus">
      <form method="POST">
        <button
          type="submit"
          name="toggleFocusMode"
          class="contrast focus-toggle"
          aria-pressed="{{if .FocusMode}}true{{else}}false{{end}}"
          title="
          {{- if .FocusMode}}Show the file list and outline columns
          {{- else}}Hide the side columns for distraction-free reading{{end -}}
          "
        >{{if .FocusMode}}Exit focus{{else}}Focus{{end}}</button>
      </form>
    </div>
    {{end}}
    {{/* Keyboard-shortcuts help. Desktop toolbar affordance (mobile has the
         more-menu item); both submit toggleKeyboardHelp, the same action the
         "?" key fires. Always shown — the help is useful even before a file
         is open. */}}
    <div class="tb-group tb-help">
      <form method="POST">
        <button
          type="submit"
          name="toggleKeyboardHelp"
          class="contrast kbd-help-btn"
          aria-pressed="{{if .KeyHelpOpen}}true{{else}}false{{end}}"
          title="Keyboard shortcuts (press ?)"
          aria-label="Keyboard shortcuts"
        >?</button>
      </form>
    </div>
  </div>
  {{if .CurrentDiff}}
  {{/* Comment on the file as a whole — works on every file type
       including binaries (image/PDF/video), deleted files, and files
       past the "too large to review" cap, since the composer doesn't
       need any line content to function. The action clears any in-
       progress line selection. Hidden when the composer is already
       open in file-mode to avoid a self-toggle loop. */}}
  {{if ne .CommentMode "file"}}
  <form method="POST" class="tb-action">
    <button
      type="submit"
      name="openFileComment"
      class="contrast"
      title="Add a comment about the whole file"
      aria-label="Comment on file"
    >
      {{template "iconChat14"}}
      <span class="nav-label">Comment on file</span>
    </button>
  </form>
  {{end}}
  {{end}}
  {{if gt (len .Files) 1}}
  <form method="POST" class="nav-prev">
    <button
      type="submit"
      name="prevFile"
      title="Previous file"
      aria-label="Previous file"
      class="contrast"
    >{{template "iconChevronLeft"}}<span class="nav-label">Prev</span></button>
  </form>
  <form method="POST" class="nav-next">
    <button
      type="submit"
      name="nextFile"
      title="Next file"
      aria-label="Next file"
      class="contrast"
    ><span class="nav-label">Next</span>{{template "iconChevronRight"}}</button>
  </form>
  {{end}}
  <form method="POST" class="tb-action">
    {{if .StreamMode}}
    <button
      type="submit"
      name="handOff"
      class="contrast"
      title="Send the current comments to your agent as a handoff event (session stays open)"
    >Hand off →</button>
    {{/* On mobile End session moves to the ⋮ overflow menu (below) so the
         narrow bar isn't crowded by two action buttons — hidden here via
         .end-session-inline in the mobile media query. */}}
    <button
      type="submit"
      name="endSession"
      class="contrast end-session-inline"
      title="Emit session_end and stop the server — your agent stops consuming the stream"
    >End session</button>
    {{else if .SkillMode}}
    <button
      type="submit"
      name="handOff"
      class="contrast"
      title="Stop the server and signal your agent to read the CSV"
    >Hand off →</button>
    {{else}}
    <button
      type="submit"
      name="quit"
      class="contrast"
      title="Stop the prereview server"
    >Quit</button>
    {{end}}
  </form>
  {{/* 3-dots trigger — mobile only (hidden on desktop via CSS). Placed
       last so it visually anchors the right edge of the toolbar; the
       menu opens directly below it (also right-edge aligned). Uses an
       SVG icon — the `⋮` unicode glyph renders zero-width on iOS Safari's
       UI font. */}}
  <form method="POST" style="margin:0">
    <button
      type="submit"
      name="toggleMoreMenu"
      class="more-trigger"
      aria-label="More options"
      aria-haspopup="menu"
      aria-expanded="{{if .MoreMenuOpen}}true{{else}}false{{end}}"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <circle cx="12" cy="5" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="12" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="19" r="1.8" fill="currentColor"/>
      </svg>
    </button>
  </form>
</header>

{{/* Mobile overflow menu. Backdrop sibling tap closes it. Both have the
     same `.is-open` class flip so they appear/disappear together. Desktop
     CSS forces display:none on both so the inline chips own the chrome.

     Icons are inline SVG (not Unicode glyphs like ⋮ ✓ ○) — iOS Safari's
     UI font sometimes renders those zero-width or substitutes them with
     emoji, which carry their own color and ignore CSS `color`. SVG with
     `fill: currentColor` honors the menu-item color cascade. */}}
<div
  class="more-menu-backdrop{{if .MoreMenuOpen}} is-open{{end}}"
  lvt-on:click="closeMoreMenu"
  aria-hidden="true"
></div>
<div
  class="more-menu{{if .MoreMenuOpen}} is-open{{end}}"
  role="menu"
  aria-label="More options"
>
  <div class="menu-info">{{len .Files}} files{{if gt .ChangedFilesCount 0}} · {{.ChangedFilesCount}} changed{{end}} · {{.ViewedCount}}/{{len .Files}} viewed
    {{- if gt (len .Comments) 0}} · {{len .Comments}} comment{{if ne (len .Comments) 1}}s{{end}}{{end -}}
  </div>
  {{if .CurrentDiff}}
  {{if ne .CommentMode "file"}}
  {{/* "Comment on file" mirrors the desktop toolbar button. Works for
       binary / deleted / too-large files where no line is clickable. */}}
  <form method="POST">
    <button
      type="submit"
      name="openFileComment"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconChat16"}}</span>
      <span class="menu-label">Comment on file</span>
    </button>
  </form>
  {{end}}
  {{with .RenderedHeadings}}
  {{/* Mobile-only entry — desktop renders the TOC as a permanent right
       sidebar, so this is `display: none` ≥900px via the media query.
       OpenTOC closes the more-menu in the same action so the dropdown
       doesn't stay drawn over the overlay it just summoned. */}}
  <form method="POST">
    <button
      type="submit"
      name="openTOC"
      class="menu-item toc-menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconTOC"}}</span>
      <span class="menu-label">Table of contents</span>
      <span class="menu-meta">{{len .}}</span>
    </button>
  </form>
  {{end}}
  {{if .IsMarkdown}}
  <form method="POST">
    <button
      type="submit"
      name="toggleRawMarkdown"
      class="menu-item{{if not .RawMarkdown}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">
        {{if .RawMarkdown}}
        {{template "iconRendered"}}
        {{else}}
        {{template "iconViewRaw"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .RawMarkdown}}Preview{{else}}View raw source{{end}}</span>
    </button>
  </form>
  {{end}}
  {{if .IsHTML}}
  <form method="POST">
    <button
      type="submit"
      name="toggleRawHTML"
      class="menu-item{{if not .RawHTML}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">
        {{if .RawHTML}}
        {{template "iconRendered"}}
        {{else}}
        {{template "iconViewRaw"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .RawHTML}}Preview{{else}}View raw source{{end}}</span>
    </button>
  </form>
  {{end}}
  {{if and (not .ShowRenderedMarkdown) (not .ShowRenderedHTML)}}
  <form method="POST">
    <button
      type="submit"
      name="toggleFileView"
      class="menu-item{{if .FileView}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">
        {{if .FileView}}
        {{/* Diff icon (split rectangles with plus/minus) — shown when current view is plain file. */}}
        {{template "iconDiff"}}
        {{else}}
        {{/* File icon (document) — shown when current view is diff. */}}
        {{template "iconFile"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .FileView}}Show diff{{else}}View file{{end}}</span>
    </button>
  </form>
  {{end}}
  {{end}}
  {{if gt (len .Comments) 0}}
  <form method="POST">
    <button
      type="submit"
      name="toggleCommentList"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconComments"}}</span>
      <span class="menu-label">{{if .ShowAllComments}}Back{{else}}All comments{{end}}</span>
      <span class="menu-meta">{{len .Comments}}</span>
    </button>
  </form>
  {{end}}
  {{if gt .ResolvedCount 0}}
  <form method="POST">
    <button
      type="submit"
      name="toggleShowResolved"
      class="menu-item{{if .ShowResolved}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">
        {{if .ShowResolved}}
        {{template "iconCheck"}}
        {{else}}
        {{template "iconCircle16"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .ShowResolved}}Hide resolved{{else}}Show resolved{{end}}</span>
      <span class="menu-meta">{{.ResolvedCount}}</span>
    </button>
  </form>
  {{end}}
  {{if and (eq (len .Comments) 0) (eq .ResolvedCount 0)}}
  <div
    class="menu-info"
    style="border-bottom: 0; margin-bottom: 0; font-style: italic;"
  >No comments yet — tap a line to add one.</div>
  {{end}}
  {{if .StreamMode}}
  {{/* Stream-mode terminator. Inline in the top bar on desktop; on mobile it
       lives here (the inline copy is hidden) so the bar isn't crowded by two
       action buttons. Last item, so it's not an accidental tap target. */}}
  <form method="POST">
    <button
      type="submit"
      name="endSession"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconStop"}}</span>
      <span class="menu-label">End session</span>
    </button>
  </form>
  {{end}}
  {{/* Keyboard shortcuts — same toggleKeyboardHelp action as the "?" key and
       the desktop toolbar button. Always available. */}}
  <form method="POST">
    <button
      type="submit"
      name="toggleKeyboardHelp"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon" aria-hidden="true">?</span>
      <span class="menu-label">Keyboard shortcuts</span>
    </button>
  </form>
</div>

{{if .Quitting}}
<div class="banner-stopping" role="status">
  Server stopping… you can close this tab.
</div>
{{end}}

{{if .SessionEnded}}
<div class="banner-stopping" role="status">
  Session ended — Claude has been notified. You can close this tab.
</div>
{{end}}

{{if .Flash}}
<div
  class="toast flash-toast"
  role="status"
  lvt-fx:auto-click="3000:clearFlash"
>
  <span class="toast-msg">{{.Flash}}</span>
  <form method="POST" class="toast-dismiss-form">
    <button
      type="submit"
      name="clearFlash"
      class="toast-dismiss"
      aria-label="Dismiss"
    >
      {{template "iconClose14"}}
    </button>
  </form>
</div>
{{end}}
{{if .DoneWritten}}
<div
  class="toast"
  role="status"
  lvt-fx:auto-click="5000:dismissBanner"
>
  <span class="toast-msg">✓ Handed off → Claude is acting on your comments</span>
  <form method="POST" class="toast-dismiss-form">
    <button
      type="submit"
      name="dismissBanner"
      class="toast-dismiss"
      aria-label="Dismiss"
    >
      {{template "iconClose14"}}
    </button>
  </form>
</div>
{{end}}

{{/* Backdrop is rendered when the drawer is open on mobile. Any tap submits
     CloseFiles via lvt-on:click — simpler and more reliable than a form-wrapped
     button which had submission edge cases. */}}
<div
  class="drawer-backdrop{{if .FileDrawerOpen}} open{{end}}"
  lvt-on:click="closeFiles"
  aria-label="Close file list"
></div>

<div class="layout{{if .FocusMode}} focus-mode{{end}}">
<dialog
  id="files-drawer"
  open
  class="{{if .FileDrawerOpen}}is-open{{end}}"
  lvt-fx:resize="--pr-drawer-w"
  data-resize-handle=".resize-handle"
  data-resize-min="200"
  data-resize-max="560"
  data-resize-store="prereview.drawerW"
>
  <div class="drawer-head">
    <strong>{{len .Files}} file{{if ne (len .Files) 1}}s{{end}}</strong>
    <form method="POST">
      <button
        type="submit"
        name="closeFiles"
        class="outline close-btn"
        aria-label="Close"
      >{{template "iconClose16"}}</button>
    </form>
  </div>
  {{/* View-change to the all-comments overview. Lives at the top of the
       drawer so it's obviously a "switch what's in the viewer" action,
       not a filter (which is the role checkboxes play in the toolbar).
       When already in all-comments view, this button hides — the
       view's own "Back" header button handles returning. */}}
  {{if and (gt (len .Comments) 0) (not .ShowAllComments)}}
  <div class="drawer-all-comments">
    <form method="POST">
      <button
        type="submit"
        name="toggleCommentList"
        class="outline"
        title="Open the all-comments overview"
      >
        💬 All comments ({{len .Comments}})
      </button>
    </form>
  </div>
  {{end}}
  {{/* Base picker — native select so iOS renders the platform wheel
       (a text input opens the keyboard with autofill noise). Options
       come from state.BaseChoices: HEAD~N presets + every local and
       remote-tracking branch, plus the current Base if it was set via
       --base to something not enumerated. Changing it submits
       immediately via lvt-on:change. The old freeform "Custom ref…"
       input was dropped — the enumerated presets cover the real
       cases (incl. origin/main) without the text-input friction. */}}
  {{/* No git base ⇒ no refs to compare against; hide the picker
       entirely (single-file / non-git-directory review). */}}
  {{if not .NoGit}}
  <div class="drawer-base">
    <form method="POST" class="base-select-form">
      <label for="base-input">Base</label>
      <select id="base-input" name="ref" lvt-on:change="setBase">
        {{range .BaseChoices}}
        <option value="{{.}}"{{if eq . $.Base}} selected{{end}}>{{.}}</option>
        {{end}}
      </select>
    </form>
  </div>
  {{end}}
  <div class="drawer-search">
    <form method="POST" lvt-form:preserve>
      <input type="text" name="filter" placeholder="Filter files…" value="{{.FileFilter}}"
             lvt-on:input="setFileFilter" lvt-mod:debounce="200"
             autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
             enterkeyhint="search">
    </form>
  </div>
  {{/* Scope toggle. Only meaningful when the repo has BOTH changed and
       unchanged files — if every file changed (changed == total) or
       none did (changed == 0, scope falls back to all anyway) there's
       nothing to switch between, so hide it. */}}
  {{if and (gt .ChangedFilesCount 0) (lt .ChangedFilesCount (len .Files))}}
  <div class="drawer-scope">
    <form method="POST">
      <button type="submit" name="toggleFileScope" class="scope-toggle{{if not .ShowAllFiles}} is-on{{end}}"
              title="
              {{- if .ShowAllFiles}}Show only files changed vs {{.Base}}
              {{- else}}Show all {{len .Files}} tracked files{{end -}}
              ">
        {{if .ShowAllFiles -}}
        All {{len .Files}} files · show changed only
        {{- else -}}
        Changed {{.ChangedFilesCount}} · show all {{len .Files}}
        {{- end}}
      </button>
    </form>
  </div>
  {{end}}
  <div class="drawer-body">
    {{/* The file browser (folder tree when unfiltered, flat path list while
         filtering) is rendered in Go and injected here. livetemplate flattens
         {{template}} calls at parse time and so cannot host a self-recursive
         tree template; rendering the recursive markup in Go and injecting it
         as template.HTML is the same native-<details> pattern tinkerdown uses
         for its nested nav. The <details lvt-ignore-attrs> open state survives
         re-renders via the upstream morphdom durability fix. */}}
    {{.FileBrowserHTML}}
  </div>
  {{/* Drag handle on the drawer's right edge — the lvt-fx:resize directive
       (livetemplate client) makes it resize the sidebar live, persisting the
       width to localStorage. Desktop-only (hidden under the mobile breakpoint
       where the drawer is an overlay). */}}
  <div class="resize-handle" aria-hidden="true"></div>
</dialog>

<main class="viewer">
{{if .ShowAllComments}}
<section class="all-comments">
  <header class="ac-head">
    <strong>All comments ({{len .Comments}})</strong>
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="toggleCommentList"
        class="outline contrast"
        title="Return to the file you were viewing"
      >Back</button>
    </form>
  </header>
  {{if .VisibleComments}}
  <ul class="ac-list">
    {{range .VisibleComments}}
    <li
      class="ac-item{{if .Resolved}} is-resolved{{end}}"
      data-key="{{.ID}}"
    >
      <form method="POST" class="ac-jump">
        <input type="hidden" name="id" value="{{.ID}}">
        <button type="submit" name="jumpToComment" class="ac-jump-btn">
          <div class="ac-where"><code>{{.File}}</code> · {{.LineSpan}} <small>({{.Side}})</small>
            {{- if .Resolved}} <small class="resolved-badge">resolved</small>{{end}}
            {{- if .AnchorMoved}} <small class="moved-badge">moved</small>{{end}}
            {{- if .AnchorOutdated}} <small class="outdated-badge">outdated</small>{{end -}}
          </div>
          <div class="ac-body">{{.Body}}</div>
        </button>
      </form>
      {{if .AnchorOutdated}}<details class="anchor-orig"><summary>⚠ the document changed here — originally anchored to:</summary><pre>{{.Anchor.Text}}</pre></details>{{end}}
      <div class="ac-actions">
        <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="toggleResolved"
        class="outline"
      >{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>
        {{if and (not .Resolved) .AnchorOutdated -}}
        <form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button
            type="submit"
            name="reanchorComment"
            class="outline"
          >Re-anchor</button>
        </form>
        {{- end}}
        {{if and (not .Resolved) (not .AnchorOutdated) -}}
        <form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button
            type="submit"
            name="editComment"
            class="outline"
          >Edit</button>
        </form>
        {{- end}}
        <button
      type="button"
      class="secondary outline"
      command="show-modal"
      commandfor="confirm-delete-{{.ID}}"
    >Delete</button>
        {{template "deleteDialog" .}}
      </div>
    </li>
    {{end}}
  </ul>
  {{else}}
  {{/* Empty overview: a centered message + a prominent Back so the user
       isn't stranded on a near-blank page with only the small sticky-
       header Back (issue #27). Both empty branches get the Back; the
       resolved-hidden branch keeps its "toggle Show resolved" hint. */}}
  <div class="ac-empty">
    <p class="ac-empty-msg">
      {{- if and (gt (len .Comments) 0) (not .ShowResolved)}}{{len .Comments}} resolved comment{{if ne (len .Comments) 1}}s{{end}} hidden — toggle “Show resolved” to see them.
      {{- else}}No comments yet.
      {{- end -}}
    </p>
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="toggleCommentList"
        class="contrast ac-empty-back"
        title="Return to the file you were viewing"
      >← Back to file</button>
    </form>
  </div>
  {{end}}
</section>
{{else}}
{{with .CurrentDiff}}
<article>
  <header class="file-head">
    <strong>{{.Path}}</strong>
    {{if .Note}}<small>{{.Note}}</small>{{end}}
  </header>
  {{/* File-level comments + composer. Lives above the body branch so
       it's visible for every preview mode (line view, markdown blocks,
       HTML blocks, binary preview, "no diff content" placeholder).
       File-level comments use the same inline-comment markup as the
       line view; the gutter / line badge is replaced with a "file" tag
       via Comment.LineSpan. Edit / Resolve / Delete reuse the existing
       per-comment actions — no new endpoints. */}}
  {{$fcs := $.FileLevelComments}}
  {{$acs := $.AreaComments}}
  {{if or $fcs $acs (eq $.CommentMode "file") (eq $.CommentMode "area")}}
  <section class="file-comments" data-key="file-comments-{{.Path}}">
    {{range $fcs}}{{template "commentCardSimple" .}}{{end}}
    {{range $acs}}{{template "commentCardSimple" .}}{{end}}
    {{if or (eq $.CommentMode "file") (eq $.CommentMode "area")}}{{template "composer" $}}{{end}}
  </section>
  {{end}}
  {{if .IsBinary}}
  {{/* Binary files: now that the HTTP static fallback serves the bytes
       (issue #13), the browser can render images, PDFs, video and audio
       inline. The src is the working-tree path under the repo root,
       served by staticFallback in main.go — its allowlist must stay in
       sync with state.BinaryKind. Unknown binary kinds (zip, etc.)
       still fall back to the cannot-display copy. */}}
  {{$kind := $.BinaryKind}}
  {{if eq $kind "image"}}
  {{/* image-with-areas wrapper: position:relative so .area-overlay
       children (saved areas + the pending selection) land at the
       right CSS coords. lvt-fx:area-select arms the upstream
       directive — pointer-drag → final-coords action via the client's
       send() pipeline. touch-action:none on the img stops iOS Safari
       from interpreting the drag as a pinch/scroll. */}}
  <div class="binary-preview binary-image"><div class="image-with-areas" data-key="iwa-{{.Path}}">
    <img
      src="/{{.Path}}"
      alt="{{.Path}}"
      lvt-fx:area-select="selectImageArea"
      style="touch-action:none;user-select:none;-webkit-user-select:none;"
    >
    {{range $.AreaComments}}<div class="area-overlay{{if .Resolved}} is-resolved{{end}}"
        data-key="ao-{{.ID}}"
        style="left:{{.Area.PercentX}};top:{{.Area.PercentY}};width:{{.Area.PercentW}};height:{{.Area.PercentH}};"
        title="{{.Body}}"></div>{{end}}
    {{if eq $.CommentMode "area"}}<div class="area-overlay area-overlay-pending"
        data-key="ao-pending"
        style="left:{{$.SelectionArea.PercentX}};top:{{$.SelectionArea.PercentY}};width:{{$.SelectionArea.PercentW}};height:{{$.SelectionArea.PercentH}};"></div>{{end}}
  </div></div>
  {{else if eq $kind "pdf"}}
  {{/* Chrome 117+ ships a deliberately-minimal embed viewer for same-
       origin PDFs (compact thumbnail + "Open" button) regardless of
       <embed>/<iframe>/<object> or Content-Disposition: inline — it's
       a PDFium sandbox policy, not something HTML/headers can override.
       PDF.js would unlock the full inline viewer at ~500KB gz cost;
       not worth the bundle weight here. So: clean card with the
       filename and an "Open in new tab" CTA — single click hands off
       to Chrome's full standalone viewer. */}}
  <div class="binary-preview binary-pdf-card">
    <div class="pdf-card-icon" aria-hidden="true">📄</div>
    <strong class="pdf-card-name">{{.Path}}</strong>
    <a
      role="button"
      class="contrast pdf-card-open"
      href="/{{.Path}}"
      target="_blank"
      rel="noopener"
    >Open PDF in new tab →</a>
  </div>
  {{else if eq $kind "video"}}
  <div class="binary-preview binary-video"><video controls preload="metadata" src="/{{.Path}}"></video></div>
  {{else if eq $kind "audio"}}
  <div class="binary-preview binary-audio"><audio controls preload="metadata" src="/{{.Path}}"></audio></div>
  {{else}}
  <p class="empty">Binary file — cannot display.</p>
  {{end}}
  {{else if $.ShowRenderedHTML}}
  {{/* Rendered-HTML view. The whole file renders once in a sandboxed
       <iframe srcdoc> — a real document, so var()/@media/vw/sticky all
       resolve against the iframe viewport (a shadow root can't do this).
       Each top-level <body> child in the srcdoc carries its REAL source
       line range (data-from / data-to). lvt-fx:iframe-autoheight sizes the
       iframe to its content; selecting a region to comment on is driven by
       a parent-document overlay (added in a later phase), not from inside
       the iframe — iOS does not deliver iframe-internal events to parent
       listeners. The sandbox without allow-scripts keeps page <script>
       inert. Comments and the composer render in a list BELOW the preview
       (they can't interleave into the iframe document). */}}
  <div class="html-view" data-key="html-{{.Path}}">
    {{- /* region-select toggle */ -}}
    {{template "regionToggle" $}}
    {{- /* sandboxed iframe preview + draw-a-region overlay */ -}}
    <div class="preview-stage"><iframe
      class="html-preview"
      sandbox="allow-same-origin"
      srcdoc="{{$.RenderedHTMLDoc}}"
      lvt-fx:iframe-autoheight
      title="HTML preview of {{.Path}}"
    ></iframe>
      {{- if $.RegionSelectArmed -}}
      <div
        class="region-overlay"
        lvt-fx:region-select="selectBlock"
        data-surface="html"
        data-key="region-html-{{.Path}}"
      ></div>
      {{- end -}}
    </div>
    {{- /* per-block comment anchors, keyed to source line range */ -}}
    {{- range $.RenderedHTML -}}
    {{$bs := .StartLine}}{{$be := .EndLine}}{{$hbkey := printf "HB-%d-%d" $bs $be -}}
    <div
      class="html-block
      {{- if and
          (ne $.SelectionEndMax 0)
          (ge $.SelectionEndMax $bs)
          (le $.SelectionEndMax $be)}} selected{{end -}}
      "
      data-key="{{$hbkey}}"
    >{{template "blockComments" .}}</div>
    {{- end -}}
  </div>
  {{else if $.ShowRenderedMarkdown}}
  {{/* Rendered-Markdown view. Each top-level block is one clickable
       unit carrying its REAL source line range (data-from/data-to);
       SelectBlock turns that into the normal line-anchored selection,
       so a comment made here round-trips with the raw line view and
       the CSV — nothing is renumbered. Comments/composer interleave
       by source line the same way the line view does, just matched to
       a block's [StartLine,EndLine] span. */}}
  <div class="md-view" data-key="md-{{.Path}}" lvt-spy="h1, h2, h3">
    {{- range $.RenderedMarkdown -}}
    {{$bs := .StartLine}}{{$be := .EndLine}}{{$mbkey := printf "MB-%d-%d" $bs $be -}}
    <div class="md-block
    {{- if and
        (ne $.SelectionEndMax 0)
        (ge $.SelectionEndMax $bs)
        (le $.SelectionEndMax $be)}} selected{{end -}}
    "
         data-key="{{$mbkey}}"
         {{- if eq $.ScrollHeadingBlockKey $mbkey}} lvt-fx:scroll="into-view"{{end}}>
      {{- /* rendered markdown — clicking (or Enter when focused) selects the
             block's source line span. tabindex makes it keyboard-focusable and
             the keydown makes Enter activate it; it deliberately has NO
             role="button" — Pico paints every [role=button] as a filled blue
             button, and this is prose, not a button (it also holds arbitrary
             rendered HTML incl. its own links, which stay independently
             focusable). */ -}}
      <div
        class="md-rendered"
        tabindex="0"
        lvt-on:click="selectBlock"
        lvt-on:keydown="selectBlock"
        lvt-key="Enter"
        data-from="{{$bs}}"
        data-to="{{$be}}"
      >{{.HTML}}</div>
      {{- template "blockComments" . -}}
    </div>
    {{- end -}}
  </div>
  {{else if .Lines}}
  {{/* data-key by path is load-bearing, NOT just a scroll-reset hack:
       per-row keys are "L<old>-<new>" which COLLIDE across files
       (every file has an L1-1, L2-2…). Without a path-scoped key on
       the container, morphdom matches old file's L1-1 to new file's
       L1-1, reuses the node, and the tree-diff leaves stale content —
       you get the previous file's lines bleeding into the new file.
       Keying .code by path forces a clean subtree replace on switch.
       Measured: this costs no extra bandwidth — livetemplate resends
       {{range}} statics on a full content swap regardless of the key.
       Bonus: a fresh element also starts at scroll (0,0). */}}
  <div class="code
    {{- if eq .Note "file added"}} pure-add
    {{- else if eq .Note "file deleted"}} pure-del{{end}}
    {{- if $.FileView}} file-view{{end -}}
    "
       data-key="code-{{.Path}}"
       data-path="{{.Path}}"
       lvt-fx:scroll="reset-on:data-path"
       style="--diff-min-width: calc({{.MaxLineChars}}ch + 7ch)">
    {{- range $.VisibleLines -}}
    {{- if eq .Kind "fold" -}}
    <div
      class="line-row fold-row"
      data-key="F{{.OldNum}}-{{.NewNum}}"
      aria-hidden="true"
    ><span class="fold-label">··· {{.Content}} unchanged line{{if ne .Content "1"}}s{{end}} ···</span></div>
    {{- else -}}
    {{$ln := .NewNum}}{{if not $ln}}{{$ln = .OldNum}}{{end -}}
    <div class="line-row" data-key="row-L{{.OldNum}}-{{.NewNum}}{{if and (ne $.SelectionEndMax 0) (eq $.SelectionEndMax $ln)}}-composing{{end}}">
      {{- /* gutter mark + line number + highlighted code; kept inline because the gutter space and chroma markup are whitespace-significant */ -}}
      {{$lkey := printf "L%d-%d" .OldNum .NewNum -}}
      <button type="button"
              lvt-on:click="selectLine"
              data-line="{{$ln}}"
              data-side="{{if eq .Kind "del"}}old{{else}}new{{end}}"
              class="line {{.Kind}}{{if index $.SelectedLines $ln}} selected{{end}}{{if eq $.CursorKey $lkey}} is-cursor{{end}}"
              {{- if eq $.CursorKey $lkey}} lvt-autofocus lvt-fx:scroll="into-view"{{end}}
              data-key="{{$lkey}}"><span class="gutter"><span class="gutter-mark">{{if eq .Kind "add"}}+{{else if eq .Kind "del"}}-{{else}}&nbsp;{{end}} </span>{{$ln}}</span>
              {{- /* */ -}}<span class="content chroma">{{if .HighlightedContent}}{{.HighlightedContent}}{{else}}{{.Content}}{{end}}</span></button>
      {{- /* comments anchored to this line, then the composer when this line is selected */ -}}
      {{- range (index $.CommentsByEndLine $ln)}}{{template "commentCardFull" .}}{{end -}}
      {{- if and (ne $.SelectionEndMax 0) (eq $.SelectionEndMax $ln) -}}
      {{template "composer" $}}
      {{- end -}}</div>
    {{- /* each code line ends with one trailing newline, as the original markup emitted */}}
{{end -}}
    {{- end -}}
    {{- /* bottom sentinel for the scroll/intersection observer */ -}}
    <div class="code-sentinel" aria-hidden="true"></div>
    {{- /* */ -}}
  </div>
  {{else}}
  <p class="empty"><small>No diff content.</small></p>
  {{end}}
</article>
{{else}}
  {{if .Files}}
  <p class="empty">Pick a file from the list.</p>
  {{else}}
  <div class="empty empty-diff">
    <h3>No files in this repository</h3>
    <p><small>Add some files and refresh, or relaunch prereview pointed at a different repo.</small></p>
  </div>
  {{end}}
{{end}}
{{end}}

{{if and .LastDeletedComment (not .Quitting)}}
<div class="undo-toast" role="status">
  <span>Comment on <code>{{.LastDeletedComment.File}}</code> {{.LastDeletedComment.LineSpan}} deleted</span>
  <form method="POST" style="margin:0;display:inline">
    <button type="submit" name="undoDelete" class="undo-btn">Undo</button>
  </form>
</div>
{{end}}

{{if and .ReanchorCommentID (eq .SelectionEndMax 0)}}
<div class="reanchor-prompt" role="status">
  <span>Re-anchoring — tap the line(s) this comment should attach to.</span>
  <form method="POST" style="margin:0;display:inline">
    <button type="submit" name="clearSelection" class="undo-btn">Cancel</button>
  </form>
</div>
{{end}}
</main>
{{/* TOC sidebar — desktop only (CSS hides it under 900px). Rendered
     only when the document has ≥ 2 headings (h1–h3). The mobile
     overlay below shares the same data; the menu entry that opens it
     uses the same RenderedHeadings gate. */}}
{{/* Desktop TOC sidebar — native anchor scroll only. No server roundtrip
     because the markdown is always in the DOM when this sidebar is
     visible (the .md-view container is the spy host); the lvt-spy-link
     directive's optimistic-activation hand-off relies on a clean click
     event with no intervening morphdom patch. The mobile overlay is a
     different story — see the closeTOC/navigateToHeading split below. */}}
{{with .RenderedHeadings}}
<aside class="toc-sidebar" aria-label="Table of contents">
  <div class="toc-head"><strong>On this page</strong></div>
  <nav class="toc-list">
    {{range .}}<a href="#{{.ID}}" lvt-spy-link class="toc-link toc-l{{.Level}}">{{.Text}}</a>
    {{end}}
  </nav>
</aside>
{{end}}
</div>
{{/* Mobile TOC overlay — full-viewport sheet shown when TOCOpen is true.
     Each link is BOTH an <a href="#id"> (browser performs the native
     anchor scroll when the markdown is already in the DOM) AND
     lvt-on:click="navigateToHeading" — the server action dismisses the
     TOC overlay AND the all-comments view, then sets ScrollToHeadingID
     so the matching MarkdownBlock picks up `lvt-fx:scroll="into-view"`
     on re-render. That second leg is what fixes issue #12: when the
     user opens TOC from inside all-comments, the markdown isn't in the
     DOM yet, so the native anchor scroll misses; the server-driven
     scroll fires after the morph reveals the section. event-delegation.ts
     does not call preventDefault on click, and link-interceptor.ts's
     same-path branch also returns without preventDefault for non-special
     hash targets, so both effects compose cleanly. Backdrop tap closes
     without jumping. */}}
{{with .RenderedHeadings}}
<div
  class="toc-backdrop{{if $.TOCOpen}} is-open{{end}}"
  lvt-on:click="closeTOC"
  aria-hidden="true"
></div>
<div
  class="toc-modal{{if $.TOCOpen}} is-open{{end}}"
  role="dialog"
  aria-label="Table of contents"
  aria-modal="true"
>
  <div class="toc-modal-head">
    <strong>On this page</strong>
    <form method="POST">
      <button
        type="submit"
        name="closeTOC"
        class="outline close-btn"
        aria-label="Close"
      >
        {{template "iconClose16"}}
      </button>
    </form>
  </div>
  <nav class="toc-modal-list">
    {{range .}}<a
      href="#{{.ID}}"
      lvt-spy-link
      lvt-on:click="navigateToHeading"
      data-id="{{.ID}}"
      class="toc-link toc-l{{.Level}}"
    >{{.Text}}</a>
    {{end}}
  </nav>
</div>
{{end}}
{{/* Keyboard-shortcuts help overlay. Driven by KeyHelpOpen (the "?" key and the
     toolbar / more-menu help buttons toggle it; Esc closes it via clearSelection).
     Rows are single-sourced from KeyBindings — the same map that wires the live
     bindings near the top of the body — so the help can't drift from the shortcuts.
     Mirrors the TOC modal's backdrop + dialog structure. */}}
<div
  class="kbd-help-backdrop{{if .KeyHelpOpen}} is-open{{end}}"
  lvt-on:click="toggleKeyboardHelp"
  aria-hidden="true"
></div>
<div
  class="kbd-help-modal{{if .KeyHelpOpen}} is-open{{end}}"
  role="dialog"
  aria-label="Keyboard shortcuts"
  aria-modal="true"
>
  <div class="kbd-help-head">
    <strong>Keyboard shortcuts</strong>
    <form method="POST">
      <button
        type="submit"
        name="toggleKeyboardHelp"
        class="outline close-btn"
        aria-label="Close"
      >
        {{template "iconClose16"}}
      </button>
    </form>
  </div>
  <dl class="kbd-help-list">
    {{- range .KeyBindings}}
    <div class="kbd-row"><dt><kbd>{{.Display}}</kbd></dt><dd>{{.Label}}</dd></div>
    {{- end}}
  </dl>
  <p class="kbd-help-note">Drawing a precise region on rendered HTML or an image needs a mouse — from the keyboard, comment on the whole block or image instead.</p>
</div>
<footer class="app-footer" role="contentinfo">
  prereview{{if ne .Version "dev"}} v{{.Version}}{{end}} · built with <a
    href="https://github.com/livetemplate/livetemplate"
    target="_blank"
    rel="noopener noreferrer"
  >livetemplate</a>
</footer>
{{end}}

<script defer src="/livetemplate-client.js"></script>
{{/* Lazy mermaid renderer; standalone file keeps it out of livetemplate's template tree. See internal/assets/mermaid-init.js. */}}
<script defer src="/mermaid-init.js"></script>
</body>
</html>

{{/*
  Reusable partials for the comment-rendering markup that was duplicated
  across the diff / html / markdown / file / area / all-comments views.
  livetemplate flattens {{template "x" .}} at parse time by inlining the
  define body, so inside a partial `.` is the passed value (a Comment, or a
  rendered block) and `$` still resolves to the root state — read draft /
  selection / scroll state off `$`. Block partials recompute $bs/$be from
  the block's .StartLine/.EndLine since a partial can't see caller locals.
*/}}
