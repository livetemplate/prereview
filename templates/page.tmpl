{{/* FORMATTING — read before reflowing.
     This renders through html/template, which copies static whitespace verbatim
     into the output. Most of the markup is normal-flow HTML where whitespace
     between elements collapses, so it can be broken across lines freely. A few
     spots ARE whitespace-sensitive — a generic formatter (prettier, djlint)
     corrupts them, so do not run one over this file:
       1. the highlighted code text — .content / .chroma is `white-space:
          pre-wrap`, so a newline inside it shows as a real line break;
       2. textarea draft bodies — a newline there is literal draft text;
       3. significant single spaces — e.g. the diff gutter's trailing space;
       4. runs of inline elements — whitespace between them renders as a space.
     Long lines are kept readable two ways, both of which leave the rendered DOM
     unchanged (the only byte differences are whitespace HTML already ignores):
       - attribute-heavy tags are split one attribute per line (whitespace
         between attributes inside a start tag is collapsed by the parser);
       - element structure is broken with Go's whitespace-trim markers; an empty
         trim-trimmed comment between two pure-HTML siblings such as a </form>
         and the next <form> is a "trim carrier" that emits nothing.
     SVG icons live in iconX define blocks at the bottom, inlined at parse. */ -}}
<!DOCTYPE html>
{{/* data-theme=light is PINNED on <html> so Pico's own (un-audited) dark
     palette never activates. The coordinated scheme (data-scheme) and the
     Light/Dark mode (data-mode) live on the .theme-root wrapper INSIDE <body>,
     not here — see that element below and the rationale in prereview.css. Why
     not <html>: livetemplate morphs its managed subtree, so a data-mode on
     <html> would only change on a full reload; on the wrapper it updates live.
     All colors derive from those two attributes — see prereview.css. */}}
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8">
<meta
  name="viewport"
  content="width=device-width, initial-scale=1, viewport-fit=cover"
>
<title>prereview · {{.RepoPath}}</title>
<link rel="stylesheet" href="/pico.min.css">
<link rel="stylesheet" href="/livetemplate.css">
<link rel="stylesheet" href="/syntax.css">
<link rel="stylesheet" href="/prereview.css">
</head>
<body
  data-lvt-loading-debounce-ms="200"
  data-lvt-heartbeat-ms="10000"
>
{{/* .theme-root carries the dynamic theme attributes INSIDE livetemplate's
     managed subtree so the Light/Dark toggle morphs them live (a data-mode on
     <html> would need a full reload). display:contents (prereview.css) keeps it
     boxless so the flex/scroll chain is unchanged; the tokens it sets cascade
     into the whole UI by custom-property inheritance. Both axes are dynamic:
     data-scheme (the curated scheme) and data-mode (Light/Dark/System). */}}
<div class="theme-root" data-scheme="{{.DataScheme}}"{{with .DataMode}} data-mode="{{.}}"{{end}}>
{{/* Global cancel. Esc clears any selection, closes the composer, and
     dismisses the keyboard-help overlay. A guard-free window binding (NOT
     skip-when-typing) so it fires even while the composer textarea is focused,
     and a top-level child of .theme-root — not gated by the external/repo
     split — so it works in both modes. The window scan finds it because it's a
     descendant of the managed wrapper; a binding on <body> itself would be
     missed. Listed in the help overlay via the keymap (Esc has Action ""). */}}
<span class="kbd-esc" hidden aria-hidden="true"
  lvt-on:window:keydown="clearSelection"
  lvt-key="Escape"
></span>

{{if .ExternalMode}}
{{/* --external (live-site) view. The proxied site renders in a cross-origin
     iframe (src = the second-origin proxy); the region overlay is toggle-
     armed (same UX as the HTML preview) so the live page stays interactive
     when off and captures a drawn box when on. lvt-fx:proxy-bridge wires the
     injected beacon's nav (→ setProxyURL) + scroll (→ pin-layer transform).
     Annotations anchor to URL + region (kind=region); the pin layer re-pins
     them on the live page, the sidebar lists them across pages. */}}
<header class="bar bar-external">
  <span class="ext-target">prereview · annotating <code>{{.TargetURL}}</code>
    {{- if .CurrentURL}} <span class="ext-page">{{.CurrentURL}}</span>{{end -}}
  </span>
  <span class="bar-actions">
    {{- /* annotation-count toggle */ -}}
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="toggleAnnotations"
        class="outline secondary anno-toggle"
        aria-pressed="{{if .AnnoDrawerOpen}}true{{else}}false{{end}}"
        title="Show/hide annotations"
      >💬 {{len $.AllRegionComments}}</button>
    </form>
    {{- if .AgentMode -}}
    {{/* Continuous enqueue (#119): annotations stream to the agent as you make
         them; pausing BATCHES them instead (held, sent together on resume) — not
         a stop. Mirrors the repo-mode toolbar. */}}
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="toggleAgentPause"
        class="contrast tb-pause{{if .AgentPaused}} is-paused{{end}}"
        title="{{if .AgentPaused}}Batching — annotations held, not sent. Resume to send the batch.{{else}}Live — each annotation is sent as you make it. Pause to batch them instead.{{end}}"
      >{{if .AgentPaused}}▶ Resume — send batch{{else}}⏸ Pause — batch{{end}}</button>
    </form>
    {{- /* session terminator — opens the confirm dialog (#58) instead of ending
           immediately; the dialog's button fires endSession. */ -}}
    <form method="POST" style="margin:0">
      <button
        type="button"
        command="show-modal"
        commandfor="confirm-end-session"
        class="contrast"
        title="Emit session_end and stop the server — your agent stops consuming the stream"
      >End session</button>
    </form>
    {{- else -}}
    <form method="POST" style="margin:0">
      <button
        type="button"
        command="show-modal"
        commandfor="confirm-quit"
        class="contrast"
        title="Stop the prereview server"
      >Quit</button>
    </form>
    {{- end -}}
  </span>
</header>
<div class="layout layout-external">
  <main class="viewer ext-viewer">
    {{template "regionToggle" $}}
    <div class="preview-stage ext-stage"
         lvt-fx:proxy-bridge="setProxyURL"
         data-key="ext-stage"
         {{- with $.FocusedComment}} data-focus-token="{{$.FocusSeq}}" data-focus-url="{{.URL}}" data-focus-y="{{.Area.Y}}"{{end}}>
      {{/* lvt-ignore: morphdom must never re-process this iframe. Its src is
           set once (SSR); as the user navigates the live site in-app the
           content moves while the src attribute stays put. Without this, any
           server render re-emits src={{`{{.ProxyBaseURL}}`}} and morphdom
           resets the iframe back to the home page. (lvt-ignore-attrs is NOT
           enough — it only back-fills dropped attrs; the template always has
           src, so morphdom would still sync it.) */}}
      <iframe
        class="ext-frame"
        src="{{.ProxyBaseURL}}"
        title="Live preview of {{.TargetURL}}"
        lvt-ignore
      ></iframe>
      <div class="pin-layer" data-pin-layer data-key="pin-layer">
        {{- range $.RegionComments -}}
        <button type="button"
                class="area-overlay pin-btn
                {{- if .Resolved}} is-resolved{{end}}
                {{- if eq $.FocusedCommentID .ID}} is-focused{{end -}}
                "
                lvt-on:click="editComment"
                data-id="{{.ID}}"
                data-key="pin-{{.ID}}"
                style="left:{{.Area.PercentX}};top:{{.Area.PercentY}};width:{{.Area.PercentW}};height:{{.Area.PercentH}};"
                title="{{.Body}}"
                aria-label="Edit annotation"></button>
        {{- end -}}
        {{- if eq $.CommentMode "region" -}}
        <div class="area-overlay area-overlay-pending"
             data-key="pin-pending"
             style="left:{{$.SelectionArea.PercentX}};top:{{$.SelectionArea.PercentY}};width:{{$.SelectionArea.PercentW}};height:{{$.SelectionArea.PercentH}};"></div>
        {{- end -}}
      </div>
      {{if .RegionSelectArmed}}<div
        class="region-overlay"
        lvt-fx:region-select="selectRegion"
        data-surface="page"
        data-key="ext-region-overlay"
      ></div>{{end}}
    </div>
    {{if eq $.CommentMode "region"}}{{template "composer" $}}{{end}}
  </main>
  <aside
    class="ext-sidebar{{if .AnnoDrawerOpen}} is-open{{end}}"
    aria-label="Annotations"
  >
    <header class="ext-sidebar-head"><strong>Annotations ({{len $.AllRegionComments}})</strong>
      {{- /* close annotations */ -}}
      <form method="POST" style="margin:0">
        <button
          type="submit"
          name="toggleAnnotations"
          class="outline secondary close-btn"
          aria-label="Close annotations"
        >{{template "iconClose16"}}</button>
      </form>
    {{- /* */ -}}
    </header>
    <div class="ext-sidebar-body">
      {{- range $.AllRegionComments -}}
      <div
        class="inline-comment ext-anno
        {{- if .Resolved}} is-resolved{{end}}
        {{- if eq $.FocusedCommentID .ID}} is-focused{{end -}}
        "
        data-key="{{.ID}}"
        lvt-fx:animate="fade"
      >
        {{- /* locate form */ -}}
        <form method="POST" class="anno-locate-form">
          <input type="hidden" name="id" value="{{.ID}}">
          <button
            type="submit"
            name="focusComment"
            class="anno-locate"
            title="Locate this region on the page"
          ><span class="ext-page-link">📍 {{.URL}}</span>
          {{- if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}
          {{- /* */ -}}<span class="anno-body">{{.Body}}</span></button>
        </form>
        {{- /* resolve / edit / delete */ -}}
        <div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="toggleResolved"
        class="outline"
      >{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>
          {{- if not .Resolved -}}
          <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="editComment"
        class="outline"
      >Edit</button>
    </form>
          {{- end -}}
          <button
      type="button"
      class="secondary outline"
      command="show-modal"
      commandfor="confirm-delete-{{.ID}}"
    >Delete</button>
          {{- template "deleteDialogTagged" . -}}
        </div></div>
      {{- else -}}
      <p class="empty"><small>No annotations yet — tap “Select a region”, then drag a box on the page.</small></p>
      {{- end -}}
    </div>
  </aside>
</div>
<footer class="app-footer" role="contentinfo"><small>prereview
  {{- if ne .Version "dev"}} v{{.Version}}{{end}} · external mode · <code>{{.TargetURL}}</code></small></footer>
{{else}}
{{/* Keyboard shortcuts — single-sourced from KeyBindings (internal/review/keymap.go),
     which also feeds the help overlay below so the two can't drift. Each global shortcut
     is a hidden window keydown binding carrying lvt-mod:skip-when-typing, so a shortcut
     letter typed into the composer or file filter types the letter instead of firing the
     shortcut. Esc — which must fire while typing to cancel — stays on <body>, not here. */}}
<div class="kbd-bindings" hidden aria-hidden="true">
  {{- range .KeyBindings}}{{$b := .}}{{range $b.Keys}}{{if $b.Action}}<span
    lvt-on:window:keydown="{{$b.Action}}"
    lvt-key="{{.}}"
    lvt-mod:skip-when-typing
  ></span>{{end}}{{end}}{{end -}}
</div>
<header
  class="bar{{if .FileDrawerOpen}} files-collapsed{{end}}"
  lvt-fx:url-hash="setURLHash"
  data-lvt-url-hash="{{.URLHash}}"
>
  <form method="POST">
    <button
      type="submit"
      name="toggleFiles"
      class="hamburger outline contrast"
      aria-label="Toggle files"
    >{{template "iconHamburger"}}</button>
  </form>
  {{/* Search palette trigger (issue #91). Always visible (outside the
       desktop-only toolbar-inline) so it's reachable on a phone too; the Mod+k
       shortcut (documented in the help overlay) is the desktop path. Repo mode
       only — there are no files to search in --external mode. */}}
  {{if not .ExternalMode}}
  <form method="POST">
    <button
      type="submit"
      name="openSearch"
      class="search-btn outline contrast"
      aria-label="Search files"
      title="Search files (⌘/Ctrl + K)"
    >{{template "iconSearch"}}</button>
  </form>
  {{end}}
  <div class="title">
    <span class="title-main">
      {{- if .ShowAllComments}}{{/* No title in all-comments mode — the "Show all comments (N) ☑" checkbox in the toolbar already conveys the view. */}}
      {{- else if .CurrentDiff}}<span class="title-file">{{.CurrentDiff.Path}}</span>
      {{- else}}<small>Pick a file from {{len .Files}} file{{if ne (len .Files) 1}}s{{end}}</small>
      {{- end -}}
    </span>
  </div>
  {{/* Desktop-only inline chip group. On mobile these same actions live
       in the 3-dots overflow menu below — single source of truth, just
       presented in the layout that fits.

       Grouped into .tb-group segments (counters | view toggles) with
       a CSS divider between them; the prev/next and Quit forms below
       form their own groups via .tb-group-divider on first-of-group. */}}
  <div class="toolbar-inline">
    <div class="tb-group tb-counters">
      {{/* File-count status text. The "Show resolved" filter and the
           "⚠ outdated" button used to sit here; they now live in the
           "View ▾" dropdown below (their toggleShowResolved /
           toggleCommentList actions are unchanged), keeping the inline
           bar to one short text chip so it can't crop the right edge. */}}
      <small class="auto-saved-long">{{len .Files}} files{{if gt .ChangedFilesCount 0}} · {{.ChangedFilesCount}} changed{{end}} · {{.ScopeViewedCount}}/{{.ScopeFileCount}} viewed</small>
    </div>
    {{if .CurrentDiff}}
    <div class="tb-group tb-toggles">
      {{/* Native HTML radio groups for view-mode toggles. Auto-submit
           on change via livetemplate's `lvt-on:change` (same pattern as
           the Base picker <select> in the file drawer). Setters
           (SetMarkdownView / SetFileViewMode) read the form's `view`
           field — idempotent, so clicking the already-active radio is a
           genuine no-op (vs. the old toggle action which would have
           flipped). Browser-native radio visuals beat any custom
           segmented control: clear "one of N" affordance, no squish
           bugs, accent-color matches the toolbar contrast. */}}
      {{if .IsMarkdown}}
      <form method="POST" class="tb-radios" aria-label="Markdown view">
        <label><input
          type="radio"
          name="view"
          value="rendered"
          {{if not .RawMarkdown}}checked{{end}}
          lvt-on:change="setMarkdownView"
        >Preview</label>
        <label><input
          type="radio"
          name="view"
          value="raw"
          {{if .RawMarkdown}}checked{{end}}
          lvt-on:change="setMarkdownView"
        >Raw</label>
      </form>
      {{end}}
      {{if .IsHTML}}
      <form method="POST" class="tb-radios" aria-label="HTML view">
        <label><input
          type="radio"
          name="view"
          value="rendered"
          {{if not .RawHTML}}checked{{end}}
          lvt-on:change="setHTMLView"
        >Preview</label>
        <label><input
          type="radio"
          name="view"
          value="raw"
          {{if .RawHTML}}checked{{end}}
          lvt-on:change="setHTMLView"
        >Raw</label>
      </form>
      {{end}}
      {{/* Diff / File inline radios (desktop). Shown for code, HTML-raw, and
           Markdown (raw + preview) — in preview the Diff/File choice gates the
           rendered change-bars (#110), matching what it does in raw. Hidden in
           HTML preview, whose highlight is deferred (it'd be a no-op there). On
           mobile the whole inline bar collapses into the 3-dots menu, which
           carries the same toggle. */}}
      {{if not .ShowRenderedHTML}}
      <form method="POST" class="tb-radios" aria-label="File view">
        <label><input
          type="radio"
          name="view"
          value="diff"
          {{if not .FileView}}checked{{end}}
          lvt-on:change="setFileViewMode"
        >Diff</label>
        <label><input
          type="radio"
          name="view"
          value="file"
          {{if .FileView}}checked{{end}}
          lvt-on:change="setFileViewMode"
        >File</label>
      </form>
      {{end}}
    </div>
    {{end}}
    {{/* "View ▾" dropdown — groups the low-frequency toolbar controls (focus,
         color scheme/mode, comment filters, help) so the inline bar stays to a
         few primary chips and never crops the right edge. Built on the docs'
         client primitive (reference/client-attributes.md): the trigger toggles
         `.open` on the wrapper (closest-match click delegation), click-away
         removes it — NO server state, NO custom JS. The `.open` class lives only
         client-side; prereview has no background re-render, so every morph is
         user-initiated and coincides with a click that already closed the menu
         (item click, click-away, or keyboard action) — hence no lvt-ignore-attrs.
         The same six actions are mirrored in the mobile .more-menu below; this is
         the desktop presentation (the wrapper sits in desktop-only .toolbar-inline).
         aria-expanded is intentionally omitted: a client class-toggle can't keep
         it in sync. */}}
    <div
      class="tb-dropdown"
      lvt-el:toggleClass:on:click="open"
      lvt-el:removeClass:on:click-away="open"
    >
      <button
        type="button"
        class="contrast theme-toggle tb-dropdown-trigger"
        aria-haspopup="menu"
        title="View options — focus, color scheme &amp; mode, comment filters, help"
      ><span class="tb-label">View</span>{{template "iconChevronDown"}}</button>
      <div class="tb-dropdown-panel" role="menu" aria-label="View options">
        {{if .CurrentDiff}}
        {{/* Focus — hide the side columns for distraction-free reading. Gated
             on an open file (with none open the drawer is the only way to pick
             one). Label flips, same as the old inline button. */}}
        <form method="POST">
          <button
            type="submit"
            name="toggleFocusMode"
            class="menu-item{{if .FocusMode}} is-on{{end}}"
            role="menuitem"
          >
            <span class="menu-icon">{{template "iconFocus"}}</span>
            <span class="menu-label">{{if .FocusMode}}Exit focus{{else}}Focus{{end}}{{with index $.KeyHint "toggleFocusMode"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
          </button>
        </form>
        {{end}}
        {{/* Color scheme + mode — cycle Solarized → Gruvbox → Catppuccin and
             System → Light → Dark; meta shows what the next click switches to.
             Always shown (global reading preferences, useful before any file). */}}
        <form method="POST">
          <button
            type="submit"
            name="cycleScheme"
            class="menu-item"
            role="menuitem"
          >
            <span class="menu-icon">{{template "iconPalette"}}</span>
            <span class="menu-label">Scheme: {{.SchemeLabel}}</span>
            <span class="menu-meta">{{.NextSchemeLabel}} →</span>
          </button>
        </form>
        <form method="POST">
          <button
            type="submit"
            name="cycleTheme"
            class="menu-item"
            role="menuitem"
          >
            <span class="menu-icon">{{if eq .ThemeMode "light"}}{{template "iconThemeLight"}}{{else if eq .ThemeMode "dark"}}{{template "iconThemeDark"}}{{else}}{{template "iconThemeSystem"}}{{end}}</span>
            <span class="menu-label">Mode: {{.ThemeModeLabel}}</span>
            <span class="menu-meta">{{.NextThemeModeLabel}} →</span>
          </button>
        </form>
        {{/* All comments — the desktop view-all entry, mirroring the file
             drawer's "All comments" button and the mobile menu (same
             toggleCommentList action). Surfacing it here also makes it reachable
             in Focus mode, where the drawer is hidden. Label flips to "Back"
             while the all-comments view is open. */}}
        {{if gt (len .Comments) 0}}
        <form method="POST">
          <button
            type="submit"
            name="toggleCommentList"
            class="menu-item{{if .ShowAllComments}} is-on{{end}}"
            role="menuitem"
          >
            <span class="menu-icon">{{template "iconComments"}}</span>
            <span class="menu-label">{{if .ShowAllComments}}Back{{else}}All comments{{end}}{{with index $.KeyHint "toggleCommentList"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
            <span class="menu-meta">{{len .Comments}}</span>
          </button>
        </form>
        {{end}}
        {{/* Show-resolved FILTER — toggles whether resolved comments appear in
             the view (toggleShowResolved, unchanged from the old inline checkbox). */}}
        {{if gt .ResolvedCount 0}}
        <form method="POST">
          <button
            type="submit"
            name="toggleShowResolved"
            class="menu-item{{if .ShowResolved}} is-on{{end}}"
            role="menuitem"
          >
            <span class="menu-icon">{{if .ShowResolved}}{{template "iconCheck"}}{{else}}{{template "iconCircle16"}}{{end}}</span>
            <span class="menu-label">{{if .ShowResolved}}Hide resolved{{else}}Show resolved{{end}}{{with index $.KeyHint "toggleShowResolved"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
            <span class="menu-meta">{{.ResolvedCount}}</span>
          </button>
        </form>
        {{end}}
        {{/* Unhide individually-hidden resolved comments (issue #88). Only while
             Show-resolved is ON and at least one resolved comment is re-hidden. */}}
        {{if and .ShowResolved (gt .HiddenResolvedCount 0)}}
        <form method="POST">
          <button
            type="submit"
            name="unhideAllResolved"
            class="menu-item"
            role="menuitem"
          >
            <span class="menu-icon">{{template "iconCircle16"}}</span>
            <span class="menu-label">Unhide</span>
            <span class="menu-meta">{{.HiddenResolvedCount}}</span>
          </button>
        </form>
        {{end}}
        {{/* Suggestions toggle (issue #98) — show/hide the LLM's inline suggestion
             boxes on this file. Only when the file has suggestions. */}}
        {{if gt .SuggestionCount 0}}
        <form method="POST">
          <button
            type="submit"
            name="toggleSuggestions"
            class="menu-item{{if not .HideSuggestions}} is-on{{end}}"
            role="menuitem"
          >
            <span class="menu-icon">{{template "iconSuggestion"}}</span>
            <span class="menu-label">{{if .HideSuggestions}}Show suggestions{{else}}Hide suggestions{{end}}{{with index $.KeyHint "toggleSuggestions"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
            <span class="menu-meta">{{.SuggestionCount}}</span>
          </button>
        </form>
        {{end}}
        {{/* #151: hide/show the per-line count badges + their inline cards on this
             file, so the diff reads clean. Only when the file has badges. */}}
        {{if $.HasMarks}}
        <form method="POST">
          <button
            type="submit"
            name="toggleMarks"
            class="menu-item{{if not .HideMarks}} is-on{{end}}"
            role="menuitem"
          >
            <span class="menu-icon">{{if .HideMarks}}{{template "iconCircle16"}}{{else}}{{template "iconCheck"}}{{end}}</span>
            <span class="menu-label">{{if .HideMarks}}Show annotations{{else}}Hide annotations{{end}}{{with index $.KeyHint "toggleMarks"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
          </button>
        </form>
        {{end}}
        {{/* Show individually-hidden suggestions on this file (hide feature). Only
             when at least one suggestion is hidden. */}}
        {{if gt .HiddenSuggestionCount 0}}
        <form method="POST">
          <button
            type="submit"
            name="showHiddenSuggestions"
            class="menu-item"
            role="menuitem"
          >
            <span class="menu-icon">{{template "iconSuggestion"}}</span>
            <span class="menu-label">Show hidden suggestions</span>
            <span class="menu-meta">{{.HiddenSuggestionCount}}</span>
          </button>
        </form>
        {{end}}
        {{/* Recorded suggestion decisions (issue #98 Phase 2). Neutral copy — the
             hand-off doesn't carry them until Phase 3. */}}
        {{if gt .DecisionCount 0}}
        <div class="menu-info sg-decision-count">{{.DecisionCount}} suggestion decision{{if ne .DecisionCount 1}}s{{end}} recorded</div>
        {{end}}
        {{/* Outdated comments needing re-anchoring (toggleCommentList, unchanged). */}}
        {{if and (gt .OutdatedCount 0) (not .ShowAllComments)}}
        <form method="POST">
          <button
            type="submit"
            name="toggleCommentList"
            class="menu-item"
            role="menuitem"
            title="{{.OutdatedCount}} comment{{if ne .OutdatedCount 1}}s{{end}} need re-anchoring — open the list to fix"
          >
            <span class="menu-icon">{{template "iconWarning"}}</span>
            <span class="menu-label">Outdated</span>
            <span class="menu-meta">{{.OutdatedCount}}</span>
          </button>
        </form>
        {{end}}
        {{/* Keyboard shortcuts — same toggleKeyboardHelp action as the "?" key. */}}
        <form method="POST">
          <button
            type="submit"
            name="toggleKeyboardHelp"
            class="menu-item"
            role="menuitem"
          >
            <span class="menu-icon" aria-hidden="true">?</span>
            <span class="menu-label">Keyboard shortcuts</span>
          </button>
        </form>
        {{/* Usage guide — a standalone page (/_usage), new tab so the review
             session is left intact. A plain link, not a POST action. */}}
        <a class="menu-item" role="menuitem" href="/_usage" target="_blank" rel="noopener">
          <span class="menu-icon">{{template "iconBook"}}</span>
          <span class="menu-label">Usage guide</span>
        </a>
      </div>
    </div>
  </div>
  {{/* "Comment on file" used to live here; it now sits in the file header
       (.file-head) next to the filename, which declutters the toolbar. */}}
  {{if gt (len .Files) 1}}
  <form method="POST" class="nav-prev">
    <button
      type="submit"
      name="prevFile"
      title="Previous file"
      aria-label="Previous file"
      class="contrast"
    >{{template "iconChevronLeft"}}<span class="nav-label">Prev{{with index $.KeyHint "prevFile"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span></button>
  </form>
  <form method="POST" class="nav-next">
    <button
      type="submit"
      name="nextFile"
      title="Next file"
      aria-label="Next file"
      class="contrast"
    ><span class="nav-label">Next{{with index $.KeyHint "nextFile"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>{{template "iconChevronRight"}}</button>
  </form>
  {{end}}
  {{/* Work queue (#119) — the hub for a continuous-enqueue session: what's queued
       / worked-on / held as drafts, PLUS Pause/Resume and End session. A direct
       child of the bar (reachable on mobile) placed AFTER the flex:1 .title so it
       sits on the RIGHT — its panel opens over the content, clear of the file
       drawer (the bar's z-index sits below the drawer's, so a left-opening panel
       would render behind it). */}}
  {{if .AgentMode}}
  <div
    class="tb-dropdown queue-dropdown{{if .AgentPaused}} is-paused{{end}}"
    lvt-el:toggleClass:on:click="open"
    lvt-el:removeClass:on:click-away="open"
  >
    <button
      type="button"
      {{- /* #129: id embeds the enqueue tick so morphdom recreates the button on
             each genuine enqueue, replaying its CSS pulse (.queue-trigger's
             animation) — a persistent node otherwise animates only once. */}}
      id="queue-trigger-{{.EnqueueTick}}"
      class="contrast tb-dropdown-trigger queue-trigger{{if .AgentWorking}} is-working{{end}}{{if .AgentPaused}} is-paused{{end}}"
      aria-haspopup="menu"
      title="{{if .AgentPaused}}Batching — comments held, not sent. {{end}}Work queue: queued, worked-on, drafts; Pause/Resume + End session inside"
    >{{if .AgentPaused}}<span class="queue-paused-dot" aria-hidden="true">⏸</span>{{end}}<span class="tb-label">Queue</span>{{if .HasQueue}}<span class="queue-counts"><span class="q-num q-queued">{{.QueuedCount}}</span>{{if .DoneCount}} · <span class="q-num q-done">{{.DoneCount}}</span>{{end}}{{if .DraftCount}} · <span class="q-num q-draft">{{.DraftCount}}</span>{{end}}</span>{{end}}{{template "iconChevronDown"}}</button>
    <div class="tb-dropdown-panel queue-panel" role="menu" aria-label="Work queue">
      {{/* Pause = batch, not stop (#119). Live: each comment is sent to the agent
           as you save it. Paused: comments are held and batched; resume sends the
           accumulated batch in one go. The button says what it does; the mode line
           below says which state you're in. */}}
      <form method="POST" class="queue-pause-form">
        <button type="submit" name="toggleAgentPause" class="queue-pause-btn{{if .AgentPaused}} is-paused{{end}}">{{if .AgentPaused}}▶ Resume — send batch{{if .QueuedCount}} ({{.QueuedCount}}){{end}}{{else}}⏸ Pause — batch comments{{end}}{{with index $.KeyHint "toggleAgentPause"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</button>
      </form>
      <div class="queue-mode{{if .AgentPaused}} is-batching{{end}}">{{if .AgentPaused}}Batching: comments are held, not sent. Resume sends them together.{{else}}Live: each comment is sent to the agent as you save it.{{end}}</div>
      {{if .AgentWorking}}<div class="queue-working">⚡ Agent working…</div>{{end}}
      {{if .HasQueue}}
      <div class="queue-legend"><span class="q-num q-queued">{{.QueuedCount}}</span> queued · <span class="q-num q-done">{{.DoneCount}}</span> done{{if .DraftCount}} · <span class="q-num q-draft">{{.DraftCount}}</span> draft{{end}}</div>
      {{range .QueueItems}}
      {{/* queue-kind-* is the row's kind hook — read by the e2e today, and the
           styling hook the collapsed-suggestion badge (M4.2/M4.3) will target. */}}
      <div class="queue-row queue-{{.State}} queue-kind-{{.Kind}}">
        <form method="POST" class="queue-jump-form">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="{{if eq .Kind "suggestion"}}jumpToSuggestion{{else}}jumpToComment{{end}}" class="queue-item" title="Go to this {{.Kind}}">
            {{if eq .Kind "suggestion"}}<span class="queue-kind-icon" aria-hidden="true">✦</span>{{end}}
            <span class="queue-badge queue-badge-{{.State}}">{{.State}}</span>
            <span class="queue-body">{{.Body}}</span>
            <span class="queue-loc" title="{{.File}}{{if .Line}}:{{.Line}}{{end}}">{{.File}}{{if .Line}}:{{.Line}}{{end}}</span>
          </button>
        </form>
        {{- if and (eq .State "done") (eq .Kind "comment")}}
        {{/* Re-enqueue (#119): put a done comment back on the queue for the agent to redo.
             A done SUGGESTION is "applied" — undoing that is a revert, not a re-enqueue, so
             it has no ↺ here (the revert lands on the collapsed-badge popup, M4.2). */}}
        <form method="POST" class="queue-reenqueue-form">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="reenqueueComment" class="queue-reenqueue" title="Re-enqueue — ask the agent to redo this" aria-label="Re-enqueue">↺</button>
        </form>
        {{- end}}
      </div>
      {{end}}
      {{else}}
      <div class="queue-empty">Nothing queued yet — comments you add stream to the agent automatically.</div>
      {{end}}
      {{/* End session — the terminator, grouped at the bottom of the hub. Opens
           the confirm dialog (endSession fires from there). */}}
      <button type="button" command="show-modal" commandfor="confirm-end-session" class="queue-end-btn" role="menuitem">End session</button>
    </div>
  </div>
  {{else}}
  <form method="POST" class="tb-action">
    <button
      type="button"
      command="show-modal"
      commandfor="confirm-quit"
      class="contrast"
      title="Stop the prereview server"
    >Quit</button>
  </form>
  {{end}}
  {{/* 3-dots trigger — mobile only (hidden on desktop via CSS). Placed
       last so it visually anchors the right edge of the toolbar; the
       menu opens directly below it (also right-edge aligned). Uses an
       SVG icon — the `⋮` unicode glyph renders zero-width on iOS Safari's
       UI font. */}}
  <form method="POST" style="margin:0">
    <button
      type="submit"
      name="toggleMoreMenu"
      class="more-trigger"
      aria-label="More options"
      aria-haspopup="menu"
      aria-expanded="{{if .MoreMenuOpen}}true{{else}}false{{end}}"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <circle cx="12" cy="5" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="12" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="19" r="1.8" fill="currentColor"/>
      </svg>
    </button>
  </form>
</header>

{{/* Mobile overflow menu. Backdrop sibling tap closes it. Both have the
     same `.is-open` class flip so they appear/disappear together. Desktop
     CSS forces display:none on both so the inline chips own the chrome.

     Icons are inline SVG (not Unicode glyphs like ⋮ ✓ ○) — iOS Safari's
     UI font sometimes renders those zero-width or substitutes them with
     emoji, which carry their own color and ignore CSS `color`. SVG with
     `fill: currentColor` honors the menu-item color cascade. */}}
<div
  class="more-menu-backdrop{{if .MoreMenuOpen}} is-open{{end}}"
  lvt-on:click="closeMoreMenu"
  aria-hidden="true"
></div>
<div
  class="more-menu{{if .MoreMenuOpen}} is-open{{end}}"
  role="menu"
  aria-label="More options"
>
  <div class="menu-info">{{len .Files}} files{{if gt .ChangedFilesCount 0}} · {{.ChangedFilesCount}} changed{{end}} · {{.ScopeViewedCount}}/{{.ScopeFileCount}} viewed
    {{- if gt (len .Comments) 0}} · {{len .Comments}} comment{{if ne (len .Comments) 1}}s{{end}}{{end -}}
  </div>
  {{/* Prev/Next file moved here from the bar on mobile (#119) so the narrow bar
       stays tidy (☰ 🔍 Queue Pause ⋮). Pause/resume + End session stay inline
       (there's room). Desktop keeps these inline (this menu is display:none
       ≥900px); their bar copies are hidden <900px via CSS. */}}
  {{if gt (len .Files) 1}}
  <form method="POST">
    <button type="submit" name="prevFile" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconChevronLeft"}}</span>
      <span class="menu-label">Previous file</span>
    </button>
  </form>
  <form method="POST">
    <button type="submit" name="nextFile" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconChevronRight"}}</span>
      <span class="menu-label">Next file</span>
    </button>
  </form>
  {{end}}
  {{/* Color scheme + mode — mirror the desktop toolbar palette + sun/moon.
       Scheme cycles Solarized → Gruvbox → Catppuccin; mode cycles
       System → Light → Dark; meta shows what the next tap switches to.
       First items so they're always reachable regardless of the open file. */}}
  <form method="POST">
    <button
      type="submit"
      name="cycleScheme"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconPalette"}}</span>
      <span class="menu-label">Scheme: {{.SchemeLabel}}</span>
      <span class="menu-meta">{{.NextSchemeLabel}} →</span>
    </button>
  </form>
  <form method="POST">
    <button
      type="submit"
      name="cycleTheme"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{if eq .ThemeMode "light"}}{{template "iconThemeLight"}}{{else if eq .ThemeMode "dark"}}{{template "iconThemeDark"}}{{else}}{{template "iconThemeSystem"}}{{end}}</span>
      <span class="menu-label">Mode: {{.ThemeModeLabel}}</span>
      <span class="menu-meta">{{.NextThemeModeLabel}} →</span>
    </button>
  </form>
  {{if .CurrentDiff}}
  {{/* "Comment on file" now lives in the sticky file header (.file-head),
       reachable on mobile too — so it's no longer mirrored in this menu. */}}
  {{with .RenderedHeadings}}
  {{/* Mobile-only entry — desktop renders the TOC as a permanent right
       sidebar, so this is `display: none` ≥900px via the media query.
       OpenTOC closes the more-menu in the same action so the dropdown
       doesn't stay drawn over the overlay it just summoned. */}}
  <form method="POST">
    <button
      type="submit"
      name="openTOC"
      class="menu-item toc-menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconTOC"}}</span>
      <span class="menu-label">Table of contents</span>
      <span class="menu-meta">{{len .}}</span>
    </button>
  </form>
  {{end}}
  {{if .IsMarkdown}}
  <form method="POST">
    <button
      type="submit"
      name="toggleRawMarkdown"
      class="menu-item{{if not .RawMarkdown}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">
        {{if .RawMarkdown}}
        {{template "iconRendered"}}
        {{else}}
        {{template "iconViewRaw"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .RawMarkdown}}Preview{{else}}View raw source{{end}}</span>
    </button>
  </form>
  {{end}}
  {{if .IsHTML}}
  <form method="POST">
    <button
      type="submit"
      name="toggleRawHTML"
      class="menu-item{{if not .RawHTML}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">
        {{if .RawHTML}}
        {{template "iconRendered"}}
        {{else}}
        {{template "iconViewRaw"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .RawHTML}}Preview{{else}}View raw source{{end}}</span>
    </button>
  </form>
  {{end}}
  {{if not .ShowRenderedHTML}}
  <form method="POST">
    <button
      type="submit"
      name="toggleFileView"
      class="menu-item{{if .FileView}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">
        {{if .FileView}}
        {{/* Diff icon (split rectangles with plus/minus) — shown when current view is plain file. */}}
        {{template "iconDiff"}}
        {{else}}
        {{/* File icon (document) — shown when current view is diff. */}}
        {{template "iconFile"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .FileView}}Show diff{{else}}View file{{end}}</span>
    </button>
  </form>
  {{end}}
  {{end}}
  {{if gt (len .Comments) 0}}
  <form method="POST">
    <button
      type="submit"
      name="toggleCommentList"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconComments"}}</span>
      <span class="menu-label">{{if .ShowAllComments}}Back{{else}}All comments{{end}}{{with index $.KeyHint "toggleCommentList"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
      <span class="menu-meta">{{len .Comments}}</span>
    </button>
  </form>
  {{end}}
  {{if gt .ResolvedCount 0}}
  <form method="POST">
    <button
      type="submit"
      name="toggleShowResolved"
      class="menu-item{{if .ShowResolved}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">
        {{if .ShowResolved}}
        {{template "iconCheck"}}
        {{else}}
        {{template "iconCircle16"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .ShowResolved}}Hide resolved{{else}}Show resolved{{end}}{{with index $.KeyHint "toggleShowResolved"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
      <span class="menu-meta">{{.ResolvedCount}}</span>
    </button>
  </form>
  {{end}}
  {{/* Unhide individually-hidden resolved comments (issue #88). */}}
  {{if and .ShowResolved (gt .HiddenResolvedCount 0)}}
  <form method="POST">
    <button
      type="submit"
      name="unhideAllResolved"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconCircle16"}}</span>
      <span class="menu-label">Unhide</span>
      <span class="menu-meta">{{.HiddenResolvedCount}}</span>
    </button>
  </form>
  {{end}}
  {{/* Suggestions toggle (issue #98) — mobile more-menu mirror. */}}
  {{if gt .SuggestionCount 0}}
  <form method="POST">
    <button
      type="submit"
      name="toggleSuggestions"
      class="menu-item{{if not .HideSuggestions}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconSuggestion"}}</span>
      <span class="menu-label">{{if .HideSuggestions}}Show suggestions{{else}}Hide suggestions{{end}}</span>
      <span class="menu-meta">{{.SuggestionCount}}</span>
    </button>
  </form>
  {{end}}
  {{/* #151: hide/show the per-line count badges + inline cards — more-menu mirror. */}}
  {{if $.HasMarks}}
  <form method="POST">
    <button
      type="submit"
      name="toggleMarks"
      class="menu-item{{if not .HideMarks}} is-on{{end}}"
      role="menuitem"
    >
      <span class="menu-icon">{{if .HideMarks}}{{template "iconCircle16"}}{{else}}{{template "iconCheck"}}{{end}}</span>
      <span class="menu-label">{{if .HideMarks}}Show annotations{{else}}Hide annotations{{end}}</span>
    </button>
  </form>
  {{end}}
  {{/* Show individually-hidden suggestions — mobile more-menu mirror. */}}
  {{if gt .HiddenSuggestionCount 0}}
  <form method="POST">
    <button
      type="submit"
      name="showHiddenSuggestions"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon">{{template "iconSuggestion"}}</span>
      <span class="menu-label">Show hidden suggestions</span>
      <span class="menu-meta">{{.HiddenSuggestionCount}}</span>
    </button>
  </form>
  {{end}}
  {{if gt .DecisionCount 0}}
  <div class="menu-info sg-decision-count">{{.DecisionCount}} suggestion decision{{if ne .DecisionCount 1}}s{{end}} recorded</div>
  {{end}}
  {{if and (eq (len .Comments) 0) (eq .ResolvedCount 0)}}
  <div
    class="menu-info"
    style="border-bottom: 0; margin-bottom: 0; font-style: italic;"
  >No comments yet — tap a line to add one.</div>
  {{end}}
  {{/* End session now lives in the Queue dropdown (the session hub) — reachable
       on mobile too since that dropdown is a direct child of the bar. */}}
  {{/* Keyboard shortcuts — same toggleKeyboardHelp action as the "?" key and
       the desktop toolbar button. Always available. */}}
  <form method="POST">
    <button
      type="submit"
      name="toggleKeyboardHelp"
      class="menu-item"
      role="menuitem"
    >
      <span class="menu-icon" aria-hidden="true">?</span>
      <span class="menu-label">Keyboard shortcuts</span>
    </button>
  </form>
  {{/* Usage guide — standalone /_usage page, opened in a new tab. */}}
  <a class="menu-item" role="menuitem" href="/_usage" target="_blank" rel="noopener">
    <span class="menu-icon">{{template "iconBook"}}</span>
    <span class="menu-label">Usage guide</span>
  </a>
</div>

{{if .Quitting}}
<div class="banner-stopping" role="status">
  Server stopping… you can close this tab.
</div>
{{end}}

{{if .SessionEnded}}
<div class="banner-stopping" role="status">
  Session ended — Claude has been notified. You can close this tab.
</div>
{{end}}

{{if .Flash}}
<div
  class="toast flash-toast"
  role="status"
  lvt-fx:auto-click="3000:clearFlash"
>
  <span class="toast-msg">{{.Flash}}</span>
  <form method="POST" class="toast-dismiss-form">
    <button
      type="submit"
      name="clearFlash"
      class="toast-dismiss"
      aria-label="Dismiss"
    >
      {{template "iconClose14"}}
    </button>
  </form>
</div>
{{end}}
{{if and .AgentMode (eq .LLMState "working")}}
<div class="toast llm-working" role="status" aria-live="polite">
  <span class="llm-spinner" aria-hidden="true"></span>
  <span class="toast-msg">{{if .LLMMessage}}{{.LLMMessage}}{{else}}Working on your handoff…{{end}}</span>
</div>
{{end}}

{{/* Backdrop is rendered when the drawer is open on mobile. Any tap submits
     CloseFiles via lvt-on:click — simpler and more reliable than a form-wrapped
     button which had submission edge cases. */}}
<div
  class="drawer-backdrop{{if .FileDrawerOpen}} open{{end}}"
  lvt-on:click="closeFiles"
  aria-label="Close file list"
></div>

<div class="layout{{if .FocusMode}} focus-mode{{end}}{{if .HideMarks}} marks-hidden{{end}}{{if .ShowResolved}} show-resolved{{end}}">
<dialog
  id="files-drawer"
  open
  class="{{if .FileDrawerOpen}}is-open{{end}}"
  lvt-fx:resize="--pr-drawer-w"
  data-resize-handle=".resize-handle"
  data-resize-min="200"
  data-resize-max="560"
  data-resize-store="prereview.drawerW"
>
  <div class="drawer-head">
    <strong>{{len .Files}} file{{if ne (len .Files) 1}}s{{end}}</strong>
    <form method="POST">
      <button
        type="submit"
        name="closeFiles"
        class="outline close-btn"
        aria-label="Close"
      >{{template "iconClose16"}}</button>
    </form>
  </div>
  {{/* The all-comments overview button used to live here, but the sidebar is for
       files (#111) — it's reachable from the toolbar "View ▾" dropdown, the mobile
       ⋮ menu, and the `a` shortcut. */}}
  {{/* Base picker — native select so iOS renders the platform wheel
       (a text input opens the keyboard with autofill noise). Options
       come from state.BaseChoices: HEAD~N presets + every local and
       remote-tracking branch, plus the current Base if it was set via
       --base to something not enumerated. Changing it submits
       immediately via lvt-on:change. The old freeform "Custom ref…"
       input was dropped — the enumerated presets cover the real
       cases (incl. origin/main) without the text-input friction. */}}
  {{/* No git base ⇒ no refs to compare against; hide the picker
       entirely (single-file / non-git-directory review). */}}
  {{if not .NoGit}}
  <div class="drawer-base">
    <form method="POST" class="base-select-form">
      <label for="base-input">Base</label>
      <select id="base-input" name="ref" lvt-on:change="setBase">
        {{range .BaseChoices}}
        <option value="{{.}}"{{if eq . $.Base}} selected{{end}}>{{.}}</option>
        {{end}}
      </select>
    </form>
  </div>
  {{end}}
  <div class="drawer-search">
    <form method="POST" lvt-form:preserve>
      <input type="text" name="filter" placeholder="Filter files…" value="{{.FileFilter}}"
             lvt-on:input="setFileFilter" lvt-mod:debounce="200"
             autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
             enterkeyhint="search">
    </form>
  </div>
  {{/* Scope toggle. Only meaningful when the repo has BOTH changed and
       unchanged files — if every file changed (changed == total) or
       none did (changed == 0, scope falls back to all anyway) there's
       nothing to switch between, so hide it. */}}
  {{if and (gt .ChangedFilesCount 0) (lt .ChangedFilesCount (len .Files))}}
  <div class="drawer-scope">
    <form method="POST">
      <button type="submit" name="toggleFileScope" class="scope-toggle{{if not .ShowAllFiles}} is-on{{end}}"
              title="
              {{- if .ShowAllFiles}}Show only files changed vs {{.Base}}
              {{- else}}Show all {{len .Files}} tracked files{{end -}}
              ">
        {{if .ShowAllFiles -}}
        All {{len .Files}} files · show changed only
        {{- else -}}
        Changed {{.ChangedFilesCount}} · show all {{len .Files}}
        {{- end}}
      </button>
    </form>
  </div>
  {{end}}
  <div class="drawer-body">
    {{/* The file browser (folder tree when unfiltered, flat path list while
         filtering) is rendered in Go and injected here. livetemplate flattens
         {{template}} calls at parse time and so cannot host a self-recursive
         tree template; rendering the recursive markup in Go and injecting it
         as template.HTML is the same native-<details> pattern tinkerdown uses
         for its nested nav. The <details lvt-ignore-attrs> open state survives
         re-renders via the upstream morphdom durability fix. */}}
    {{.FileBrowserHTML}}
  </div>
  {{/* Drag handle on the drawer's right edge — the lvt-fx:resize directive
       (livetemplate client) makes it resize the sidebar live, persisting the
       width to localStorage. Desktop-only (hidden under the mobile breakpoint
       where the drawer is an overlay). */}}
  <div class="resize-handle" aria-hidden="true"></div>
</dialog>

<main class="viewer"
      {{- /* #128 read progress: report the visible line keys as the reviewer
             scrolls so the server can track how far they've read + where they left
             off. .viewer is the scroll container; .line rows carry the keys. */}}
      lvt-fx:viewport-report="reportViewport"
      {{- /* track both the code-view lines AND the preview-view markdown blocks;
             only one renders at a time, and both carry a data-key the server
             parses to a source line (L<old>-<new> / MB-<start>-<end>). */}}
      data-lvt-viewport-items=".line, .md-block">
{{if .ShowAllComments}}
<section class="all-comments">
  <header class="ac-head">
    <strong>All comments ({{len .Comments}})</strong>
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="toggleCommentList"
        class="outline contrast"
        title="Return to the file you were viewing"
      >Back</button>
    </form>
  </header>
  {{if .VisibleComments}}
  <ul class="ac-list">
    {{range .VisibleComments}}
    <li
      class="ac-item{{if .Resolved}} is-resolved{{end}}"
      data-key="{{.ID}}"
    >
      <form method="POST" class="ac-jump">
        <input type="hidden" name="id" value="{{.ID}}">
        <button type="submit" name="jumpToComment" class="ac-jump-btn">
          <div class="ac-where"><code>{{.File}}</code> · {{.LineSpan}} <small>({{.Side}})</small>
            {{- if .Resolved}} <small class="resolved-badge">resolved</small>{{end}}
            {{- if .AnchorMoved}} <small class="moved-badge">moved</small>{{end}}
            {{- if .AnchorOutdated}} <small class="outdated-badge">outdated</small>{{end}}
            {{- if .Processed}} <small class="processed-badge">worked on</small>{{end -}}
          </div>
          <div class="ac-body">{{.Body}}</div>
        </button>
      </form>
      {{if .AnchorOutdated}}<details class="anchor-orig"><summary>⚠ the document changed here — originally anchored to:</summary><pre>{{.Anchor.Text}}</pre></details>{{end}}
      <div class="ac-actions">
        <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button
        type="submit"
        name="toggleResolved"
        class="outline"
      >{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>
        {{if .Resolved -}}
        <form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button
            type="submit"
            name="hideComment"
            class="outline"
          >Hide</button>
        </form>
        {{- end}}
        {{if and (not .Resolved) .AnchorOutdated -}}
        <form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button
            type="submit"
            name="reanchorComment"
            class="outline"
          >Re-anchor</button>
        </form>
        {{- end}}
        {{if and (not .Resolved) (not .AnchorOutdated) -}}
        <form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button
            type="submit"
            name="editComment"
            class="outline"
          >Edit</button>
        </form>
        {{- end}}
        <button
      type="button"
      class="secondary outline"
      command="show-modal"
      commandfor="confirm-delete-{{.ID}}"
    >Delete</button>
        {{template "deleteDialog" .}}
      </div>
    </li>
    {{end}}
  </ul>
  {{else}}
  {{/* Empty overview: a centered message + a prominent Back so the user
       isn't stranded on a near-blank page with only the small sticky-
       header Back (issue #27). Both empty branches get the Back; the
       resolved-hidden branch keeps its "toggle Show resolved" hint. */}}
  <div class="ac-empty">
    <p class="ac-empty-msg">
      {{- if and (gt (len .Comments) 0) (not .ShowResolved)}}{{len .Comments}} resolved comment{{if ne (len .Comments) 1}}s{{end}} hidden — toggle “Show resolved” to see them.
      {{- else}}No comments yet.
      {{- end -}}
    </p>
    <form method="POST" style="margin:0">
      <button
        type="submit"
        name="toggleCommentList"
        class="contrast ac-empty-back"
        title="Return to the file you were viewing"
      >← Back to file</button>
    </form>
  </div>
  {{end}}
</section>
{{else}}
{{with .CurrentDiff}}
<article>
  <header class="file-head">
    {{- /* #128: reading-progress fill along the header's bottom edge. Absolutely
           positioned (out of the flex flow), so it never shifts the header. */ -}}
    {{- if gt $.ReadPercent 0}}<div class="read-progress-fill" style="width: {{$.ReadPercent}}%" aria-hidden="true"></div>{{end -}}
    {{- /* Directory prefix muted + truncatable, basename bold + always in full,
           so a long/deep path never wraps into a multi-line block (see .fh-dir /
           .fh-base). Title carries the full path for hover/long-press. */ -}}
    <span class="file-head-name" title="{{.Path}}">{{if $.SelectedFileDir}}<span class="fh-dir">{{$.SelectedFileDir}}</span>{{end}}<strong class="fh-base">{{$.SelectedFileBase}}</strong>{{if .Note}} <small>{{.Note}}</small>{{end}}</span>
    {{/* Right-aligned action group: comment-on-file + the versions control. Both
         are compact chips sharing one row so the sticky header stays a single
         thin line on every viewport. */}}
    <span class="file-head-actions">
    {{/* #128: jump to the read frontier — the first unread content. Shown only
         when the file is partly read (some progress, not all), so it never
         clutters a fresh or finished file. */}}
    {{if $.HasReadFrontier}}
    <form method="POST" class="file-head-resume">
      <button
        type="submit"
        name="jumpToReadFrontier"
        class="outline"
        title="Jump to the first content you haven't read yet"
      >{{template "iconChevronDown"}}<span class="resume-label">Jump to unread</span></button>
    </form>
    {{end}}
    {{/* Comment on the whole file — sits in context next to the filename. Hidden
         while the file composer is already open (self-toggle loop) or while
         viewing a historical version (read-only). */}}
    {{if and (ne $.CommentMode "file") (not $.ViewingVersion)}}
    <form method="POST" class="file-head-comment">
      <button
        type="submit"
        name="openFileComment"
        class="contrast"
        title="Add a comment about the whole file"
        aria-label="Comment on file"
      >{{template "iconChat14"}}<span class="file-head-comment-label">Comment on file{{with index $.KeyHint "openFileComment"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span></button>
    </form>
    {{end}}
    {{/* #147: "Ask for suggestions" — pick a prebuilt prompt; it pre-fills the file
         composer (tweak/scope, then Save) and the agent answers with inline
         suggestions. Reuses the View-dropdown client primitive (lvt-el toggle +
         click-away, no server state). Hidden while the file composer is open or a
         historical version is shown, and only when prompts exist. */}}
    {{if and (ne $.CommentMode "file") (not $.ViewingVersion) $.Prompts}}
    <div
      class="tb-dropdown prompts-dropdown"
      lvt-el:toggleClass:on:click="open"
      lvt-el:removeClass:on:click-away="open"
    >
      <button
        type="button"
        class="prompts-trigger"
        aria-haspopup="menu"
        title="Ask the agent for suggestions using a prebuilt prompt"
      >{{template "iconSuggestion"}}<span class="prompts-trigger-label">Ask for suggestions</span></button>
      <div class="tb-dropdown-panel prompts-panel" role="menu" aria-label="Suggestion prompts">
        {{range $.Prompts}}
        <form method="POST"><input type="hidden" name="slug" value="{{.Slug}}"><button type="submit" name="pickPrompt" class="prompt-row" title="{{.Body}}">{{.Title}}</button></form>
        {{end}}
      </div>
    </div>
    {{end}}
    {{/* Versions panel (#90): the selected file's version timeline with view +
         rollback. Reuses the View-dropdown client primitive (lvt-el toggle +
         click-away, no server state, no custom JS). A compact chip (history icon
         + count) matching the comment button; label hides on mobile. Only shows
         once the file has recorded history. */}}
    {{if $.Versions}}
    <div
      class="tb-dropdown versions-dropdown"
      lvt-el:toggleClass:on:click="open"
      lvt-el:removeClass:on:click-away="open"
    >
      <button
        type="button"
        class="versions-trigger"
        aria-haspopup="menu"
        title="Versions of this file — view or roll back to a previous version"
      >{{template "iconHistory14"}}<span class="versions-trigger-label">Versions</span><span class="versions-count">{{len $.Versions}}</span></button>
      <div class="tb-dropdown-panel versions-panel" role="menu" aria-label="File versions">
        {{/* #155: the row is compact by default (label · time · ⋯); the ⋯ toggle
             expands it INLINE to reveal what changed + the actions, so the busy
             three-button row no longer crowds every entry. Client-only lvt-el toggle
             (like the parent dropdown) — a click inside the panel is not a click-away,
             so it expands the row without closing the Versions dropdown. */}}
        {{range $.Versions}}
        <div class="version-row{{if .Viewing}} viewing{{end}}">
          <button
            type="button"
            class="version-summary-toggle"
            lvt-el:toggleClass:on:click="expanded"
            data-lvt-target="closest:.version-row"
            aria-label="Show what changed and version actions"
          ><span class="version-meta">
            <span class="version-label">{{.Label}}{{if .Deleted}} · deleted{{end}}</span>
            <span class="version-when">{{.When}}{{if .Current}} · current{{end}}</span>
          </span><span class="version-more" aria-hidden="true">⋯</span></button>
          <div class="version-details">
            {{if .Changelog}}<p class="version-changelog">{{.Changelog}}</p>{{end}}
            <div class="version-summary">{{template "versionSummary" .Summary}}</div>
            <span class="version-actions">
              <form method="POST"><input type="hidden" name="seq" value="{{.Seq}}"><button type="submit" name="viewVersion" class="version-btn">View</button></form>
              {{if not .Current}}<form method="POST"><input type="hidden" name="seq" value="{{.Seq}}"><button type="submit" name="diffVersion" class="version-btn">Diff</button></form>
              <form method="POST"><input type="hidden" name="seq" value="{{.Seq}}"><button type="submit" name="restoreVersion" class="version-btn version-restore">Restore</button></form>{{end}}
            </span>
          </div>
        </div>
        {{end}}
      </div>
    </div>
    {{end}}
    </span>
  </header>
  {{if $.ViewingVersion}}
  {{/* Read-only banner while viewing a historical version. Commenting is gated
       off (line coords don't match disk); this is the way back to the live diff. */}}
  <div class="version-view-banner" role="status">
    <span>{{if $.VersionViewDiff}}Comparing a previous version against the current file (read-only).{{else}}Viewing a previous version (read-only).{{end}}</span>
    <form method="POST" class="toast-dismiss-form"><button type="submit" name="exitVersionView" class="refresh-btn">Back to current</button></form>
  </div>
  {{end}}
  {{/* File-level comments + composer. Lives above the body branch so
       it's visible for every preview mode (line view, markdown blocks,
       HTML blocks, binary preview, "no diff content" placeholder).
       File-level comments use the same inline-comment markup as the
       line view; the gutter / line badge is replaced with a "file" tag
       via Comment.LineSpan. Edit / Resolve / Delete reuse the existing
       per-comment actions — no new endpoints. */}}
  {{$fcs := $.FileLevelComments}}
  {{$acs := $.AreaComments}}
  {{/* The file composer opens as a blocking modal (below), not inline here — a
       mid-page scroll position used to leave it off-screen. Area mode keeps its
       inline composer (it anchors to the image region). This section still lists
       existing file/area comment cards. */}}
  {{if or $fcs $acs (eq $.CommentMode "area")}}
  <section class="file-comments" data-key="file-comments-{{.Path}}">
    {{range $fcs}}{{template "commentCardSimple" .}}{{end}}
    {{range $acs}}{{template "commentCardSimple" .}}{{end}}
    {{if eq $.CommentMode "area"}}{{template "composer" $}}{{end}}
  </section>
  {{end}}
  {{/* File-comment modal (#—): pressing `c` opens a blocking, viewport-centered
       composer so it's reachable regardless of scroll position. Backdrop click /
       Esc / Cancel / Save all close it (clearSelection resets CommentMode). The
       backdrop is a sibling BEHIND the card (like .more-menu-backdrop) so a click
       on the card doesn't bubble to close. Stable data-keys keep the textarea node
       identity across the debounced saveDraft re-render (focus/cursor survive). */}}
  {{if eq $.CommentMode "file"}}
  <div class="fc-modal-backdrop" data-key="fc-modal-backdrop" lvt-on:click="clearSelection" aria-hidden="true"></div>
  <div class="fc-modal" data-key="fc-modal" role="dialog" aria-modal="true" aria-label="Comment on file">
    {{template "composer" $}}
  </div>
  {{end}}
  {{if .IsBinary}}
  {{/* Binary files: now that the HTTP static fallback serves the bytes
       (issue #13), the browser can render images, PDFs, video and audio
       inline. The src is the working-tree path under the repo root,
       served by staticFallback in main.go — its allowlist must stay in
       sync with state.BinaryKind. Unknown binary kinds (zip, etc.)
       still fall back to the cannot-display copy. */}}
  {{$kind := $.BinaryKind}}
  {{if eq $kind "image"}}
  {{/* Annotable image with two modes via the shared region toggle (issue #57).
       DISARMED (default): the <img> carries no capture directive and no
       touch-action lock, so touch pinch-zooms / scrolls to examine the image
       natively (the viewport allows user scaling) — previously every touch
       started a comment and the image couldn't be zoomed. ARMED: the
       lvt-fx:area-select directive + touch-action:none capture a pointer drag
       into a region comment. Mirrors how the rendered-HTML / external views
       gate their capture overlay. The saved-area overlays render in BOTH modes
       so existing comments stay visible while zooming; only NEW capture is
       gated. position:relative on .image-with-areas anchors the % overlays. */}}
  {{template "regionToggle" $}}
  {{- if not $.RegionSelectArmed}}<small class="region-hint">Pinch or scroll to zoom; use the button above to comment on a region.</small>{{end -}}
  <div class="binary-preview binary-image"><div class="image-with-areas{{if $.RegionSelectArmed}} is-armed{{end}}" data-key="iwa-{{.Path}}">
    <img
      src="/{{.Path}}"
      alt="{{.Path}}"
      {{if $.RegionSelectArmed}}lvt-fx:area-select="selectImageArea" style="touch-action:none;user-select:none;-webkit-user-select:none;"{{else}}style="user-select:none;-webkit-user-select:none;"{{end}}
    >
    {{range $.AreaComments}}<div class="area-overlay{{if .Resolved}} is-resolved{{end}}"
        data-key="ao-{{.ID}}"
        style="left:{{.Area.PercentX}};top:{{.Area.PercentY}};width:{{.Area.PercentW}};height:{{.Area.PercentH}};"
        title="{{.Body}}"></div>{{end}}
    {{if eq $.CommentMode "area"}}<div class="area-overlay area-overlay-pending"
        data-key="ao-pending"
        style="left:{{$.SelectionArea.PercentX}};top:{{$.SelectionArea.PercentY}};width:{{$.SelectionArea.PercentW}};height:{{$.SelectionArea.PercentH}};"></div>{{end}}
  </div></div>
  {{else if eq $kind "pdf"}}
  {{/* Chrome 117+ ships a deliberately-minimal embed viewer for same-
       origin PDFs (compact thumbnail + "Open" button) regardless of
       <embed>/<iframe>/<object> or Content-Disposition: inline — it's
       a PDFium sandbox policy, not something HTML/headers can override.
       PDF.js would unlock the full inline viewer at ~500KB gz cost;
       not worth the bundle weight here. So: clean card with the
       filename and an "Open in new tab" CTA — single click hands off
       to Chrome's full standalone viewer. */}}
  <div class="binary-preview binary-pdf-card">
    <div class="pdf-card-icon" aria-hidden="true">📄</div>
    <strong class="pdf-card-name">{{.Path}}</strong>
    <a
      role="button"
      class="contrast pdf-card-open"
      href="/{{.Path}}"
      target="_blank"
      rel="noopener"
    >Open PDF in new tab →</a>
  </div>
  {{else if eq $kind "video"}}
  <div class="binary-preview binary-video"><video controls preload="metadata" src="/{{.Path}}"></video></div>
  {{else if eq $kind "audio"}}
  <div class="binary-preview binary-audio"><audio controls preload="metadata" src="/{{.Path}}"></audio></div>
  {{else}}
  <p class="empty">Binary file — cannot display.</p>
  {{end}}
  {{else if $.ShowRenderedHTML}}
  {{/* Rendered-HTML view. The whole file renders once in a sandboxed
       <iframe srcdoc> — a real document, so var()/@media/vw/sticky all
       resolve against the iframe viewport (a shadow root can't do this).
       Each top-level <body> child in the srcdoc carries its REAL source
       line range (data-from / data-to). The sandbox is allow-scripts WITHOUT
       allow-same-origin: the page's own scripts RUN (so JS-generated CSS like
       the Tailwind Play CDN renders, #63) but the opaque origin blocks all
       access to the parent app. That also means the parent can't read the
       iframe's contentDocument, so lvt-fx:preview-bridge takes the height +
       block rects the in-iframe beacon (previewBridgeJS) posts out. Selecting
       a region to comment on is driven by a parent-document overlay, not from
       inside the iframe — iOS does not deliver iframe-internal events to parent
       listeners. Comments and the composer render in a list BELOW the preview
       (they can't interleave into the iframe document). */}}
  <div class="html-view" data-key="html-{{.Path}}">
    {{- /* region-select toggle */ -}}
    {{template "regionToggle" $}}
    {{- /* sandboxed iframe preview + draw-a-region overlay */ -}}
    <div class="preview-stage"><iframe
      class="html-preview"
      sandbox="allow-scripts"
      srcdoc="{{$.RenderedHTMLDoc}}"
      lvt-fx:preview-bridge
      title="HTML preview of {{.Path}}"
    ></iframe>
      {{- if $.RegionSelectArmed -}}
      <div
        class="region-overlay"
        lvt-fx:region-select="selectBlock"
        data-surface="html"
        data-key="region-html-{{.Path}}"
      ></div>
      {{- end -}}
    </div>
    {{- /* per-block comment anchors, keyed to source line range */ -}}
    {{- range $.RenderedHTML -}}
    {{$bs := .StartLine}}{{$be := .EndLine}}{{$hbkey := printf "HB-%d-%d" $bs $be -}}
    <div
      class="html-block
      {{- if and
          (ne $.SelectionEndMax 0)
          (ge $.SelectionEndMax $bs)
          (le $.SelectionEndMax $be)}} selected{{end -}}
      "
      data-key="{{$hbkey}}"
    >{{template "blockComments" .}}{{template "blockSuggestions" .}}</div>
    {{- end -}}
  </div>
  {{else if $.ShowRenderedMarkdown}}
  {{/* Rendered-Markdown view. Each top-level block is one clickable
       unit carrying its REAL source line range (data-from/data-to);
       SelectBlock turns that into the normal line-anchored selection,
       so a comment made here round-trips with the raw line view and
       the CSV — nothing is renumbered. Comments/composer interleave
       by source line the same way the line view does, just matched to
       a block's [StartLine,EndLine] span. */}}
  {{- /* text-select on the rendered view: a native selection resolves to the
         touched blocks' source line range (data-surface="block"), so a phrase
         can be commented on in Preview too — not just the raw/code view. Columns
         don't apply (rendered text != source), so it anchors line-level with the
         phrase quoted. */ -}}
  <div class="md-view" data-key="md-{{.Path}}" lvt-spy="h1, h2, h3"
       lvt-fx:text-select="selectText" data-surface="block">
    {{- range $.RenderedMarkdown -}}
    {{$bs := .StartLine}}{{$be := .EndLine}}{{$mbkey := printf "MB-%d-%d" $bs $be -}}
    {{$mbstatus := index $.BlockDiffStatus $mbkey -}}
    <div class="md-block
    {{- if and
        (ne $.SelectionEndMax 0)
        (ge $.SelectionEndMax $bs)
        (le $.SelectionEndMax $be)}} selected{{end -}}
    {{- if $mbstatus}} md-{{$mbstatus}}{{end -}}
    "
         data-key="{{$mbkey}}"
         {{- if or (eq $.ScrollHeadingBlockKey $mbkey) (eq $.ScrollToReadKey $mbkey)}} lvt-fx:scroll="into-view"{{end}}>
      {{- /* #165: the md-view has no gutter, so each block carries a state badge in its
             top-right — yellow if any open annotation, else green — counting the block's
             comments/suggestions. Clicking peeks the done cards (peek-done on the block,
             client-only). Done cards auto-collapse via CSS (like the diff view). */ -}}
      {{- $ba := index $.BlockAnnotations $mbkey -}}
      {{- if gt $ba.Total 0 -}}
      <button type="button" class="md-block-marks"
              lvt-el:toggleClass:on:click="peek-done"
              data-lvt-target="closest:.md-block"
              aria-label="Show or hide resolved and accepted annotations in this block"
              title="Show/hide resolved &amp; accepted annotations">
        <span class="line-mark{{if $ba.Open}} is-open{{else if $ba.Accepted}} is-accepted{{else}} is-done{{end}}" aria-hidden="true">{{$ba.Total}}</span>
      </button>
      {{- end -}}
      {{- /* rendered markdown — clicking (or Enter when focused) selects the
             block's source line span. tabindex makes it keyboard-focusable and
             the keydown makes Enter activate it; it deliberately has NO
             role="button" — Pico paints every [role=button] as a filled blue
             button, and this is prose, not a button (it also holds arbitrary
             rendered HTML incl. its own links, which stay independently
             focusable). */ -}}
      <div
        class="md-rendered"
        tabindex="0"
        lvt-on:click="selectBlock"
        lvt-on:keydown="selectBlock"
        lvt-key="Enter"
        data-from="{{$bs}}"
        data-to="{{$be}}"
      >{{.HTML}}</div>
      {{- template "blockComments" . -}}
      {{- template "blockSuggestions" . -}}
    </div>
    {{- end -}}
  </div>
  {{else if .Lines}}
  {{/* data-key by path is load-bearing, NOT just a scroll-reset hack:
       per-row keys are "L<old>-<new>" which COLLIDE across files
       (every file has an L1-1, L2-2…). Without a path-scoped key on
       the container, morphdom matches old file's L1-1 to new file's
       L1-1, reuses the node, and the tree-diff leaves stale content —
       you get the previous file's lines bleeding into the new file.
       Keying .code by path forces a clean subtree replace on switch.
       Measured: this costs no extra bandwidth — livetemplate resends
       {{range}} statics on a full content swap regardless of the key.
       Bonus: a fresh element also starts at scroll (0,0). */}}
  <div class="code
    {{- if eq .Note "file added"}} pure-add
    {{- else if eq .Note "file deleted"}} pure-del{{end}}
    {{- if $.FileView}} file-view{{end -}}
    "
       data-key="code-{{.Path}}"
       data-path="{{.Path}}"
       lvt-fx:scroll="reset-on:data-path"
       lvt-fx:text-select="selectText"
       style="--diff-min-width: calc({{.MaxLineChars}}ch + 7ch)">
    {{- range $.VisibleLines -}}
    {{- if eq .Kind "fold" -}}
    <div
      class="line-row fold-row"
      data-key="F{{.OldNum}}-{{.NewNum}}"
      aria-hidden="true"
    ><span class="fold-label">··· {{.Content}} unchanged line{{if ne .Content "1"}}s{{end}} ···</span></div>
    {{- else -}}
    {{$ln := .NewNum}}{{if not $ln}}{{$ln = .OldNum}}{{end -}}
    {{- /* $lside is this row's diff side (matches data-side). A diff line
           number is NOT unique — a modified line exists as both a del (old)
           and an add (new) row with the same $ln — so the composer, cards, and
           composing-marker must also match the SELECTED side, or they render
           on both rows. */ -}}
    {{$lside := "new"}}{{if eq .Kind "del"}}{{$lside = "old"}}{{end -}}
    {{- /* #151: how many comments / suggestions render on THIS row (this line, this
           side)? CommentCountLines/SuggestionCountLines are keyed "<line>-<side>" and
           are built from the SAME filtered maps the card ranges below render, so a
           badge's number matches what actually renders on the row (never both
           old+new). $hasComment/$hasSuggestion (count>0) drive the #136 presence gate.
           A zero-arg map lookup — NOT an assign-inside-range, which breaks the
           framework's live render. */ -}}
    {{$rowkey := printf "%d-%s" $ln $lside -}}
    {{$commentCount := index $.CommentCountLines $rowkey -}}
    {{$suggestionCount := index $.SuggestionCountLines $rowkey -}}
    {{$hasComment := gt $commentCount 0 -}}
    {{$hasSuggestion := gt $suggestionCount 0 -}}
    {{$lkey := printf "L%d-%d" .OldNum .NewNum -}}
    <div class="line-row{{if or $hasComment $hasSuggestion}} has-line-marks{{end}}" data-key="row-L{{.OldNum}}-{{.NewNum}}{{if and (ne $.SelectionEndMax 0) (eq $.SelectionEndMax $ln) (eq $.SelectionSide $lside)}}-composing{{end}}">
      {{- /* gutter mark + line number + highlighted code; kept inline because the gutter space and chroma markup are whitespace-significant */ -}}
      {{- /* A selectable div (not <button>): <button> content is non-
             selectable in UA styles, which would block native text selection.
             Same pattern as .md-rendered above — tabindex + click/keydown so
             collapsed activation still selects the whole line, while a
             non-collapsed drag is caught by lvt-fx:text-select on .code.
             data-line-text marks the text container so text-select's column
             count excludes the gutter. */ -}}
      <div tabindex="0"
              lvt-on:click="selectLine"
              lvt-on:keydown="selectLine"
              lvt-key="Enter"
              data-line="{{$ln}}"
              data-side="{{if eq .Kind "del"}}old{{else}}new{{end}}"
              class="line {{.Kind}}{{if index $.SelectedLines $ln}} selected{{end}}{{if eq $.CursorKey $lkey}} is-cursor{{end}}"
              {{- if eq $.CursorKey $lkey}} lvt-autofocus lvt-fx:scroll="into-view"{{else if eq $.ScrollToReadKey $lkey}} lvt-fx:scroll="into-view"{{end}}
              data-key="{{$lkey}}"><span class="gutter"><span class="gutter-mark">{{if eq .Kind "add"}}+{{else if eq .Kind "del"}}-{{else}}&nbsp;{{end}} </span>{{$ln}}</span>
              {{- /* */ -}}<span class="content chroma" data-line-text>{{index $.LineDisplay $lkey}}</span></div>
      {{- /* #165: ONE state-coloured right-margin badge per line — the TOTAL annotation
             count (comments + suggestions), coloured YELLOW when any are open (unresolved
             comment / unaccepted suggestion) or GREEN when all are done. Done cards
             auto-collapse (CSS by state class); clicking the badge toggles `peek-done`
             on the row (client-only) to reveal them. Sibling of .line so the click
             can't bubble to selectLine; sits in the reserved right padding. */ -}}
      {{- if or $hasComment $hasSuggestion -}}
      <span class="line-margin">
        <button type="button" class="line-marks{{if index $.AwaitingLines $rowkey}} has-unread{{end}}"
                lvt-el:toggleClass:on:click="peek-done"
                data-lvt-target="closest:.line-row"
                aria-label="Show or hide resolved and accepted annotations on this line"
                title="Show/hide resolved &amp; accepted annotations on this line">
          <span class="line-mark{{if index $.AnnotationOpenLines $rowkey}} is-open{{else if index $.AnnotationAcceptedLines $rowkey}} is-accepted{{else}} is-done{{end}}" aria-hidden="true">{{index $.AnnotationCountLines $rowkey}}</span>
        </button>
      </span>
      {{- end -}}
      {{- /* comments anchored to this line (on THIS side), then the composer when
             this line+side is selected — both gated on $lside so a modified line's
             old/new rows don't each render the same card/composer */ -}}
      {{- range (index $.CommentsByEndLine $ln)}}{{if or (eq .Side $lside) (eq .Side "")}}{{template "commentCardFull" .}}{{end}}{{end -}}
      {{- /* LLM suggestion boxes anchored to this line (on THIS side) */ -}}
      {{- range (index $.SuggestionsByEndLine $ln)}}{{if or (eq .Side $lside) (eq .Side "")}}{{template "suggestionCard" .}}{{end}}{{end -}}
      {{- if and (ne $.SelectionEndMax 0) (eq $.SelectionEndMax $ln) (eq $.SelectionSide $lside) -}}
      {{template "composer" $}}
      {{- end -}}</div>
    {{- /* each code line ends with one trailing newline, as the original markup emitted */}}
{{end -}}
    {{- end -}}
    {{- /* bottom sentinel for the scroll/intersection observer */ -}}
    <div class="code-sentinel" aria-hidden="true"></div>
    {{- /* */ -}}
  </div>
  {{else}}
  <p class="empty"><small>No diff content.</small></p>
  {{end}}
</article>
{{else}}
  {{if .Files}}
  <p class="empty">Pick a file from the list.</p>
  {{else}}
  <div class="empty empty-diff">
    <h3>No files in this repository</h3>
    <p><small>Add some files and refresh, or relaunch prereview pointed at a different repo.</small></p>
  </div>
  {{end}}
{{end}}
{{end}}

{{if and .LastDeletedComment (not .Quitting)}}
<div class="undo-toast" role="status">
  <span>Comment on <code>{{.LastDeletedComment.File}}</code> {{.LastDeletedComment.LineSpan}} deleted</span>
  <span class="toast-actions">
    <form method="POST" style="margin:0;display:inline">
      <button type="submit" name="undoDelete" class="undo-btn">Undo</button>
    </form>
    <form method="POST" class="toast-dismiss-form">
      <button type="submit" name="dismissUndo" class="toast-dismiss" aria-label="Dismiss">{{template "iconClose14"}}</button>
    </form>
  </span>
</div>
{{end}}

{{if and .ReanchorCommentID (eq .SelectionEndMax 0)}}
<div class="reanchor-prompt" role="status">
  <span>Re-anchoring — tap the line(s) this comment should attach to.</span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="clearSelection" class="toast-dismiss" aria-label="Cancel re-anchoring">{{template "iconClose14"}}</button>
  </form>
</div>
{{end}}
{{if .PendingRefresh}}
{{/* Frozen-view nudge (#119): the agent edited files ON DISK; this view is
     deliberately still showing the pre-edit version so scroll/drafts survive.
     Say that plainly — the old "✓ Changes applied" read as "already in your
     view" and made the frozen view look like a leak (live-test feedback). */}}
<div class="reanchor-prompt refresh-prompt" role="status">
  <span>The agent edited files on disk. This view still shows the earlier version — refresh to see the changes.</span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="refreshDiff" class="refresh-btn">Refresh diff</button>
  </form>
</div>
{{end}}
{{if .AgentPaused}}
{{/* Paused = batching (#119): comments are held, not sent one-by-one. Set only
     by the manual Pause toggle — a rollback no longer force-pauses (send-mode is
     decoupled from rollback; see RestoreVersion). The wording describes the
     STATE (batching), not any cause. Resume releases the held batch in one
     snapshot. */}}
<div class="reanchor-prompt paused-prompt" role="status">
  <span>⏸ Batching — comments are held, not sent to the agent yet.</span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="resumeAgent" class="refresh-btn">Resume — send batch</button>
  </form>
</div>
{{end}}
</main>
{{/* TOC sidebar — desktop only (CSS hides it under 900px). Rendered
     only when the document has ≥ 2 headings (h1–h3). The mobile
     overlay below shares the same data; the menu entry that opens it
     uses the same RenderedHeadings gate. */}}
{{/* Desktop TOC sidebar — native anchor scroll only. No server roundtrip
     because the markdown is always in the DOM when this sidebar is
     visible (the .md-view container is the spy host); the lvt-spy-link
     directive's optimistic-activation hand-off relies on a clean click
     event with no intervening morphdom patch. The mobile overlay is a
     different story — see the closeTOC/navigateToHeading split below. */}}
{{with .RenderedHeadings}}
<aside class="toc-sidebar" aria-label="Table of contents">
  <div class="toc-head"><strong>On this page</strong></div>
  <nav class="toc-list">
    {{range .}}<a href="#{{.ID}}" lvt-spy-link class="toc-link toc-l{{.Level}}">{{.Text}}</a>
    {{end}}
  </nav>
</aside>
{{end}}
</div>
{{/* Mobile TOC overlay — full-viewport sheet shown when TOCOpen is true.
     Each link is BOTH an <a href="#id"> (browser performs the native
     anchor scroll when the markdown is already in the DOM) AND
     lvt-on:click="navigateToHeading" — the server action dismisses the
     TOC overlay AND the all-comments view, then sets ScrollToHeadingID
     so the matching MarkdownBlock picks up `lvt-fx:scroll="into-view"`
     on re-render. That second leg is what fixes issue #12: when the
     user opens TOC from inside all-comments, the markdown isn't in the
     DOM yet, so the native anchor scroll misses; the server-driven
     scroll fires after the morph reveals the section. event-delegation.ts
     does not call preventDefault on click, and link-interceptor.ts's
     same-path branch also returns without preventDefault for non-special
     hash targets, so both effects compose cleanly. Backdrop tap closes
     without jumping. */}}
{{with .RenderedHeadings}}
<div
  class="toc-backdrop{{if $.TOCOpen}} is-open{{end}}"
  lvt-on:click="closeTOC"
  aria-hidden="true"
></div>
<div
  class="toc-modal{{if $.TOCOpen}} is-open{{end}}"
  role="dialog"
  aria-label="Table of contents"
  aria-modal="true"
>
  <div class="toc-modal-head">
    <strong>On this page</strong>
    <form method="POST">
      <button
        type="submit"
        name="closeTOC"
        class="outline close-btn"
        aria-label="Close"
      >
        {{template "iconClose16"}}
      </button>
    </form>
  </div>
  <nav class="toc-modal-list">
    {{range .}}<a
      href="#{{.ID}}"
      lvt-spy-link
      lvt-on:click="navigateToHeading"
      data-id="{{.ID}}"
      class="toc-link toc-l{{.Level}}"
    >{{.Text}}</a>
    {{end}}
  </nav>
</div>
{{end}}
{{/* Keyboard-shortcuts help overlay. Driven by KeyHelpOpen (the "?" key and the
     toolbar / more-menu help buttons toggle it; Esc closes it via clearSelection).
     Rows are single-sourced from KeyBindings — the same map that wires the live
     bindings near the top of the body — so the help can't drift from the shortcuts.
     Mirrors the TOC modal's backdrop + dialog structure. */}}
<div
  class="kbd-help-backdrop{{if .KeyHelpOpen}} is-open{{end}}"
  lvt-on:click="toggleKeyboardHelp"
  aria-hidden="true"
></div>
<div
  class="kbd-help-modal{{if .KeyHelpOpen}} is-open{{end}}"
  role="dialog"
  aria-label="Keyboard shortcuts"
  aria-modal="true"
>
  <div class="kbd-help-head">
    <strong>Keyboard shortcuts</strong>
    <form method="POST">
      <button
        type="submit"
        name="toggleKeyboardHelp"
        class="outline close-btn"
        aria-label="Close"
      >
        {{template "iconClose16"}}
      </button>
    </form>
  </div>
  <dl class="kbd-help-list">
    {{- range .KeyBindings}}
    <div class="kbd-row"><dt><kbd>{{.Display}}</kbd></dt><dd>{{.Label}}</dd></div>
    {{- end}}
  </dl>
  <p class="kbd-help-note">Drawing a precise region on rendered HTML or an image needs a mouse — from the keyboard, comment on the whole block or image instead.</p>
  {{/* The full usage guide is a standalone page (/_usage), opened in a new tab
       so the review session is left intact. The reserved "_" path can't be
       shadowed by a repo file named usage/usage.md — see registerAssetRoutes. */}}
  <p class="kbd-help-usage"><a href="/_usage" target="_blank" rel="noopener">Open the usage guide ↗</a></p>
</div>
{{/* Search palette (cmd+k, issue #91). Backdrop + modal driven by SearchOpen,
     mirroring the keyboard-help overlay. Repo mode only. The head + body render
     only while open so the input is created fresh on open (reliable lvt-autofocus);
     lvt-form:preserve then keeps focus/cursor across the debounced re-renders. */}}
{{if not .ExternalMode}}
<div
  class="search-backdrop{{if .SearchOpen}} is-open{{end}}"
  lvt-on:click="closeSearch"
  aria-hidden="true"
></div>
<div
  class="search-modal{{if .SearchOpen}} is-open{{end}}"
  role="dialog"
  aria-label="Search files"
  aria-modal="true"
>
  {{if .SearchOpen}}
  <div class="search-head">
    <span class="search-head-icon">{{template "iconSearch"}}</span>
    <form method="POST" lvt-form:preserve class="search-input-form">
      <input
        type="text"
        name="q"
        value="{{.SearchQuery}}"
        placeholder="Search file names & contents…"
        lvt-autofocus
        lvt-on:input="setSearchQuery"
        lvt-mod:debounce="200"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        enterkeyhint="search"
      >
    </form>
    <form method="POST">
      <button
        type="submit"
        name="toggleSearchScope"
        class="search-scope outline"
        title="Toggle search scope (changed files vs all files)"
      >{{.SearchScopeLabel}} <span class="search-scope-count">{{.SearchScopeCount}}</span></button>
    </form>
    <form method="POST">
      <button
        type="submit"
        name="closeSearch"
        class="outline close-btn"
        aria-label="Close"
      >{{template "iconClose16"}}</button>
    </form>
  </div>
  <div class="search-body">
    {{if .SearchHits}}
    <ul class="search-list">
      {{- range .SearchHits}}
      <li class="search-item{{if eq .Kind "file"}} is-file{{end}}">
        <form method="POST">
          <input type="hidden" name="file" value="{{.File}}">
          <input type="hidden" name="old" value="{{.OldNum}}">
          <input type="hidden" name="new" value="{{.NewNum}}">
          <button type="submit" name="jumpToSearchResult" class="search-hit">
            <span class="search-where"><code>{{.File}}</code>{{if eq .Kind "line"}} <small>L{{.NewNum}}</small>{{else}} <small class="search-filematch">file name</small>{{end}}</span>
            {{- if eq .Kind "line"}}<span class="search-line">{{.Line}}</span>{{end -}}
          </button>
        </form>
      </li>
      {{- end}}
    </ul>
    {{if .SearchTruncated}}<p class="search-note">Showing the first {{len .SearchHits}} matches — narrow your search.</p>{{end}}
    {{else if .SearchQuery}}
    <p class="search-empty">No matches for “{{.SearchQuery}}”.</p>
    {{else}}
    <p class="search-empty">Type to search file names and contents.</p>
    {{end}}
  </div>
  {{end}}
</div>
{{end}}
<footer class="app-footer" role="contentinfo">
  prereview{{if ne .Version "dev"}} v{{.Version}}{{end}} · built with <a
    href="https://github.com/livetemplate/livetemplate"
    target="_blank"
    rel="noopener noreferrer"
  >livetemplate</a>
</footer>
{{end}}

{{/* Confirm dialogs for the session terminators (#58), rendered ONCE here at the
     top level — outside every <form> — so the toolbar/overflow/external triggers
     can all open them by id. End session shows in agent mode; Quit in standalone.
     Hidden until a trigger fires command="show-modal". */}}
{{if .AgentMode}}{{template "endSessionDialog" .}}{{end}}
{{if not .AgentMode}}{{template "quitDialog" .}}{{end}}

</div>{{/* .theme-root */}}
<script defer src="/livetemplate-client.js"></script>
{{/* Lazy mermaid renderer; standalone file keeps it out of livetemplate's template tree. See internal/assets/mermaid-init.js. */}}
<script defer src="/mermaid-init.js"></script>
</body>
</html>

{{/*
  Reusable partials for the comment-rendering markup that was duplicated
  across the diff / html / markdown / file / area / all-comments views.
  livetemplate flattens {{template "x" .}} at parse time by inlining the
  define body, so inside a partial `.` is the passed value (a Comment, or a
  rendered block) and `$` still resolves to the root state — read draft /
  selection / scroll state off `$`. Block partials recompute $bs/$be from
  the block's .StartLine/.EndLine since a partial can't see caller locals.
*/}}
