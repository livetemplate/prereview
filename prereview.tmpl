<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>prereview · {{.RepoPath}}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
<link rel="stylesheet" href="/livetemplate.css">
<style>
:root {
  --pr-bar-h: 44px;
  --pr-drawer-w: 280px;
  --pr-add: #1f4e1f; --pr-del: #4e1f1f;
  --pr-add-bg: #d9f5d9; --pr-del-bg: #f5d9d9;
  --pr-sel-bg: #fff3a8;
  --pr-comment-bg: #eef4ff;
  --pr-comment-bd: #b9cdf0;
}

/* ===== Mobile-first base ===== */

/* `overflow-x: hidden` clamps horizontal scroll only — a too-wide toolbar
   or descendant can't push the page sideways past the viewport.
   IMPORTANT: do NOT set `overflow-y: hidden` here. iOS Safari treats
   `overflow: hidden` on body as a hard scroll-lock that blocks touch
   events from reaching nested `overflow-y: auto` containers like
   main.viewer — the page silently becomes unscrollable. Body's height
   is already 100dvh (below) and its only direct flex children (header
   + .layout) fit within that bound, so body has no vertical overflow
   to scroll regardless. Rubber-band-into-whitespace is prevented by
   the empty-state CSS that gives the .empty wrapper `min-height: 100%`
   and the `overscroll-behavior: contain` on main.viewer further down. */
html, body { height: 100%; margin: 0; font-size: 14px; overflow-x: hidden; }
/* Use `height: 100dvh` (not just min-height) so main.viewer becomes the
   actual scroll container — without this, the window scrolls and the
   sticky file-head detaches from the viewer (file-head ends up under the
   top bar, defeating the point of sticky positioning). */
body { padding: 0; display: flex; flex-direction: column; height: 100dvh; }
.layout { flex: 1; display: flex; flex-direction: column; min-height: 0; }

/* Top bar — sticky on mobile, becomes header row on desktop */
header.bar {
  position: sticky; top: 0; z-index: 30;
  height: var(--pr-bar-h);
  display: flex; align-items: center; gap: 0.4rem;
  padding: 0 0.5rem;
  background: var(--pico-card-background-color);
  border-bottom: 1px solid var(--pico-muted-border-color);
}
header.bar .title {
  flex: 1; min-width: 0;
  font-weight: 600; font-size: 0.95rem;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
header.bar .title small { color: var(--pico-muted-color); font-weight: normal; }
header.bar .title { display: flex; align-items: center; gap: 0.4rem; min-width: 0; }
header.bar .title .title-main { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Inline chip group — only shown on desktop where the toolbar has room.
   Mobile users get the same controls inside the 3-dots overflow menu. */
.toolbar-inline { display: none; align-items: center; gap: 0.4rem; flex-shrink: 0; }
.toolbar-inline .auto-saved-long { font-size: 0.7rem; color: var(--pico-muted-color); }

.chip {
  flex-shrink: 0; margin: 0; padding: 0.15rem 0.5rem;
  font-size: 0.7rem; font-weight: 600; min-height: 0;
  background: var(--pico-card-sectioning-background-color);
  /* Pico v2 sets `--pico-color: var(--pico-primary-inverse)` (white) inside
     button scope — re-anchor to the document text color so the chip label
     stays readable. Same fix lives on .more-trigger and .menu-item. */
  --pico-color: var(--pico-h1-color);
  color: var(--pico-color);
  border: 1px solid var(--pico-muted-border-color); border-radius: 999px;
  cursor: pointer; white-space: nowrap;
}
.chip.resolved.is-on {
  background: var(--pr-add-bg); --pico-color: var(--pr-add); color: var(--pico-color); border-color: var(--pr-add);
}

/* 3-dots overflow menu trigger — mobile only. The menu itself uses the
   same state-driven open/close pattern as #files-drawer: a CSS class
   toggle on a hidden block, with a backdrop sibling whose tap submits
   CloseMoreMenu. No client JS.

   Pico v2 redefines `--pico-color: var(--pico-primary-inverse)` inside
   `button { ... }` for its blue button. Any custom button that does
   `color: var(--pico-color)` would resolve to white. So we re-anchor
   `--pico-color` back to the document text color at the button level
   before consuming it. This keeps child elements that inherit color
   (icon glyphs, label spans) readable. */
.more-trigger {
  flex-shrink: 0; margin: 0;
  padding: 0 !important;
  min-width: 36px; min-height: 32px;
  display: inline-flex; align-items: center; justify-content: center;
  background: none; border: 1px solid var(--pico-muted-border-color);
  --pico-color: var(--pico-h1-color);
  color: var(--pico-color);
  border-radius: 4px;
}
.more-trigger svg { display: block; pointer-events: none; }
.more-menu {
  position: fixed; top: calc(var(--pr-bar-h) + 0.25rem); right: 0.5rem;
  min-width: 13rem; max-width: calc(100vw - 1rem);
  display: none;
  background: var(--pico-card-background-color);
  border: 1px solid var(--pico-muted-border-color);
  border-radius: 6px;
  box-shadow: 0 4px 14px rgba(0,0,0,.18);
  padding: 0.35rem;
  z-index: 50;
}
.more-menu.is-open { display: block; }
.more-menu form { margin: 0; }
.more-menu button.menu-item {
  display: flex; align-items: center; justify-content: flex-start; gap: 0.6rem;
  width: 100%; margin: 0; padding: 0.55rem 0.65rem;
  background: none;
  --pico-color: var(--pico-h1-color);
  color: var(--pico-color);
  border: 0; border-radius: 4px;
  font-size: 0.9rem; font-weight: 500; min-height: 0;
  text-align: left; cursor: pointer;
}
.more-menu button.menu-item:hover,
.more-menu button.menu-item:focus { background: var(--pico-card-sectioning-background-color); }
.more-menu button.menu-item .menu-icon {
  flex: 0 0 1.2rem; display: inline-flex; align-items: center; justify-content: center;
  color: var(--pico-muted-color);
}
.more-menu button.menu-item .menu-icon svg { display: block; }
.more-menu button.menu-item .menu-label { flex: 1; }
.more-menu button.menu-item .menu-meta {
  margin-left: auto; font-size: 0.72rem; color: var(--pico-muted-color); font-weight: 600;
  padding: 0.05rem 0.4rem; background: var(--pico-card-sectioning-background-color);
  border-radius: 999px;
}
.more-menu button.menu-item.is-on .menu-icon,
.more-menu button.menu-item.is-on .menu-label { color: var(--pr-add); font-weight: 600; }
.more-menu .menu-info {
  padding: 0.4rem 0.65rem; font-size: 0.7rem;
  color: var(--pico-muted-color); border-bottom: 1px solid var(--pico-muted-border-color);
  margin-bottom: 0.25rem;
}
.more-menu-backdrop {
  position: fixed; inset: 0; background: transparent; z-index: 45;
  display: none;
}
.more-menu-backdrop.is-open { display: block; }
.banner-stopping {
  padding: 0.5rem 0.75rem; background: var(--pr-del-bg); color: var(--pr-del);
  border-bottom: 1px solid var(--pr-del); font-size: 0.85rem; text-align: center;
  font-weight: 600;
}
/* Auto-fallback banner — explains why we're showing commit-level
   changes instead of an empty "Nothing to review". Soft yellow,
   dismissable. The button is inline and unstyled-looking on purpose
   (no pill shape) so it doesn't compete with primary actions. */
.banner-fallback {
  padding: 0.4rem 0.6rem; background: #fff8d8; color: #5a4500;
  border-bottom: 1px solid #e6d488; font-size: 0.8rem;
  display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
}
.banner-fallback .msg { flex: 1; min-width: 0; }
.banner-fallback code { font-size: 0.75rem; padding: 0 0.25rem;
  background: rgba(0,0,0,.04); border-radius: 3px; }
.banner-fallback form { margin: 0; }
.banner-fallback .dismiss-btn {
  margin: 0; padding: 0.15rem 0.45rem; min-height: 24px;
  background: transparent; border: 1px solid #e6d488;
  --pico-color: #5a4500; color: var(--pico-color);
  font-size: 0.72rem; font-weight: 600; border-radius: 3px;
}
/* Composer hint shown between first-click and second-click on a range. */
.composer .selection-hint {
  font-weight: normal; color: var(--pico-muted-color); font-size: 0.7rem;
  display: inline-block; margin-left: 0.4rem;
}
/* Empty-diff state — when the diff has zero files. */
.empty.empty-diff { padding: 3rem 1rem; max-width: 32rem; margin: 0 auto; }
.empty.empty-diff h3 { margin: 0 0 0.5rem 0; }
.empty.empty-diff p { margin: 0.25rem 0; }
/* Undo-delete toast — sticky at the bottom of the viewer, fades on next mutation. */
.undo-toast {
  position: sticky; bottom: 0;
  margin: 0.4rem 0.4rem 0.2rem; padding: 0.4rem 0.6rem;
  display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
  background: var(--pico-card-background-color);
  border: 1px solid var(--pico-muted-border-color); border-radius: 4px;
  font-size: 0.8rem; box-shadow: 0 -2px 8px rgba(0,0,0,.08);
  z-index: 8;
}
.undo-toast code { font-size: 0.75rem; padding: 0 0.2rem; }
.undo-toast .undo-btn {
  margin: 0; padding: 0.2rem 0.7rem; font-size: 0.78rem;
  background: var(--pico-primary); color: var(--pico-primary-inverse); border: 0;
}
header.bar form { margin: 0; }
header.bar button { margin: 0; padding: 0.25rem 0.55rem; font-size: 0.85rem; min-height: 32px; }
.hamburger {
  background: none; border: 1px solid var(--pico-muted-border-color);
  padding: 0 !important; line-height: 1;
  min-width: 36px; min-height: 32px;
  display: inline-flex; align-items: center; justify-content: center;
  color: var(--pico-color);
}
.hamburger svg { display: block; pointer-events: none; }
header.bar .nav-prev, header.bar .nav-next { margin: 0; }
header.bar .nav-prev button, header.bar .nav-next button {
  padding: 0 0.4rem !important; min-width: 32px; min-height: 32px;
  display: inline-flex; align-items: center; justify-content: center;
}
header.bar .nav-prev button svg, header.bar .nav-next button svg { pointer-events: none; display: block; }
/* iOS Safari sometimes dispatches taps to <svg> children of a <button>
   rather than the button itself; pointer-events: none ensures the button
   wins the tap and submits its form. */
.close-btn svg { pointer-events: none; }

/* Files drawer — overlay on mobile, sidebar on desktop.
   The `html body` prefix raises specificity over Pico's default dialog rules
   which otherwise force width:100% and align-items:center on every <dialog>. */
html body dialog#files-drawer {
  position: fixed;
  top: var(--pr-bar-h); bottom: 0; left: 0;
  width: 85vw; max-width: var(--pr-drawer-w); min-width: 0; inset-inline-end: auto;
  margin: 0; padding: 0; border: 0; border-right: 1px solid var(--pico-muted-border-color);
  background: var(--pico-card-background-color);
  transform: translateX(-100%); transition: transform 220ms ease;
  z-index: 40;
  overflow: hidden; display: flex; flex-direction: column; align-items: stretch;
}
html body dialog#files-drawer.is-open { transform: translateX(0); }
/* All direct flex children should fill the drawer's width. */
dialog#files-drawer > * { width: 100%; }
dialog#files-drawer .drawer-head {
  padding: 0.4rem 0.6rem; display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1px solid var(--pico-muted-border-color);
  gap: 0.5rem;
}
dialog#files-drawer .drawer-head strong { font-size: 0.85rem; color: var(--pico-muted-color); }
dialog#files-drawer .drawer-head form { margin: 0; }
dialog#files-drawer .close-btn {
  margin: 0; padding: 0.25rem 0.4rem;
  min-height: 28px; min-width: 28px;
  display: inline-flex; align-items: center; justify-content: center;
  background: none; border: 1px solid transparent; color: var(--pico-muted-color);
}
dialog#files-drawer .close-btn:hover { border-color: var(--pico-muted-border-color); }
/* Base picker — lets the user swap the comparison ref at runtime
   (HEAD, HEAD~1, main, abc1234, …). Lives right under .drawer-head so
   it's contextually near the file count it produces. The text input
   uses lvt-form:preserve so partial typing survives re-renders. */
dialog#files-drawer .drawer-base {
  padding: 0.3rem 0.5rem 0.35rem; border-bottom: 1px solid var(--pico-muted-border-color);
  font-size: 0.75rem;
}
dialog#files-drawer .drawer-base form { margin: 0; display: flex; gap: 0.3rem; align-items: center; }
dialog#files-drawer .drawer-base label {
  font-weight: 600; color: var(--pico-muted-color); margin: 0;
  font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.03em;
}
dialog#files-drawer .drawer-base input {
  flex: 1; min-width: 0; margin: 0;
  padding: 0.25rem 0.5rem; font-size: 0.8rem; min-height: 28px;
  font-family: ui-monospace, SFMono-Regular, monospace;
}
dialog#files-drawer .drawer-base .base-apply {
  margin: 0; padding: 0.25rem 0.55rem; font-size: 0.75rem; min-height: 28px;
  --pico-color: var(--pico-h1-color); color: var(--pico-color);
  background: var(--pico-card-sectioning-background-color);
  border: 1px solid var(--pico-muted-border-color);
}
dialog#files-drawer .drawer-base .base-error {
  margin: 0.25rem 0 0; padding: 0.2rem 0.4rem; font-size: 0.7rem;
  color: var(--pr-del); background: var(--pr-del-bg);
  border-left: 2px solid var(--pr-del); border-radius: 2px;
}
dialog#files-drawer .drawer-search {
  padding: 0.35rem 0.5rem; border-bottom: 1px solid var(--pico-muted-border-color);
}
dialog#files-drawer .drawer-search form { margin: 0; }
dialog#files-drawer .drawer-search input {
  margin: 0; padding: 0.3rem 0.5rem; font-size: 0.85rem; min-height: 30px; width: 100%;
  /* Strip iOS Safari's built-in search-icon decoration which otherwise
     overlaps the typed text/placeholder. */
  appearance: none; -webkit-appearance: none;
}
dialog#files-drawer .drawer-search input::-webkit-search-decoration,
dialog#files-drawer .drawer-search input::-webkit-search-cancel-button,
dialog#files-drawer .drawer-search input::-webkit-search-results-button,
dialog#files-drawer .drawer-search input::-webkit-search-results-decoration {
  -webkit-appearance: none;
  display: none;
}
dialog#files-drawer .drawer-body { flex: 1; overflow-y: auto; padding: 0.5rem; }
dialog#files-drawer .file-row { display: flex; gap: 0.2rem; align-items: stretch; }
dialog#files-drawer .file-select-form { flex: 1; margin: 0; min-width: 0; }
dialog#files-drawer .file-viewed-form { margin: 0; }
dialog#files-drawer .viewed-toggle {
  margin: 0; padding: 0 !important;
  min-width: 40px; min-height: 40px;
  background: none; border: 1px solid var(--pico-muted-border-color); border-radius: 6px;
  color: var(--pico-muted-color); display: inline-flex; align-items: center; justify-content: center;
}
dialog#files-drawer .viewed-toggle svg { width: 20px; height: 20px; display: block; pointer-events: none; }
dialog#files-drawer .file-row.is-viewed .file-btn { opacity: 0.5; text-decoration: line-through; }
dialog#files-drawer .file-row.is-viewed .viewed-toggle { color: #166534; border-color: #166534; background: #dcfce7; }
dialog#files-drawer .file-row.is-viewed .viewed-toggle svg { color: #166534; }
.empty-filter { padding: 0.5rem; color: var(--pico-muted-color); }

/* All-comments overview pane (replaces the diff viewer). */
.all-comments { padding: 0.5rem; }
.all-comments .ac-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0.5rem; border-bottom: 1px solid var(--pico-muted-border-color);
  margin-bottom: 0.5rem; position: sticky; top: 0;
  background: var(--pico-card-background-color); z-index: 5;
}
.all-comments .ac-head button { margin: 0; padding: 0.3rem 0.7rem; font-size: 0.8rem; min-height: 30px; }
.all-comments .ac-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
.all-comments .ac-item { margin: 0; }
.all-comments .ac-jump { margin: 0; }
.all-comments .ac-jump-btn {
  display: block; width: 100%; padding: 0.5rem 0.6rem; margin: 0;
  text-align: left; background: var(--pr-comment-bg);
  border: 1px solid var(--pr-comment-bd); border-radius: 4px; color: inherit;
  cursor: pointer; font-family: inherit; font-size: 0.85rem; line-height: 1.4;
}
.all-comments .ac-jump-btn:hover { background: #c7daf3; }
.all-comments .ac-item.is-resolved .ac-jump-btn {
  background: var(--pico-card-sectioning-background-color, #f4f4f4);
  border-color: var(--pico-muted-color); opacity: 0.7;
}
.all-comments .ac-item.is-resolved .ac-body { text-decoration: line-through; text-decoration-color: var(--pico-muted-color); }
.all-comments .ac-where { font-size: 0.75rem; color: var(--pico-muted-color); margin-bottom: 0.25rem; }
.all-comments .ac-body { white-space: pre-wrap; word-break: break-word; }
dialog#files-drawer ul { list-style: none; padding: 0; margin: 0; }
dialog#files-drawer li { margin: 0 0 0.15rem 0; }
dialog#files-drawer button.file-btn {
  width: 100%; text-align: left; margin: 0;
  padding: 0.5rem 0.6rem; font-size: 0.9rem;
  line-height: 1.3;
  display: flex; align-items: center; gap: 0.5rem;
}
dialog#files-drawer button.file-btn .file-label {
  flex: 1; min-width: 0;
  word-break: break-all;
}
dialog#files-drawer button.file-btn .file-meta { flex-shrink: 0; display: inline-flex; align-items: center; gap: 0.4rem; }
dialog#files-drawer button.file-btn .file-count {
  margin: 0;
  padding: 0.05rem 0.4rem;
  font-size: 0.75rem;
  line-height: 1.3;
}
dialog#files-drawer button.file-btn .diff-stats {
  font-family: ui-monospace, SFMono-Regular, monospace;
  font-size: 0.7rem; line-height: 1.3; white-space: nowrap;
}
dialog#files-drawer button.file-btn .diff-stats .add { color: #166534; margin-right: 0.2rem; }
dialog#files-drawer button.file-btn .diff-stats .del { color: #991b1b; }
/* Selected-file highlight. Pico's theme-aware variables resolve to dark
   colors that fight our dark status-A/M/D text — so we hardcode a light
   cyan tint and a strong primary border. Status text colors stay readable. */
/* Selected file: light blue tint + strong left accent + bold weight.
   The bg color (#dbeafe, tailwind blue-100) is light enough that
   dark status-A/M/D text colors stay readable. */
dialog#files-drawer button.file-btn.is-selected {
  background: #dbeafe;
  border: 1px solid #93c5fd;
  border-left: 4px solid #1e40af;
  padding-left: calc(0.6rem - 3px);
  font-weight: 600;
}
dialog#files-drawer form { margin: 0; }

/* Backdrop behind the drawer, click-to-close on mobile */
.drawer-backdrop {
  position: fixed; top: var(--pr-bar-h); bottom: 0; left: 0; right: 0;
  background: rgba(0,0,0,.4); z-index: 35;
  opacity: 0; pointer-events: none; transition: opacity 200ms;
}
.drawer-backdrop.open { opacity: 1; pointer-events: auto; }
/* Backdrop only catches taps in the visible strip to the right of the
   open drawer. Restricting pointer-events to that strip prevents taps in
   the drawer's area from being eaten before they reach the drawer. */
.drawer-backdrop.open { cursor: pointer; }

/* Main viewer — must have min-width: 0 so flex shrink works and a wide
   button.line inside .code doesn't push article past the viewer's width.
   Without this, the file-head inherits the wider article width and gets
   clipped at the left edge of the viewport (negative x). */
main.viewer { flex: 1; overflow-y: auto; padding: 0; min-width: 0; }
main.viewer > article { margin: 0; padding: 0; min-width: 0; max-width: 100%; }
/* `main.viewer > article > header` beats Pico's `article > header` rules
   so our explicit padding isn't dropped — the filename would otherwise
   be clipped at the viewport edge with no margin. */
main.viewer > article > header.file-head {
  /* Pico CSS sets a negative margin on `article > header` to make the
     header bleed to the article's edges (assuming the article has padding).
     Our article has no padding, so we need margin: 0 explicitly — otherwise
     the file-head extends past the viewport on both sides and the first
     character of the filename gets clipped. */
  margin: 0;
  display: flex; justify-content: space-between; align-items: center; gap: 0.5rem;
  padding: 0.4rem 0.75rem;
  background: var(--pico-card-background-color);
  border-bottom: 1px solid var(--pico-muted-border-color);
  position: sticky; top: 0; z-index: 5;
  font-size: 0.85rem;
}
main.viewer > article > header.file-head strong {
  word-break: break-all; font-size: 0.9rem; padding-left: 0;
}
main.viewer > article > header.file-head small { color: var(--pico-muted-color); font-size: 0.75rem; }

/* Diff viewer container — was <pre> but that preserves whitespace which
   made every template-loop newline a visible blank line. Now a <div>
   stack with per-line <button> blocks. */
.code {
  background: var(--pico-card-background-color);
  padding: 0; margin: 0; overflow-x: auto;
  font-size: 0.8rem; line-height: 1.2;
  font-family: ui-monospace, SFMono-Regular, monospace;
}
.code form { margin: 0; padding: 0; display: block; line-height: 1.2; }
.code .line-row { line-height: 1.2; }
.code button.line {
  display: flex; padding: 0; margin: 0; min-height: 0;
  /* Line sizes to its content but never narrower than the viewer width.
     This way .code's horizontal scrollable extent = widest line (not
     viewer width), so the scrollbar clamps to actual content. */
  width: max-content; min-width: 100%;
  border: 0; background: none; color: inherit; font: inherit; cursor: pointer;
  text-align: left; align-items: baseline; line-height: 1.2;
}
.code button.line:hover { outline: 1px solid var(--pico-primary-border); outline-offset: -1px; }
.code button.line.add { background: var(--pr-add-bg); color: var(--pr-add); }
.code button.line.del { background: var(--pr-del-bg); color: var(--pr-del); }
/* When EVERY line in the file is an add (or every line is a del) the
   per-line background carries no information — the [A]/[D] badge in the
   file list already signals the file-level state. Drop the noise. */
.code.pure-add button.line.add { background: none; color: inherit; }
.code.pure-del button.line.del { background: none; color: inherit; }
/* File view mode — same effect as pure-add/pure-del but applied unconditionally,
   plus deleted lines disappear (they don't exist in the working-tree file).
   The :has() pseudo hides the whole .line-row (button + any inline comments
   anchored to that del line), which is correct: a comment on a deleted line
   has no anchor in file-view mode. Switching back to diff view restores them. */
.code.file-view button.line.add,
.code.file-view button.line.del { background: none; color: inherit; }
.code.file-view .line-row:has(button.line.del) { display: none; }
.code.file-view .gutter-mark { display: none; }
.code button.line.selected { background: var(--pr-sel-bg) !important; outline: 1px solid var(--pico-primary); outline-offset: -1px; }
.code .gutter {
  flex: 0 0 5.5ch; color: var(--pico-muted-color); user-select: none;
  text-align: right; padding-right: 0.4rem; font-size: 0.75rem;
  white-space: nowrap;
  /* Stick to the left of the scrollable .code container so the line
     numbers stay visible while the content scrolls horizontally. */
  position: sticky; left: 0; z-index: 1;
  background: var(--pico-card-background-color);
  border-right: 1px solid var(--pico-muted-border-color);
}
.code .content { white-space: pre; flex: 1; padding-left: 0.35rem; min-height: 1em; }

/* Inline comment cards — between the diff lines */
.inline-comment {
  margin: 0.25rem 0.4rem; padding: 0.35rem 0.5rem;
  background: var(--pr-comment-bg);
  border-left: 3px solid var(--pr-comment-bd);
  border-radius: 3px;
  font-size: 0.82rem; line-height: 1.35;
}
/* Resolved comments stay visible but muted, with a clear badge. The skill
   reads the CSV `resolved` column and skips these — UI just signals the
   resolution to the human reviewer. */
.inline-comment.is-resolved {
  background: var(--pico-card-sectioning-background-color, #f4f4f4);
  border-left-color: var(--pico-muted-color);
  opacity: 0.7;
}
.inline-comment.is-resolved .body { text-decoration: line-through; text-decoration-color: var(--pico-muted-color); }
.inline-comment .resolved-badge {
  background: var(--pr-add-bg); color: var(--pr-add);
  padding: 0 0.35rem; border-radius: 999px; font-weight: 600;
  font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.03em;
}
.inline-comment header {
  font-size: 0.7rem; color: var(--pico-muted-color); margin: 0 0 0.2rem 0;
  display: flex; justify-content: space-between; align-items: center;
  font-weight: 600;
}
.inline-comment .body { white-space: pre-wrap; word-break: break-word; }
.inline-comment .ic-actions { display: flex; gap: 0.3rem; margin-top: 0.3rem; }
.inline-comment .ic-actions button {
  padding: 0.15rem 0.5rem; font-size: 0.72rem; margin: 0;
  min-height: 26px; min-width: auto; line-height: 1.2;
}
.inline-comment .ic-actions form { margin: 0; }

/* Inline composer — sticky on mobile, static on desktop. Save and Cancel
   live in separate <form> elements (siblings, not nested) so Cancel can't
   get blocked by the required-textarea validation on the add form. */
.composer {
  position: sticky; bottom: 0; z-index: 10;
  margin: 0.35rem 0.4rem;
  padding: 0.4rem 0.5rem;
  background: var(--pico-card-background-color);
  border: 1px solid var(--pico-muted-border-color);
  border-radius: 4px;
  box-shadow: 0 -2px 8px rgba(0,0,0,.06);
  display: flex; flex-direction: column;
}
.composer strong { font-size: 0.78rem; }
.composer textarea {
  min-height: 3rem; margin: 0.25rem 0; font-size: 16px; width: 100%;
  padding: 0.35rem 0.45rem; line-height: 1.4;
}
.composer .composer-add { margin: 0; display: flex; flex-direction: column; }
.composer .composer-cancel { margin: 0.3rem 0 0 0; display: flex; }
.composer .c-actions { display: flex; gap: 0.3rem; justify-content: flex-end; align-items: center; }
.composer .save-btn { margin: 0; padding: 0.3rem 0.9rem; font-size: 0.85rem; min-height: 30px; }
.composer .cancel-btn {
  margin: 0; padding: 0.3rem 0.7rem; font-size: 0.78rem; min-height: 28px;
  flex: 1;
  background: none; border: 1px solid var(--pico-muted-border-color);
  color: var(--pico-muted-color);
}

/* File status badges in the drawer */
.status-A { color: #1f4e1f; }
.status-M { color: #5a4500; }
.status-D { color: #4e1f1f; }
.status-R { color: #1f3a4e; }

/* Empty states */
.empty { color: var(--pico-muted-color); padding: 2rem; text-align: center; }

/* Floating toast — confirms DONE write without consuming header space.
   Positioned absolutely so the layout doesn't shift when it appears/dismisses. */
.toast {
  position: fixed;
  top: calc(var(--pr-bar-h) + 0.5rem);
  right: 0.75rem;
  max-width: calc(100vw - 1.5rem);
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.4rem 0.5rem 0.4rem 0.7rem;
  background: var(--pr-add-bg); color: var(--pr-add);
  border: 1px solid var(--pr-add); border-radius: 6px;
  font-size: 0.8rem; line-height: 1.3;
  box-shadow: 0 2px 8px rgba(0,0,0,.1);
  z-index: 25;
}
.toast .toast-msg { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
.toast .toast-msg code { font-size: 0.75rem; background: rgba(255,255,255,.5); padding: 0 0.25rem; border-radius: 3px; }
.toast-dismiss-form { margin: 0; }
.toast-dismiss {
  margin: 0; padding: 0.15rem 0.3rem; min-height: 22px; min-width: 22px;
  background: transparent; border: 0; color: inherit;
  display: inline-flex; align-items: center; justify-content: center;
  cursor: pointer; line-height: 1;
}
.toast-dismiss svg { pointer-events: none; display: block; }
@media (min-width: 900px) {
  .toast { font-size: 0.85rem; max-width: 500px; }
  .toast .toast-msg { white-space: normal; }
}

/* ===== Desktop overrides (>=900px) ===== */
@media (min-width: 900px) {
  .hamburger { display: none; }
  .drawer-backdrop { display: none; }
  .layout { flex-direction: row; }
  html body dialog#files-drawer {
    position: static; transform: none;
    width: var(--pr-drawer-w); max-width: var(--pr-drawer-w);
    height: auto; align-self: stretch;
    flex-shrink: 0;
  }
  main.viewer { flex: 1; padding: 0; min-width: 0; }
  .composer { position: static; box-shadow: none; }
  .code { font-size: 0.85rem; }
  /* Desktop has room — render chips inline and hide the overflow menu. */
  .toolbar-inline { display: inline-flex; }
  .more-trigger { display: none; }
  .more-menu, .more-menu-backdrop { display: none !important; }
}

/* Anchor the empty-state to the viewer center so the user can't scroll
   into blank whitespace below it. Without this, `<p class="empty">` is a
   short paragraph at the top of an unbounded flex container — iOS
   rubber-band scroll then reveals a sea of nothing below. */
main.viewer > .empty { min-height: 100%; display: flex; flex-direction: column;
                       justify-content: center; align-items: center; }
main.viewer > .empty-diff { min-height: 100%; display: flex; flex-direction: column;
                            justify-content: center; align-items: center; }
main.viewer { overscroll-behavior: contain; }
</style>
</head>
<body lvt-on:keydown="clearSelection" lvt-key="Escape">

<header class="bar">
  <form method="POST">
    <button type="submit" name="toggleFiles" class="hamburger outline contrast" aria-label="Toggle files"><svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg></button>
  </form>
  <div class="title">
    <span class="title-main">{{if .ShowAllComments}}<small>All comments ({{len .Comments}})</small>{{else if .CurrentDiff}}{{.CurrentDiff.Path}}{{else}}<small>Pick a file from {{len .Files}} changed</small>{{end}}</span>
  </div>
  {{/* Desktop-only inline chip group. On mobile these same actions live
       in the 3-dots overflow menu below — single source of truth, just
       presented in the layout that fits. */}}
  <div class="toolbar-inline">
    <small class="auto-saved-long">{{len .Files}} files · {{.ViewedCount}}/{{len .Files}} viewed</small>
    {{if .CurrentDiff}}
    <form method="POST"><button type="submit" name="toggleFileView" class="chip view-chip{{if .FileView}} is-on{{end}}" title="{{if .FileView}}Show diff overlay{{else}}Hide diff overlay — view file as-is{{end}}">{{if .FileView}}File{{else}}Diff{{end}}</button></form>
    {{end}}
    {{if gt (len .Comments) 0}}
    <form method="POST"><button type="submit" name="toggleCommentList" class="chip" title="View all comments">{{len .Comments}} 💬</button></form>
    {{end}}
    {{if gt .ResolvedCount 0}}
    <form method="POST"><button type="submit" name="toggleShowResolved" class="chip resolved{{if .ShowResolved}} is-on{{end}}" title="{{if .ShowResolved}}Hide{{else}}Show{{end}} {{.ResolvedCount}} resolved">{{if .ShowResolved}}✓{{else}}○{{end}} {{.ResolvedCount}} resolved</button></form>
    {{end}}
  </div>
  {{if gt (len .Files) 1}}
  <form method="POST" class="nav-prev"><button type="submit" name="prevFile" aria-label="Previous file" class="outline contrast"><svg viewBox="0 0 24 24" width="14" height="14"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg></button></form>
  <form method="POST" class="nav-next"><button type="submit" name="nextFile" aria-label="Next file" class="outline contrast"><svg viewBox="0 0 24 24" width="14" height="14"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg></button></form>
  {{end}}
  <form method="POST">
    {{if .SkillMode}}
    <button type="submit" name="handOff" class="contrast">Hand off →</button>
    {{else}}
    <button type="submit" name="quit" class="contrast">Quit</button>
    {{end}}
  </form>
  {{/* 3-dots trigger — mobile only (hidden on desktop via CSS). Placed
       last so it visually anchors the right edge of the toolbar; the
       menu opens directly below it (also right-edge aligned). Uses an
       SVG icon — the `⋮` unicode glyph renders zero-width on iOS Safari's
       UI font. */}}
  <form method="POST" style="margin:0">
    <button type="submit" name="toggleMoreMenu" class="more-trigger" aria-label="More options" aria-haspopup="menu" aria-expanded="{{if .MoreMenuOpen}}true{{else}}false{{end}}">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <circle cx="12" cy="5" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="12" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="19" r="1.8" fill="currentColor"/>
      </svg>
    </button>
  </form>
</header>

{{/* Mobile overflow menu. Backdrop sibling tap closes it. Both have the
     same `.is-open` class flip so they appear/disappear together. Desktop
     CSS forces display:none on both so the inline chips own the chrome.

     Icons are inline SVG (not Unicode glyphs like ⋮ ✓ ○) — iOS Safari's
     UI font sometimes renders those zero-width or substitutes them with
     emoji, which carry their own color and ignore CSS `color`. SVG with
     `fill: currentColor` honors the menu-item color cascade. */}}
<div class="more-menu-backdrop{{if .MoreMenuOpen}} is-open{{end}}" lvt-on:click="closeMoreMenu" aria-hidden="true"></div>
<div class="more-menu{{if .MoreMenuOpen}} is-open{{end}}" role="menu" aria-label="More options">
  <div class="menu-info">{{len .Files}} files · {{.ViewedCount}}/{{len .Files}} viewed{{if gt (len .Comments) 0}} · {{len .Comments}} comment{{if ne (len .Comments) 1}}s{{end}}{{end}}</div>
  {{if .CurrentDiff}}
  <form method="POST">
    <button type="submit" name="toggleFileView" class="menu-item{{if .FileView}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .FileView}}
        {{/* Diff icon (split rectangles with plus/minus) — shown when current view is plain file. */}}
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M4 4h7v16H4zM13 4h7v16h-7z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round"/><path d="M6 11h3M6 13h3M16 9v6M14 12h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        {{else}}
        {{/* File icon (document) — shown when current view is diff. */}}
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M6 3h8l4 4v14H6z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round"/><path d="M14 3v4h4" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round"/></svg>
        {{end}}
      </span>
      <span class="menu-label">{{if .FileView}}Show diff{{else}}View file{{end}}</span>
    </button>
  </form>
  {{end}}
  {{if gt (len .Comments) 0}}
  <form method="POST">
    <button type="submit" name="toggleCommentList" class="menu-item" role="menuitem">
      <span class="menu-icon"><svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M4 5h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H9l-4 4v-4H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round"/></svg></span>
      <span class="menu-label">{{if .ShowAllComments}}Back to diff{{else}}All comments{{end}}</span>
      <span class="menu-meta">{{len .Comments}}</span>
    </button>
  </form>
  {{end}}
  {{if gt .ResolvedCount 0}}
  <form method="POST">
    <button type="submit" name="toggleShowResolved" class="menu-item{{if .ShowResolved}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .ShowResolved}}
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M5 12l4 4 10-10" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {{else}}
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.8" fill="none"/></svg>
        {{end}}
      </span>
      <span class="menu-label">{{if .ShowResolved}}Hide resolved{{else}}Show resolved{{end}}</span>
      <span class="menu-meta">{{.ResolvedCount}}</span>
    </button>
  </form>
  {{end}}
  {{if and (eq (len .Comments) 0) (eq .ResolvedCount 0)}}
  <div class="menu-info" style="border-bottom: 0; margin-bottom: 0; font-style: italic;">No comments yet — tap a line to add one.</div>
  {{end}}
</div>

{{if .Quitting}}
<div class="banner-stopping" role="status">
  Server stopping… you can close this tab.
</div>
{{end}}

{{if and .BaseAutoFallback (not .Quitting)}}
<div class="banner-fallback" role="status">
  <span class="msg">No working-tree changes — showing last commit (<code>{{.Base}}</code>). Change the base in the file drawer to compare against something else.</span>
  <form method="POST">
    <button type="submit" name="dismissBaseFallback" class="dismiss-btn" aria-label="Dismiss banner">Got it</button>
  </form>
</div>
{{end}}

{{if .DoneWritten}}
<div class="toast" role="status">
  <span class="toast-msg">✓ Saved to <code>.prereview/{{.CSVBasename}}</code></span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="dismissBanner" class="toast-dismiss" aria-label="Dismiss">
      <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
    </button>
  </form>
</div>
{{end}}

{{/* Backdrop is rendered when the drawer is open on mobile. Any tap submits
     CloseFiles via lvt-on:click — simpler and more reliable than a form-wrapped
     button which had submission edge cases. */}}
<div class="drawer-backdrop{{if .FileDrawerOpen}} open{{end}}" lvt-on:click="closeFiles" aria-label="Close file list"></div>

<div class="layout">
<dialog id="files-drawer" open class="{{if .FileDrawerOpen}}is-open{{end}}">
  <div class="drawer-head">
    <strong>{{len .Files}} file{{if ne (len .Files) 1}}s{{end}}</strong>
    <form method="POST">
      <button type="submit" name="closeFiles" class="outline close-btn" aria-label="Close"><svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg></button>
    </form>
  </div>
  {{/* Base picker — type any ref git would resolve. Hitting Enter
       submits the form, which routes to SetBase. lvt-form:preserve
       keeps the typed value across re-renders; if validation fails,
       state.BaseError surfaces below the input. */}}
  <div class="drawer-base">
    <form method="POST" lvt-form:preserve>
      <label for="base-input">Base</label>
      <input id="base-input" type="text" name="ref" value="{{.Base}}"
             placeholder="HEAD"
             autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
             enterkeyhint="go">
      <button type="submit" name="setBase" class="base-apply">Apply</button>
    </form>
    {{if .BaseError}}<div class="base-error" role="alert">{{.BaseError}}</div>{{end}}
  </div>
  <div class="drawer-search">
    <form method="POST" lvt-form:preserve>
      <input type="text" name="filter" placeholder="Filter files…" value="{{.FileFilter}}"
             lvt-on:input="setFileFilter" lvt-mod:debounce="200"
             autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
             enterkeyhint="search">
    </form>
  </div>
  <div class="drawer-body">
    {{if .Files}}
    <ul>
      {{range .FilteredFiles}}
      <li data-key="{{.Path}}">
        <div class="file-row{{if index $.ViewedFiles .Path}} is-viewed{{end}}">
          <form method="POST" class="file-select-form">
            <input type="hidden" name="path" value="{{.Path}}">
            <button type="submit" name="selectFile" class="file-btn outline contrast status-{{.Status}}{{if eq .Path $.SelectedFile}} is-selected{{end}}">
              <span class="file-label"><small>[{{.Status}}]</small> {{.Path}}</span>
              <span class="file-meta">
                {{if or (gt .Added 0) (gt .Deleted 0)}}<small class="diff-stats">{{if gt .Added 0}}<span class="add">+{{.Added}}</span>{{end}}{{if gt .Deleted 0}}<span class="del">-{{.Deleted}}</span>{{end}}</small>{{end}}
                {{if gt .CommentCount 0}}<mark class="file-count">{{.CommentCount}}</mark>{{end}}
              </span>
            </button>
          </form>
          <form method="POST" class="file-viewed-form">
            <input type="hidden" name="path" value="{{.Path}}">
            <button type="submit" name="toggleViewed" class="viewed-toggle" aria-label="{{if index $.ViewedFiles .Path}}Mark as not viewed{{else}}Mark as viewed{{end}}" title="{{if index $.ViewedFiles .Path}}Viewed{{else}}Mark viewed{{end}}">
              {{if index $.ViewedFiles .Path}}<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12l5 5 9-11" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg>{{else}}<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>{{end}}
            </button>
          </form>
        </div>
      </li>
      {{else}}
      <li class="empty-filter"><small>No files match "<code>{{.FileFilter}}</code>"</small></li>
      {{end}}
    </ul>
    {{else}}
    <p class="empty"><small>No changes vs <code>{{.Base}}</code>.</small></p>
    {{end}}
  </div>
</dialog>

<main class="viewer">
{{if .ShowAllComments}}
<section class="all-comments">
  <header class="ac-head">
    <strong>All comments ({{len .Comments}})</strong>
    <form method="POST" style="margin:0">
      <button type="submit" name="toggleCommentList" class="outline contrast">Back to diff</button>
    </form>
  </header>
  {{if .VisibleComments}}
  <ul class="ac-list">
    {{range .VisibleComments}}
    <li class="ac-item{{if .Resolved}} is-resolved{{end}}" data-key="{{.ID}}">
      <form method="POST" class="ac-jump">
        <input type="hidden" name="id" value="{{.ID}}">
        <button type="submit" name="jumpToComment" class="ac-jump-btn">
          <div class="ac-where"><code>{{.File}}</code> · {{.LineSpan}} <small>({{.Side}})</small>{{if .Resolved}} <small class="resolved-badge">resolved</small>{{end}}</div>
          <div class="ac-body">{{.Body}}</div>
        </button>
      </form>
    </li>
    {{end}}
  </ul>
  {{else}}
  <p class="empty"><small>{{if and (gt (len .Comments) 0) (not .ShowResolved)}}{{len .Comments}} resolved comment{{if ne (len .Comments) 1}}s{{end}} hidden — toggle "Show resolved" to see them.{{else}}No comments yet.{{end}}</small></p>
  {{end}}
</section>
{{else}}
{{with .CurrentDiff}}
<article>
  <header class="file-head">
    <strong>{{.Path}}</strong>
    {{if .Note}}<small>{{.Note}}</small>{{end}}
  </header>
  {{if .IsBinary}}
  <p class="empty">Binary file — cannot display.</p>
  {{else if .Lines}}
  <div class="code{{if eq .Note "file added"}} pure-add{{else if eq .Note "file deleted"}} pure-del{{end}}{{if $.FileView}} file-view{{end}}">{{range .Lines}}{{$ln := .NewNum}}{{if not $ln}}{{$ln = .OldNum}}{{end}}<div class="line-row"><form method="POST"><input type="hidden" name="line" value="{{$ln}}"><input type="hidden" name="side" value="{{if eq .Kind "del"}}old{{else}}new{{end}}"><button type="submit" name="selectLine" class="line {{.Kind}}{{if index $.SelectedLines $ln}} selected{{end}}" data-key="L{{.OldNum}}-{{.NewNum}}"><span class="gutter"><span class="gutter-mark">{{if eq .Kind "add"}}+{{else if eq .Kind "del"}}-{{else}}&nbsp;{{end}} </span>{{$ln}}</span><span class="content">{{.Content}}</span></button></form>{{range (index $.CommentsByEndLine $ln)}}<div class="inline-comment{{if .Resolved}} is-resolved{{end}}" data-key="{{.ID}}"{{if eq $.ScrollToCommentID .ID}} lvt-fx:scroll="into-view"{{end}}><header><span>{{.LineSpan}} · <small>{{.Side}}</small>{{if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}</span></header><div class="body">{{.Body}}</div><div class="ic-actions"><form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="toggleResolved" class="outline">{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button></form>{{if not .Resolved}}<form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="editComment" class="outline">Edit</button></form>{{end}}<button type="button" class="secondary outline" command="show-modal" commandfor="confirm-delete-{{.ID}}">Delete</button><dialog id="confirm-delete-{{.ID}}"><article><header><strong>Delete comment?</strong></header><p><small><code>{{.File}}</code> {{.LineSpan}}</small></p><footer><form method="POST"><input type="hidden" name="id" value="{{.ID}}"><fieldset role="group"><button type="button" command="close" commandfor="confirm-delete-{{.ID}}" class="secondary">Cancel</button><button type="submit" name="deleteComment" class="contrast">Delete</button></fieldset></form></footer></article></dialog></div></div>{{end}}{{if and (ne $.SelectionEndMax 0) (eq $.SelectionEndMax $ln)}}<div class="composer" data-key="composer"><strong>{{if $.EditingCommentID}}Editing comment on {{else}}Comment on {{end}}{{$.SelectionLabel}}</strong>{{if and (ne $.SelectionAnchor 0) (eq $.SelectionAnchor $.SelectionEnd) (not $.EditingCommentID)}} <small class="selection-hint">tap another line to extend, or save now for a single line</small>{{end}}<form method="POST" lvt-form:preserve class="composer-add"><textarea name="body" placeholder="What's wrong with these lines?" required>{{$.DraftBody}}</textarea><div class="c-actions"><button type="submit" name="addComment" class="save-btn">Save</button></div></form><form method="POST" class="composer-cancel"><button type="submit" name="clearSelection" class="cancel-btn">Cancel</button></form></div>{{end}}</div>
{{end}}</div>
  {{else}}
  <p class="empty"><small>No diff content.</small></p>
  {{end}}
</article>
{{else}}
  {{if .Files}}
  <p class="empty">Pick a file from the list.</p>
  {{else}}
  <div class="empty empty-diff">
    <h3>Nothing to review</h3>
    <p>No changes vs <code>{{.Base}}</code>.</p>
    <p><small>Try editing some files in the repo, or pass <code>--base &lt;branch&gt;</code> for a wider diff range.</small></p>
  </div>
  {{end}}
{{end}}
{{end}}

{{if and .LastDeletedComment (not .Quitting)}}
<div class="undo-toast" role="status">
  <span>Comment on <code>{{.LastDeletedComment.File}}</code> {{.LastDeletedComment.LineSpan}} deleted</span>
  <form method="POST" style="margin:0;display:inline">
    <button type="submit" name="undoDelete" class="undo-btn">Undo</button>
  </form>
</div>
{{end}}
</main>
</div>

<script defer src="/livetemplate-client.js"></script>
</body>
</html>
