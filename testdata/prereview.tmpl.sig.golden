=== blockComments ===
{{$bs := .StartLine}}{{$be := .EndLine}}{{range $.FileComments}}{{if and (ge .ToLine $bs) (le .ToLine $be)}}{{template "commentCardFull" .}}{{end}}{{end}}{{if and (ne $.SelectionEndMax 0) (ge $.SelectionEndMax $bs) (le $.SelectionEndMax $be)}}{{template "composer" $}}{{end}}
=== commentCardFull ===
<div class="inline-comment{{if .Resolved}} is-resolved{{end}}{{if .AnchorOutdated}} is-outdated{{end}}" data-key="{{.ID}}" lvt-fx:animate="fade"{{if eq $.ScrollToCommentID .ID}} lvt-fx:scroll="into-view" tabindex="-1" lvt-autofocus{{end}}><header><span>{{.LineSpan}} · <small>{{.Side}}</small>{{if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}{{if .AnchorMoved}} · <small class="moved-badge">moved</small>{{end}}{{if .AnchorOutdated}} · <small class="outdated-badge">outdated</small>{{end}}</span></header><div class="body">{{.Body}}</div>{{if .AnchorOutdated}}<details class="anchor-orig"><summary>⚠ the document changed here — originally anchored to:</summary><pre>{{.Anchor.Text}}</pre></details>{{end}}<div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="toggleResolved" class="outline">{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>{{if and (not .Resolved) .AnchorOutdated}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="reanchorComment" class="outline">Re-anchor</button>
    </form>{{end}}{{if and (not .Resolved) (not .AnchorOutdated)}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="editComment" class="outline">Edit</button>
    </form>{{end}}<button type="button" class="secondary outline" command="show-modal" commandfor="confirm-delete-{{.ID}}">Delete</button>{{template "deleteDialog" .}}</div></div>
=== commentCardSimple ===
<div class="inline-comment{{if .Resolved}} is-resolved{{end}}" data-key="{{.ID}}" lvt-fx:animate="fade"{{if eq $.ScrollToCommentID .ID}} lvt-fx:scroll="into-view" tabindex="-1" lvt-autofocus{{end}}><header><span>{{.LineSpan}}{{if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}</span></header><div class="body">{{.Body}}</div><div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="toggleResolved" class="outline">{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>{{if not .Resolved}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="editComment" class="outline">Edit</button>
    </form>{{end}}<button type="button" class="secondary outline" command="show-modal" commandfor="confirm-delete-{{.ID}}">Delete</button>{{template "deleteDialogTagged" .}}</div></div>
=== composer ===
<div class="composer{{if eq $.CommentMode "region"}} ext-composer{{end}}" data-key="composer"{{if eq $.CommentMode "region"}} lvt-fx:scroll="into-view"{{end}}><strong>{{if eq $.CommentMode "region"}}{{if $.EditingCommentID}}Editing comment on {{else}}Comment on {{end}}region · <small>{{$.CurrentURL}}</small>{{else}}{{if eq $.CommentMode "file"}}{{if $.EditingCommentID}}Editing comment on file{{else}}Comment on file{{end}} <code>{{$.CurrentDiff.Path}}</code>{{else}}{{if eq $.CommentMode "area"}}{{if $.EditingCommentID}}Editing comment on area of{{else}}Comment on area of{{end}} <code>{{$.CurrentDiff.Path}}</code>{{else}}{{if $.ReanchorCommentID}}Re-anchoring comment to {{else}}{{if $.EditingCommentID}}Editing comment on {{else}}Comment on {{end}}{{end}}{{$.SelectionLabel}}{{end}}{{end}}{{end}}</strong>{{if and (eq $.CommentMode "") (ne $.SelectionAnchor 0) (eq $.SelectionAnchor $.SelectionEnd) (not $.EditingCommentID) (not $.ShowRenderedMarkdown) (not $.ShowRenderedHTML)}} <small class="selection-hint">tap another line to extend, or save now for a single line</small>{{end}}<form method="POST" lvt-form:preserve class="composer-add" id="composer-add-form" lvt-on:keydown="addComment" lvt-key="Mod+Enter">
    <textarea name="body" placeholder="{{if eq $.CommentMode "region"}}What's wrong with this region?{{else}}{{if eq $.CommentMode "file"}}What's wrong with this file?{{else}}{{if eq $.CommentMode "area"}}What's wrong with this region?{{else}}What's wrong with these lines?{{end}}{{end}}{{end}}" required lvt-autofocus>{{$.DraftBody}}</textarea>
  </form><form method="POST" class="composer-cancel" id="composer-cancel-form"></form><div class="c-actions">
    <button type="submit" name="clearSelection" form="composer-cancel-form" class="cancel-btn">Cancel</button>
    <button type="submit" name="addComment" form="composer-add-form" class="save-btn">Save</button>
  </div></div>
=== deleteDialog ===
<dialog id="confirm-delete-{{.ID}}"><article><header><strong>Delete comment?</strong></header><p><small><code>{{.File}}</code> {{.LineSpan}}</small></p><footer>
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <fieldset role="group">
        <button type="button" command="close" commandfor="confirm-delete-{{.ID}}" class="secondary">Cancel</button>
        <button type="submit" name="deleteComment" class="contrast">Delete</button>
      </fieldset>
    </form>
  </footer></article></dialog>
=== deleteDialogTagged ===
<dialog id="confirm-delete-{{.ID}}"><article><header><strong>Delete comment?</strong></header><p><small>{{if .IsRegionLevel}}<code>{{.URL}}</code> · region{{else}}{{if .IsAreaLevel}}<code>{{.File}}</code> · area{{else}}<code>{{.File}}</code> · file{{end}}{{end}}</small></p><footer>
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <fieldset role="group">
        <button type="button" command="close" commandfor="confirm-delete-{{.ID}}" class="secondary">Cancel</button>
        <button type="submit" name="deleteComment" class="contrast">Delete</button>
      </fieldset>
    </form>
  </footer></article></dialog>
=== endSessionDialog ===
<dialog id="confirm-end-session"><article><header><strong>End session?</strong></header><p><small>Emits the final <code>session_end</code> event and stops the prereview server — your agent stops consuming the stream. This can't be undone.</small></p><footer>
    <form method="POST">
      <fieldset role="group">
        <button type="button" command="close" commandfor="confirm-end-session" class="secondary">Cancel</button>
        <button type="submit" name="endSession" class="contrast">End session</button>
      </fieldset>
    </form>
  </footer></article></dialog>
