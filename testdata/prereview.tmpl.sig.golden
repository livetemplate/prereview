=== allComments ===
<section class="all-comments">
  <header class="ac-head">
    <strong>All comments ({{.CommentCount}})</strong>
    <form method="POST" style="margin:0">
      <button type="submit" name="toggleCommentList" class="outline contrast" title="Return to the file you were viewing">Back</button>
    </form>
  </header>
  {{if .VisibleComments}}
  <ul class="ac-list">
    {{range .VisibleComments}}
    <li class="ac-item{{if .Resolved}} is-resolved{{end}}" data-key="{{.ID}}">
      <form method="POST" class="ac-jump">
        <input type="hidden" name="id" value="{{.ID}}">
        <button type="submit" name="jumpToComment" class="ac-jump-btn">
          <div class="ac-where"><code>{{.File}}</code> · {{.LineSpan}} <small>({{.Side}})</small>{{if .Resolved}} <small class="resolved-badge">resolved</small>{{end}}{{if .AnchorMoved}} <small class="moved-badge">moved</small>{{end}}{{if .AnchorOutdated}} <small class="outdated-badge">outdated</small>{{end}}{{if .Processed}} <small class="processed-badge">worked on</small>{{end}}</div>
          <div class="ac-body">{{.Body}}</div>
        </button>
      </form>
      {{if .AnchorOutdated}}<details class="anchor-orig"><summary>⚠ the document changed here — originally anchored to:</summary><pre>{{.Anchor.Text}}</pre></details>{{end}}
      <div class="ac-actions">
        <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="toggleResolved" class="outline">{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>
        {{if .Resolved}}<form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="hideComment" class="outline">Hide</button>
        </form>{{end}}
        {{if and (not .Resolved) .AnchorOutdated}}<form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="reanchorComment" class="outline">Re-anchor</button>
        </form>{{end}}
        {{if and (not .Resolved) (not .AnchorOutdated)}}<form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="editComment" class="outline">Edit</button>
        </form>{{end}}
        <button type="button" class="secondary outline" command="show-modal" commandfor="confirm-delete-{{.ID}}">Delete</button>
        {{template "deleteDialog" .}}
      </div>
    </li>
    {{end}}
  </ul>
  {{else}}
  
  <div class="ac-empty">
    <p class="ac-empty-msg">{{if and (gt .CommentCount 0) (not .ShowResolved)}}{{.CommentCount}} resolved comment{{if ne .CommentCount 1}}s{{end}} hidden — toggle “Show resolved” to see them.{{else}}No comments yet.{{end}}</p>
    <form method="POST" style="margin:0">
      <button type="submit" name="toggleCommentList" class="contrast ac-empty-back" title="Return to the file you were viewing">← Back to file</button>
    </form>
  </div>
  {{end}}
</section>
=== binaryView ===
{{with $.CurrentDiff}}  
  {{$kind := $.BinaryKind}}
  {{if eq $kind "image"}}
  
  {{template "regionToggle" $}}{{if not $.RegionSelectArmed}}<small class="region-hint">Pinch or scroll to zoom; use the button above to comment on a region.</small>{{end}}<div class="binary-preview binary-image"><div class="image-with-areas{{if $.RegionSelectArmed}} is-armed{{end}}" data-key="iwa-{{.Path}}">
    <img src="/{{.Path}}" alt="{{.Path}}" {{if $.RegionSelectArmed}}lvt-fx:area-select="selectImageArea" style="touch-action:none;user-select:none;-webkit-user-select:none;"{{else}}style="user-select:none;-webkit-user-select:none;"{{end}}>
    {{range $.AreaComments}}<div class="area-overlay{{if .Resolved}} is-resolved{{end}}" data-key="ao-{{.ID}}" style="left:{{.Area.PercentX}};top:{{.Area.PercentY}};width:{{.Area.PercentW}};height:{{.Area.PercentH}};" title="{{.Body}}"></div>{{end}}
    {{if eq $.CommentMode "area"}}<div class="area-overlay area-overlay-pending" data-key="ao-pending" style="left:{{$.SelectionArea.PercentX}};top:{{$.SelectionArea.PercentY}};width:{{$.SelectionArea.PercentW}};height:{{$.SelectionArea.PercentH}};"></div>{{end}}
  </div></div>
  {{else}}{{if eq $kind "pdf"}}
  
  <div class="binary-preview binary-pdf-card">
    <div class="pdf-card-icon" aria-hidden="true">📄</div>
    <strong class="pdf-card-name">{{.Path}}</strong>
    <a role="button" class="contrast pdf-card-open" href="/{{.Path}}" target="_blank" rel="noopener">Open PDF in new tab →</a>
  </div>
  {{else}}{{if eq $kind "video"}}
  <div class="binary-preview binary-video"><video controls preload="metadata" src="/{{.Path}}"></video></div>
  {{else}}{{if eq $kind "audio"}}
  <div class="binary-preview binary-audio"><audio controls preload="metadata" src="/{{.Path}}"></audio></div>
  {{else}}
  <p class="empty">Binary file — cannot display.</p>
  {{end}}{{end}}{{end}}{{end}}{{end}}
=== blockComments ===
{{$bs := .StartLine}}{{$be := .EndLine}}{{range $.FileComments}}{{if and (ge .ToLine $bs) (le .ToLine $be)}}{{template "commentCardFull" .}}{{end}}{{end}}{{if and (ne $.SelectionEndMax 0) (ge $.SelectionEndMax $bs) (le $.SelectionEndMax $be)}}{{template "composer" $}}{{end}}
=== blockSuggestions ===
{{$bs := .StartLine}}{{$be := .EndLine}}{{range $.FileSuggestions}}{{if and (ge .ToLine $bs) (le .ToLine $be)}}{{template "suggestionCard" .}}{{end}}{{end}}
=== commentCardFull ===
<div class="inline-comment{{if .Resolved}} is-resolved{{end}}{{if .AnchorOutdated}} is-outdated{{end}}" data-key="{{.ID}}" lvt-fx:animate="fade"{{if and (eq $.ScrollToCommentID .ID) (eq $.SelectionAnchor 0) (eq $.CommentMode "")}} lvt-fx:scroll="into-view" tabindex="-1" lvt-autofocus{{end}}><header><span>{{.LineSpan}} · <small>{{.Side}}</small>{{if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}{{if .AnchorMoved}} · <small class="moved-badge">moved</small>{{end}}{{if .AnchorOutdated}} · <small class="outdated-badge">outdated</small>{{end}}{{if .Draft}} · <small class="draft-badge">draft</small>{{end}}{{if .Processed}} · <small class="processed-badge">worked on</small>{{end}}{{if eq .QueueState "queued"}} · <small class="queued-badge" title="queued for the agent">queued</small>{{end}}{{if index $.AwaitingAgent .ID}} · <small class="awaiting-badge" title="you replied — waiting on the agent">awaiting agent</small>{{end}}</span></header>{{if .Snippet}}<div class="ic-snippet">{{.Snippet}}</div>{{end}}<div class="body">{{.Body}}</div>{{if .AnchorOutdated}}<details class="anchor-orig"><summary>⚠ the document changed here — originally anchored to:</summary><pre>{{.Anchor.Text}}</pre></details>{{end}}{{template "thread" (index $.Threads .ID)}}{{if eq $.ReplyingID .ID}}<form method="POST" class="reply-form" lvt-on:keydown="postReply" lvt-key="Mod+Enter">
    <input type="hidden" name="id" value="{{.ID}}">
    <textarea name="body" placeholder="Reply to the agent…" lvt-on:input="saveReplyDraft" lvt-mod:debounce="200" lvt-autofocus>{{$.ReplyDraft}}</textarea>
    <div class="reply-actions">
      <button type="submit" name="cancelReply" class="secondary outline">Cancel</button>
      <button type="submit" name="postReply">Send reply</button>
    </div>
  </form>{{end}}<div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="toggleResolved" class="outline">{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>{{if ne $.ReplyingID .ID}}<form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="openReply" class="outline">Reply</button></form>{{end}}{{if and $.AgentMode (not .Resolved) (not .AnchorOutdated) .Processed}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="enqueueComment" class="outline enqueue-btn" title="Re-enqueue — ask the agent to redo this">Re-enqueue</button>
    </form>{{end}}{{if .Resolved}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="hideComment" class="outline">Hide</button>
    </form>{{end}}{{if and (not .Resolved) .AnchorOutdated}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="reanchorComment" class="outline">Re-anchor</button>
    </form>{{end}}{{if and (not .Resolved) (not .AnchorOutdated)}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="editComment" class="outline">Edit</button>
    </form>{{end}}<button type="button" class="secondary outline" command="show-modal" commandfor="confirm-delete-{{.ID}}">Delete</button>{{template "deleteDialog" .}}</div></div>
=== commentCardSimple ===
<div class="inline-comment{{if .Resolved}} is-resolved{{end}}" data-key="{{.ID}}"lvt-fx:animate="fade"{{if and (eq $.ScrollToCommentID .ID) (eq $.SelectionAnchor 0) (eq $.CommentMode "")}} lvt-fx:scroll="into-view" tabindex="-1" lvt-autofocus{{end}}><header><span>{{.LineSpan}}{{if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}{{if .Draft}} · <small class="draft-badge">draft</small>{{end}}{{if .Processed}} · <small class="processed-badge">worked on</small>{{end}}{{if eq .QueueState "queued"}} · <small class="queued-badge" title="queued for the agent">queued</small>{{end}}{{if index $.AwaitingAgent .ID}} · <small class="awaiting-badge" title="you replied — waiting on the agent">awaiting agent</small>{{end}}</span></header><div class="body">{{.Body}}</div>{{template "thread" (index $.Threads .ID)}}{{if eq $.ReplyingID .ID}}<form method="POST" class="reply-form" lvt-on:keydown="postReply" lvt-key="Mod+Enter">
    <input type="hidden" name="id" value="{{.ID}}">
    <textarea name="body" placeholder="Reply to the agent…" lvt-on:input="saveReplyDraft" lvt-mod:debounce="200" lvt-autofocus>{{$.ReplyDraft}}</textarea>
    <div class="reply-actions">
      <button type="submit" name="cancelReply" class="secondary outline">Cancel</button>
      <button type="submit" name="postReply">Send reply</button>
    </div>
  </form>{{end}}<div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="toggleResolved" class="outline">{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>{{if ne $.ReplyingID .ID}}<form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="openReply" class="outline">Reply</button></form>{{end}}{{if .Resolved}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="hideComment" class="outline">Hide</button>
    </form>{{end}}{{if not .Resolved}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="editComment" class="outline">Edit</button>
    </form>{{end}}<button type="button" class="secondary outline" command="show-modal" commandfor="confirm-delete-{{.ID}}">Delete</button>{{template "deleteDialogTagged" .}}</div></div>
=== composer ===
<div class="composer{{if eq $.CommentMode "region"}} ext-composer{{end}}" data-key="composer"{{if eq $.CommentMode "region"}} lvt-fx:scroll="into-view"{{end}}><strong>{{if eq $.CommentMode "region"}}{{if $.EditingCommentID}}Editing comment on {{else}}Comment on {{end}}region · <small>{{$.CurrentURL}}</small>{{else}}{{if eq $.CommentMode "file"}}{{if $.EditingCommentID}}Editing comment on file{{else}}Comment on file{{end}} <code>{{$.CurrentDiff.Path}}</code>{{else}}{{if eq $.CommentMode "area"}}{{if $.EditingCommentID}}Editing comment on area of{{else}}Comment on area of{{end}} <code>{{$.CurrentDiff.Path}}</code>{{else}}{{if eq $.CommentMode "text"}}{{if $.EditingCommentID}}Editing comment on {{else}}Comment on {{end}}{{$.SelectionLabel}} · “<span class="selection-snippet">{{$.SelectionText}}</span>”{{else}}{{if $.ReanchorCommentID}}Re-anchoring comment to {{else}}{{if $.EditingCommentID}}Editing comment on {{else}}Comment on {{end}}{{end}}{{$.SelectionLabel}}{{end}}{{end}}{{end}}{{end}}</strong>{{if and (eq $.CommentMode "") (ne $.SelectionAnchor 0) (eq $.SelectionAnchor $.SelectionEnd) (not $.EditingCommentID) (not $.ShowRenderedMarkdown) (not $.ShowRenderedHTML)}} <small class="selection-hint">tap another line to extend, or save now for a single line</small>{{end}}<form method="POST" lvt-form:preserve class="composer-add" id="composer-add-form" lvt-on:keydown="addComment" lvt-key="Mod+Enter">
    <textarea name="body" placeholder="{{if eq $.CommentMode "region"}}What's wrong with this region?{{else}}{{if eq $.CommentMode "file"}}What's wrong with this file?{{else}}{{if eq $.CommentMode "area"}}What's wrong with this region?{{else}}{{if eq $.CommentMode "text"}}What's wrong with this text?{{else}}What's wrong with these lines?{{end}}{{end}}{{end}}{{end}}" required lvt-autofocus lvt-on:input="saveDraft" lvt-mod:debounce="150">{{$.DraftBody}}</textarea>
  </form><form method="POST" class="composer-cancel" id="composer-cancel-form"></form><div class="c-actions">
    <button type="submit" name="clearSelection" form="composer-cancel-form" class="cancel-btn">Cancel{{with index $.KeyHint "clearSelection"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</button>
    <button type="submit" name="addComment" form="composer-add-form" class="save-btn">Save{{with index $.KeyHint "addComment"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</button>
  </div></div>
=== deleteDialog ===
<dialog id="confirm-delete-{{.ID}}"><article><header><strong>Delete comment?</strong></header><p><small><code>{{.File}}</code> {{.LineSpan}}</small></p><footer>
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <fieldset role="group">
        <button type="button" command="close" commandfor="confirm-delete-{{.ID}}" class="secondary">Cancel</button>
        <button type="submit" name="deleteComment" class="contrast">Delete</button>
      </fieldset>
    </form>
  </footer></article></dialog>
=== deleteDialogTagged ===
<dialog id="confirm-delete-{{.ID}}"><article><header><strong>Delete comment?</strong></header><p><small>{{if .IsRegionLevel}}<code>{{.URL}}</code> · region{{else}}{{if .IsAreaLevel}}<code>{{.File}}</code> · area{{else}}<code>{{.File}}</code> · file{{end}}{{end}}</small></p><footer>
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <fieldset role="group">
        <button type="button" command="close" commandfor="confirm-delete-{{.ID}}" class="secondary">Cancel</button>
        <button type="submit" name="deleteComment" class="contrast">Delete</button>
      </fieldset>
    </form>
  </footer></article></dialog>
=== diffView ===
{{with $.CurrentDiff}}  
  <div class="code{{if eq .Note "file added"}} pure-add{{else}}{{if eq .Note "file deleted"}} pure-del{{end}}{{end}}{{if $.FileView}} file-view{{end}}" data-key="code-{{.Path}}" data-path="{{.Path}}" lvt-fx:scroll="reset-on:data-path" lvt-fx:text-select="selectText" style="--diff-min-width: calc({{.MaxLineChars}}ch + 7ch)">{{range $.VisibleLines}}{{if eq .Kind "fold"}}<div class="line-row fold-row" data-key="F{{.OldNum}}-{{.NewNum}}" aria-hidden="true"><span class="fold-label">··· {{.Content}} unchanged line{{if ne .Content "1"}}s{{end}} ···</span></div>{{else}}{{$ln := .NewNum}}{{if not $ln}}{{$ln = .OldNum}}{{end}}{{$lside := "new"}}{{if eq .Kind "del"}}{{$lside = "old"}}{{end}}{{$rowkey := printf "%d-%s" $ln $lside}}{{$commentCount := index $.CommentCountLines $rowkey}}{{$suggestionCount := index $.SuggestionCountLines $rowkey}}{{$hasComment := gt $commentCount 0}}{{$hasSuggestion := gt $suggestionCount 0}}{{$hasQuiz := gt (index $.QuizCountLines $rowkey) 0}}{{$lkey := printf "L%d-%d" .OldNum .NewNum}}<div class="line-row{{if or $hasComment $hasSuggestion $hasQuiz}} has-line-marks{{end}}{{if index $.RowToggled $rowkey}} row-toggled{{end}}" data-key="row-L{{.OldNum}}-{{.NewNum}}{{if and (ne $.SelectionEndMax 0) (eq $.SelectionEndMax $ln) (eq $.SelectionSide $lside)}}-composing{{end}}"><div tabindex="0" lvt-on:click="selectLine" lvt-on:keydown="selectLine" lvt-key="Enter" data-line="{{$ln}}" data-side="{{if eq .Kind "del"}}old{{else}}new{{end}}" class="line {{.Kind}}{{if index $.SelectedLines $ln}} selected{{end}}{{if eq $.CursorKey $lkey}} is-cursor{{end}}"{{if eq $.CursorKey $lkey}} lvt-autofocus lvt-fx:scroll="into-view"{{else}}{{if eq $.ScrollToReadKey $lkey}} lvt-fx:scroll="into-view"{{end}}{{end}} data-key="{{$lkey}}"><span class="gutter"><span class="gutter-mark">{{if eq .Kind "add"}}+{{else}}{{if eq .Kind "del"}}-{{else}}&nbsp;{{end}}{{end}} </span>{{$ln}}</span><span class="content chroma" data-line-text>{{index $.LineDisplay $lkey}}</span></div>{{if or $hasComment $hasSuggestion $hasQuiz}}<span class="line-margin">
        <button type="button" class="line-marks{{if index $.AwaitingLines $rowkey}} has-unread{{end}}" lvt-on:click="toggleRow" data-row="{{$rowkey}}" lvt-el:toggleClass:on:click="row-toggled" data-lvt-target="closest:.line-row" aria-label="Show or hide the annotations on this line" title="Show/hide this line's annotations">
          <span class="line-mark{{if index $.AnnotationOpenLines $rowkey}} is-open{{else}}{{if index $.AnnotationAcceptedLines $rowkey}} is-accepted{{else}} is-done{{end}}{{end}}" aria-hidden="true">{{index $.AnnotationCountLines $rowkey}}</span>
        </button>
      </span>{{end}}{{range (index $.CommentsByEndLine $ln)}}{{if or (eq .Side $lside) (eq .Side "")}}{{template "commentCardFull" .}}{{end}}{{end}}{{range (index $.SuggestionsByEndLine $ln)}}{{if or (eq .Side $lside) (eq .Side "")}}{{template "suggestionCard" .}}{{end}}{{end}}{{range (index $.QuizByEndLine $ln)}}{{if or (eq .Side $lside) (eq .Side "")}}{{template "quizCard" .}}{{end}}{{end}}{{if and (ne $.SelectionEndMax 0) (eq $.SelectionEndMax $ln) (eq $.SelectionSide $lside)}}{{template "composer" $}}{{end}}</div>
{{end}}{{end}}<div class="code-sentinel" aria-hidden="true"></div></div>{{end}}
=== endSessionDialog ===
<dialog id="confirm-end-session"><article><header><strong>End session?</strong></header><p><small>Emits the final <code>session_end</code> event and stops the prereview server — your agent stops consuming the stream. This can't be undone.</small></p>{{if .AwaitingApplyCount}}
  <p class="end-warn" role="alert"><small><strong>{{.AwaitingApplyCount}} accepted edit{{if ne .AwaitingApplyCount 1}}s{{end}} not yet applied.</strong> The agent still has to write {{if eq .AwaitingApplyCount 1}}it{{else}}them{{end}} to the file (<code>prereview applied</code>). Ending now leaves the document without {{if eq .AwaitingApplyCount 1}}that change{{else}}those changes{{end}}.</small></p>{{end}}<footer>
    <form method="POST">
      <fieldset role="group">
        <button type="button" command="close" commandfor="confirm-end-session" class="secondary">Cancel</button>
        <button type="submit" name="endSession" class="contrast">End session</button>
      </fieldset>
    </form>
  </footer></article></dialog>
=== externalBody ===

<header class="bar bar-external">
  <span class="ext-target">prereview · annotating <code>{{.TargetURL}}</code>{{if .CurrentURL}} <span class="ext-page">{{.CurrentURL}}</span>{{end}}</span>
  <span class="bar-actions"><form method="POST" style="margin:0">
      <button type="submit" name="toggleAnnotations" class="outline secondary anno-toggle" aria-pressed="{{if .AnnoDrawerOpen}}true{{else}}false{{end}}" title="Show/hide annotations">💬 {{len $.AllRegionComments}}</button>
    </form>{{if .AgentMode}}
    <form method="POST" style="margin:0">
      <button type="submit" name="toggleAgentPause" class="contrast tb-pause{{if .AgentPaused}} is-paused{{end}}" title="{{if .AgentPaused}}Batching — annotations held, not sent. Resume to send the batch.{{else}}Live — each annotation is sent as you make it. Pause to batch them instead.{{end}}">{{if .AgentPaused}}▶ Resume — send batch{{else}}⏸ Pause — batch{{end}}</button>
    </form><form method="POST" style="margin:0">
      <button type="button" command="show-modal" commandfor="confirm-end-session" class="contrast" title="Emit session_end and stop the server — your agent stops consuming the stream">End session</button>
    </form>{{else}}<form method="POST" style="margin:0">
      <button type="button" command="show-modal" commandfor="confirm-quit" class="contrast" title="Stop the prereview server">Quit</button>
    </form>{{end}}</span>
</header>
<div class="layout layout-external">
  <main class="viewer ext-viewer">
    {{template "regionToggle" $}}
    <div class="preview-stage ext-stage" lvt-fx:proxy-bridge="setProxyURL" data-key="ext-stage"{{with $.FocusedComment}} data-focus-token="{{$.FocusSeq}}" data-focus-url="{{.URL}}" data-focus-y="{{.Area.Y}}"{{end}}>
      
      <iframe class="ext-frame" src="{{.ProxyBaseURL}}" title="Live preview of {{.TargetURL}}" lvt-ignore></iframe>
      <div class="pin-layer" data-pin-layer data-key="pin-layer">{{range $.RegionComments}}<button type="button" class="area-overlay pin-btn{{if .Resolved}} is-resolved{{end}}{{if eq $.FocusedCommentID .ID}} is-focused{{end}}" lvt-on:click="editComment" data-id="{{.ID}}" data-key="pin-{{.ID}}" style="left:{{.Area.PercentX}};top:{{.Area.PercentY}};width:{{.Area.PercentW}};height:{{.Area.PercentH}};" title="{{.Body}}" aria-label="Edit annotation"></button>{{end}}{{if eq $.CommentMode "region"}}<div class="area-overlay area-overlay-pending" data-key="pin-pending" style="left:{{$.SelectionArea.PercentX}};top:{{$.SelectionArea.PercentY}};width:{{$.SelectionArea.PercentW}};height:{{$.SelectionArea.PercentH}};"></div>{{end}}</div>
      {{if .RegionSelectArmed}}<div class="region-overlay" lvt-fx:region-select="selectRegion" data-surface="page" data-key="ext-region-overlay"></div>{{end}}
    </div>
    {{if eq $.CommentMode "region"}}{{template "composer" $}}{{end}}
  </main>
  <aside class="ext-sidebar{{if .AnnoDrawerOpen}} is-open{{end}}" aria-label="Annotations">
    <header class="ext-sidebar-head"><strong>Annotations ({{len $.AllRegionComments}})</strong><form method="POST" style="margin:0">
        <button type="submit" name="toggleAnnotations" class="outline secondary close-btn" aria-label="Close annotations">{{template "iconClose16"}}</button>
      </form></header>
    <div class="ext-sidebar-body">{{range $.AllRegionComments}}<div class="inline-comment ext-anno{{if .Resolved}} is-resolved{{end}}{{if eq $.FocusedCommentID .ID}} is-focused{{end}}" data-key="{{.ID}}" lvt-fx:animate="fade"><form method="POST" class="anno-locate-form">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="focusComment" class="anno-locate" title="Locate this region on the page"><span class="ext-page-link">📍 {{.URL}}</span>{{if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}<span class="anno-body">{{.Body}}</span></button>
        </form><div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="toggleResolved" class="outline">{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>{{if not .Resolved}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="editComment" class="outline">Edit</button>
    </form>{{end}}<button type="button" class="secondary outline" command="show-modal" commandfor="confirm-delete-{{.ID}}">Delete</button>{{template "deleteDialogTagged" .}}</div></div>{{else}}<p class="empty"><small>No annotations yet — tap “Select a region”, then drag a box on the page.</small></p>{{end}}</div>
  </aside>
</div>
<footer class="app-footer" role="contentinfo"><small>prereview{{if ne .Version "dev"}} v{{.Version}}{{end}} · external mode · <code>{{.TargetURL}}</code></small></footer>
=== fileDrawer ===
<dialog id="files-drawer" open class="{{if .FileDrawerOpen}}is-open{{end}}" lvt-fx:resize="--pr-drawer-w" data-resize-handle=".resize-handle" data-resize-min="200" data-resize-max="560" data-resize-store="prereview.drawerW">
  
  <div class="drawer-collapse">
    <form method="POST">
      <button type="submit" name="toggleFiles" class="collapse-toggle" aria-label="{{if .FileDrawerOpen}}Show file list{{else}}Hide file list{{end}}" aria-expanded="{{if .FileDrawerOpen}}false{{else}}true{{end}}" title="{{if .FileDrawerOpen}}Show files{{else}}Hide files{{end}}{{with index $.KeyHint "toggleFiles"}} ({{.}}){{end}}">{{if .FileDrawerOpen}}{{template "iconChevronRight"}}{{else}}{{template "iconChevronLeft"}}{{end}}</button>
    </form>
  </div>
  <div class="drawer-head">
    <strong>{{len .Files}} file{{if ne (len .Files) 1}}s{{end}}</strong>
    <form method="POST">
      <button type="submit" name="closeFiles" class="outline close-btn" aria-label="Close">{{template "iconClose16"}}</button>
    </form>
  </div>
  
  
  
  {{if not .NoGit}}
  <div class="drawer-base">
    <form method="POST" class="base-select-form">
      <label for="base-input">Base</label>
      <select id="base-input" name="ref" lvt-on:change="setBase">
        {{range .BaseChoices}}
        <option value="{{.}}"{{if eq . $.Base}} selected{{end}}>{{.}}</option>
        {{end}}
      </select>
    </form>
  </div>
  {{end}}
  <div class="drawer-search">
    <form method="POST" lvt-form:preserve>
      <input type="text" name="filter" placeholder="Filter files…" value="{{.FileFilter}}" lvt-on:input="setFileFilter" lvt-mod:debounce="200" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" enterkeyhint="search">
    </form>
  </div>
  
  {{if and (gt .ChangedFilesCount 0) (lt .ChangedFilesCount (len .Files))}}
  <div class="drawer-scope">
    <form method="POST">
      <button type="submit" name="toggleFileScope" class="scope-toggle{{if not .ShowAllFiles}} is-on{{end}}" title="{{if .ShowAllFiles}}Show only files changed vs {{.Base}}{{else}}Show all {{len .Files}} tracked files{{end}}">
        {{if .ShowAllFiles}}All {{len .Files}} files · show changed only{{else}}Changed {{.ChangedFilesCount}} · show all {{len .Files}}{{end}}
      </button>
    </form>
  </div>
  {{end}}
  <div class="drawer-body">
    
    {{.FileBrowserHTML}}
  </div>
  
  <div class="resize-handle" aria-hidden="true"></div>
</dialog>
=== fileHeader ===
{{with $.CurrentDiff}}  <header class="file-head">{{if gt $.ReadPercent 0}}<div class="read-progress-fill" style="width: {{$.ReadPercent}}%" aria-hidden="true"></div>{{end}}<span class="file-head-name" title="{{.Path}}">{{if $.SelectedFileDir}}<span class="fh-dir">{{$.SelectedFileDir}}</span>{{end}}<strong class="fh-base">{{$.SelectedFileBase}}</strong>{{if .Note}} <small>{{.Note}}</small>{{end}}</span>
    
    <span class="file-head-actions">
    
    {{if $.HasReadFrontier}}
    <form method="POST" class="file-head-resume">
      <button type="submit" name="jumpToReadFrontier" class="outline" title="Jump to the first content you haven't read yet">{{template "iconChevronDown"}}<span class="resume-label">Jump to unread</span></button>
    </form>
    {{end}}
    
    {{if and (ne $.CommentMode "file") (not $.ViewingVersion)}}
    <form method="POST" class="file-head-comment">
      <button type="submit" name="openFileComment" class="contrast" title="Add a comment about the whole file" aria-label="Comment on file">{{template "iconChat14"}}<span class="file-head-comment-label">Comment on file{{with index $.KeyHint "openFileComment"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span></button>
    </form>
    {{end}}
    
    {{if and (ne $.CommentMode "file") (not $.ViewingVersion) $.QuizPrompts}}
    {{if $.QuizPending}}
    <span class="quiz-trigger is-pending" title="The request is queued — the agent will answer shortly">{{template "iconQuiz"}}<span class="quiz-trigger-label">Quiz requested…</span></span>
    {{else}}{{if eq (len $.QuizPrompts) 1}}
    <form method="POST" style="margin:0"><button type="submit" name="requestQuiz" class="quiz-trigger" title="Ask the agent for a comprehension quiz about this diff">{{template "iconQuiz"}}<span class="quiz-trigger-label">Quiz me</span></button></form>
    {{else}}
    <div class="tb-dropdown prompts-dropdown" lvt-el:toggleClass:on:click="open" lvt-el:removeClass:on:click-away="open">
      <button type="button" class="quiz-trigger" aria-haspopup="menu" title="Ask the agent for a comprehension quiz about this diff">{{template "iconQuiz"}}<span class="quiz-trigger-label">Quiz me</span></button>
      <div class="tb-dropdown-panel prompts-panel" role="menu" aria-label="Quiz prompts">
        {{range $.QuizPrompts}}
        <form method="POST"><input type="hidden" name="slug" value="{{.Slug}}"><button type="submit" name="requestQuiz" class="prompt-row" title="{{.Body}}">{{.Title}}</button></form>
        {{end}}
      </div>
    </div>
    {{end}}{{end}}
    {{end}}
    
    {{if and (ne $.CommentMode "file") (not $.ViewingVersion) $.Prompts}}
    <div class="tb-dropdown prompts-dropdown" lvt-el:toggleClass:on:click="open" lvt-el:removeClass:on:click-away="open">
      <button type="button" class="prompts-trigger" aria-haspopup="menu" title="Ask the agent for suggestions using a prebuilt prompt">{{template "iconSuggestion"}}<span class="prompts-trigger-label">Ask for suggestions</span></button>
      <div class="tb-dropdown-panel prompts-panel" role="menu" aria-label="Suggestion prompts">
        {{range $.Prompts}}
        <form method="POST"><input type="hidden" name="slug" value="{{.Slug}}"><button type="submit" name="pickPrompt" class="prompt-row" title="{{.Body}}">{{.Title}}</button></form>
        {{end}}
      </div>
    </div>
    {{end}}
    
    {{if $.Versions}}
    <div class="tb-dropdown versions-dropdown" lvt-el:toggleClass:on:click="open" lvt-el:removeClass:on:click-away="open">
      <button type="button" class="versions-trigger" aria-haspopup="menu" title="Versions of this file — view or roll back to a previous version">{{template "iconHistory14"}}<span class="versions-trigger-label">Versions</span><span class="versions-count">{{len $.Versions}}</span></button>
      <div class="tb-dropdown-panel versions-panel" role="menu" aria-label="File versions">
        
        {{range $.Versions}}
        <div class="version-row{{if .Viewing}} viewing{{end}}">
          <button type="button" class="version-summary-toggle" lvt-el:toggleClass:on:click="expanded" data-lvt-target="closest:.version-row" aria-label="Show what changed and version actions"><span class="version-meta">
            <span class="version-label">{{.Label}}{{if .Deleted}} · deleted{{end}}</span>
            <span class="version-when">{{.When}}{{if .Current}} · current{{end}}</span>
          </span><span class="version-more" aria-hidden="true">⋯</span></button>
          <div class="version-details">
            {{if .Changelog}}<p class="version-changelog">{{.Changelog}}</p>{{end}}
            <div class="version-summary">{{template "versionSummary" .Summary}}</div>
            <span class="version-actions">
              <form method="POST"><input type="hidden" name="seq" value="{{.Seq}}"><button type="submit" name="viewVersion" class="version-btn">View</button></form>
              {{if not .Current}}<form method="POST"><input type="hidden" name="seq" value="{{.Seq}}"><button type="submit" name="diffVersion" class="version-btn">Diff</button></form>
              <form method="POST"><input type="hidden" name="seq" value="{{.Seq}}"><button type="submit" name="restoreVersion" class="version-btn version-restore">Restore</button></form>{{end}}
            </span>
          </div>
        </div>
        {{end}}
      </div>
    </div>
    {{end}}
    </span>
  </header>{{end}}
=== htmlView ===
{{with $.CurrentDiff}}  
  <div class="html-view" data-key="html-{{.Path}}">{{template "regionToggle" $}}<div class="preview-stage"><iframe class="html-preview" sandbox="allow-scripts" srcdoc="{{$.RenderedHTMLDoc}}" lvt-fx:preview-bridge title="HTML preview of {{.Path}}"></iframe>{{if $.RegionSelectArmed}}<div class="region-overlay" lvt-fx:region-select="selectBlock" data-surface="html" data-key="region-html-{{.Path}}"></div>{{end}}</div>{{range $.RenderedHTML}}{{$bs := .StartLine}}{{$be := .EndLine}}{{$hbkey := printf "HB-%d-%d" $bs $be}}<div class="html-block{{if and (ne $.SelectionEndMax 0) (ge $.SelectionEndMax $bs) (le $.SelectionEndMax $be)}} selected{{end}}" data-key="{{$hbkey}}">{{template "blockComments" .}}{{template "blockSuggestions" .}}</div>{{end}}</div>{{end}}
