=== kbdHelp ===
<div class="kbd-help-backdrop{{if .KeyHelpOpen}} is-open{{end}}" lvt-on:click="toggleKeyboardHelp" aria-hidden="true"></div>
<div class="kbd-help-modal{{if .KeyHelpOpen}} is-open{{end}}" role="dialog" aria-label="Keyboard shortcuts" aria-modal="true">
  <div class="kbd-help-head">
    <strong>Keyboard shortcuts</strong>
    <form method="POST">
      <button type="submit" name="toggleKeyboardHelp" class="outline close-btn" aria-label="Close">
        {{template "iconClose16"}}
      </button>
    </form>
  </div>
  <dl class="kbd-help-list">{{range .KeyBindings}}
    <div class="kbd-row"><dt><kbd>{{.Display}}</kbd></dt><dd>{{.Label}}</dd></div>{{end}}
  </dl>
  <p class="kbd-help-note">Drawing a precise region on rendered HTML or an image needs a mouse — from the keyboard, comment on the whole block or image instead.</p>
  
  <p class="kbd-help-usage"><a href="/_usage" target="_blank" rel="noopener">Open the usage guide ↗</a></p>
</div>
=== markdownView ===
{{with $.CurrentDiff}}  <div class="md-view" data-key="md-{{.Path}}" lvt-spy="h1, h2, h3" lvt-fx:text-select="selectText" data-surface="block">{{range $.RenderedMarkdown}}{{$bs := .StartLine}}{{$be := .EndLine}}{{$mbkey := printf "MB-%d-%d" $bs $be}}{{$mbstatus := index $.BlockDiffStatus $mbkey}}<div class="md-block{{if and (ne $.SelectionEndMax 0) (ge $.SelectionEndMax $bs) (le $.SelectionEndMax $be)}} selected{{end}}{{if $mbstatus}} md-{{$mbstatus}}{{end}}{{if index $.RowToggled $mbkey}} row-toggled{{end}}" data-key="{{$mbkey}}"{{if or (eq $.ScrollHeadingBlockKey $mbkey) (eq $.ScrollToReadKey $mbkey)}} lvt-fx:scroll="into-view"{{end}}>{{$ba := index $.BlockAnnotations $mbkey}}{{if gt $ba.Total 0}}<button type="button" class="md-block-marks" lvt-on:click="toggleRow" data-row="{{$mbkey}}" lvt-el:toggleClass:on:click="row-toggled" data-lvt-target="closest:.md-block" aria-label="Show or hide the annotations in this block" title="Show/hide this block's annotations">
        <span class="line-mark{{if $ba.Open}} is-open{{else}}{{if $ba.Accepted}} is-accepted{{else}} is-done{{end}}{{end}}" aria-hidden="true">{{$ba.Total}}</span>
      </button>{{end}}<div class="md-rendered" tabindex="0" lvt-on:click="selectBlock" lvt-on:keydown="selectBlock" lvt-key="Enter" data-from="{{$bs}}" data-to="{{$be}}">{{.HTML}}</div>{{template "blockComments" .}}{{template "blockSuggestions" .}}</div>{{end}}</div>{{end}}
=== moreMenu ===
<div class="more-menu-backdrop{{if .MoreMenuOpen}} is-open{{end}}" lvt-on:click="closeMoreMenu" aria-hidden="true"></div>
<div class="more-menu{{if .MoreMenuOpen}} is-open{{end}}" role="menu" aria-label="More options">
  <div class="menu-info">{{len .Files}} files{{if gt .ChangedFilesCount 0}} · {{.ChangedFilesCount}} changed{{end}} · {{.ScopeViewedCount}}/{{.ScopeFileCount}} viewed{{if gt .CommentCount 0}} · {{.CommentCount}} comment{{if ne .CommentCount 1}}s{{end}}{{end}}</div>
  
  {{if gt (len .Files) 1}}
  <form method="POST">
    <button type="submit" name="prevFile" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconChevronLeft"}}</span>
      <span class="menu-label">Previous file</span>
    </button>
  </form>
  <form method="POST">
    <button type="submit" name="nextFile" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconChevronRight"}}</span>
      <span class="menu-label">Next file</span>
    </button>
  </form>
  {{end}}
  
  <form method="POST">
    <button type="submit" name="cycleScheme" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconPalette"}}</span>
      <span class="menu-label">Scheme: {{.SchemeLabel}}</span>
      <span class="menu-meta">{{.NextSchemeLabel}} →</span>
    </button>
  </form>
  <form method="POST">
    <button type="submit" name="cycleTheme" class="menu-item" role="menuitem">
      <span class="menu-icon">{{if eq .ThemeMode "light"}}{{template "iconThemeLight"}}{{else}}{{if eq .ThemeMode "dark"}}{{template "iconThemeDark"}}{{else}}{{template "iconThemeSystem"}}{{end}}{{end}}</span>
      <span class="menu-label">Mode: {{.ThemeModeLabel}}</span>
      <span class="menu-meta">{{.NextThemeModeLabel}} →</span>
    </button>
  </form>
  {{if .CurrentDiff}}
  
  {{with .RenderedHeadings}}
  
  <form method="POST">
    <button type="submit" name="openTOC" class="menu-item toc-menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconTOC"}}</span>
      <span class="menu-label">Table of contents</span>
      <span class="menu-meta">{{len .}}</span>
    </button>
  </form>
  {{end}}
  {{if .IsMarkdown}}
  <form method="POST">
    <button type="submit" name="toggleRawMarkdown" class="menu-item{{if not .RawMarkdown}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .RawMarkdown}}
        {{template "iconRendered"}}
        {{else}}
        {{template "iconViewRaw"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .RawMarkdown}}Preview{{else}}View raw source{{end}}</span>
    </button>
  </form>
  {{end}}
  {{if .IsHTML}}
  <form method="POST">
    <button type="submit" name="toggleRawHTML" class="menu-item{{if not .RawHTML}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .RawHTML}}
        {{template "iconRendered"}}
        {{else}}
        {{template "iconViewRaw"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .RawHTML}}Preview{{else}}View raw source{{end}}</span>
    </button>
  </form>
  {{end}}
  {{if not .ShowRenderedHTML}}
  <form method="POST">
    <button type="submit" name="toggleFileView" class="menu-item{{if .FileView}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .FileView}}
        
        {{template "iconDiff"}}
        {{else}}
        
        {{template "iconFile"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .FileView}}Show diff{{else}}View file{{end}}</span>
    </button>
  </form>
  {{end}}
  {{end}}
  {{if gt .CommentCount 0}}
  <form method="POST">
    <button type="submit" name="toggleCommentList" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconComments"}}</span>
      <span class="menu-label">{{if .ShowAllComments}}Back{{else}}All comments{{end}}{{with index $.KeyHint "toggleCommentList"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
      <span class="menu-meta">{{.CommentCount}}</span>
    </button>
  </form>
  {{end}}
  {{if .HasQuiz}}
  <form method="POST">
    <button type="submit" name="toggleQuiz" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconQuiz"}}</span>
      <span class="menu-label">{{if .ShowQuiz}}Back{{else}}Quiz{{end}}{{with index $.KeyHint "toggleQuiz"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
      <span class="menu-meta">{{.QuizScoreLabel}}</span>
    </button>
  </form>
  {{end}}
  {{if gt .ResolvedCount 0}}
  <form method="POST">
    <button type="submit" name="toggleShowResolved" class="menu-item{{if .ShowResolved}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .ShowResolved}}
        {{template "iconCheck"}}
        {{else}}
        {{template "iconCircle16"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .ShowResolved}}Hide resolved{{else}}Show resolved{{end}}{{with index $.KeyHint "toggleShowResolved"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
      <span class="menu-meta">{{.ResolvedCount}}</span>
    </button>
  </form>
  {{end}}
  
  {{if and .ShowResolved (gt .HiddenResolvedCount 0)}}
  <form method="POST">
    <button type="submit" name="unhideAllResolved" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconCircle16"}}</span>
      <span class="menu-label">Unhide</span>
      <span class="menu-meta">{{.HiddenResolvedCount}}</span>
    </button>
  </form>
  {{end}}
  
  {{if gt .SuggestionCount 0}}
  <form method="POST">
    <button type="submit" name="toggleSuggestions" class="menu-item{{if not .HideSuggestions}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">{{template "iconSuggestion"}}</span>
      <span class="menu-label">{{if .HideSuggestions}}Show suggestions{{else}}Hide suggestions{{end}}</span>
      <span class="menu-meta">{{.SuggestionCount}}</span>
    </button>
  </form>
  {{end}}
  
  {{if $.HasMarks}}
  <form method="POST">
    <button type="submit" name="toggleMarks" class="menu-item{{if not .HideMarks}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">{{if .HideMarks}}{{template "iconCircle16"}}{{else}}{{template "iconCheck"}}{{end}}</span>
      <span class="menu-label">{{if .HideMarks}}Show annotations{{else}}Hide annotations{{end}}</span>
    </button>
  </form>
  {{end}}
  
  {{if gt .HiddenSuggestionCount 0}}
  <form method="POST">
    <button type="submit" name="showHiddenSuggestions" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconSuggestion"}}</span>
      <span class="menu-label">Show hidden suggestions</span>
      <span class="menu-meta">{{.HiddenSuggestionCount}}</span>
    </button>
  </form>
  {{end}}
  {{if gt .DecisionCount 0}}
  <div class="menu-info sg-decision-count">{{.DecisionCount}} suggestion decision{{if ne .DecisionCount 1}}s{{end}} recorded</div>
  {{end}}
  {{if and (eq .CommentCount 0) (eq .ResolvedCount 0)}}
  <div class="menu-info" style="border-bottom: 0; margin-bottom: 0; font-style: italic;">No comments yet — tap a line to add one.</div>
  {{end}}
  
  
  <form method="POST">
    <button type="submit" name="toggleKeyboardHelp" class="menu-item" role="menuitem">
      <span class="menu-icon" aria-hidden="true">?</span>
      <span class="menu-label">Keyboard shortcuts</span>
    </button>
  </form>
  
  <a class="menu-item" role="menuitem" href="/_usage" target="_blank" rel="noopener">
    <span class="menu-icon">{{template "iconBook"}}</span>
    <span class="menu-label">Usage guide</span>
  </a>
</div>
=== prereview ===
<!DOCTYPE html>

<html lang="en" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>prereview · {{.RepoPath}}</title>
<link rel="stylesheet" href="/pico.min.css">
<link rel="stylesheet" href="/livetemplate.css">
<link rel="stylesheet" href="/syntax.css">
<link rel="stylesheet" href="/prereview.css">
</head>
<body data-lvt-loading-debounce-ms="200" data-lvt-heartbeat-ms="10000">

<div class="theme-root" data-scheme="{{.DataScheme}}"{{with .DataMode}} data-mode="{{.}}"{{end}}>

<span class="kbd-esc" hidden aria-hidden="true" lvt-on:window:keydown="clearSelection" lvt-key="Escape"></span>

{{if .ExternalMode}}
{{template "externalBody" $}}
{{else}}

<div class="kbd-bindings" hidden aria-hidden="true">{{range .KeyBindings}}{{$b := .}}{{range $b.Keys}}{{if $b.Action}}<span lvt-on:window:keydown="{{$b.Action}}" lvt-key="{{.}}" lvt-mod:skip-when-typing></span>{{end}}{{end}}{{end}}</div>
{{template "toolbar" $}}


{{template "moreMenu" $}}

{{template "statusBanners" $}}


<div class="drawer-backdrop{{if .FileDrawerOpen}} open{{end}}" lvt-on:click="closeFiles" aria-label="Close file list"></div>

<div class="layout{{if .FocusMode}} focus-mode{{end}}{{if .TocCollapsed}} toc-collapsed{{end}}{{if .HideMarks}} marks-hidden{{end}}{{if .ShowResolved}} show-resolved{{end}}">
{{template "fileDrawer" $}}

<main class="viewer" lvt-fx:viewport-report="reportViewport" data-lvt-viewport-items=".line, .md-block">
{{if .ShowQuiz}}
{{template "quizView" $}}
{{else}}{{if .ShowAllComments}}
{{template "allComments" $}}
{{else}}
{{with .CurrentDiff}}
<article>
{{template "fileHeader" $}}
  {{if $.ViewingVersion}}
  
  <div class="version-view-banner" role="status">
    <span>{{if $.VersionViewDiff}}Comparing a previous version against the current file (read-only).{{else}}Viewing a previous version (read-only).{{end}}</span>
    <form method="POST" class="toast-dismiss-form"><button type="submit" name="exitVersionView" class="refresh-btn">Back to current</button></form>
  </div>
  {{end}}
  
  
  {{if $.ShowQuizNav}}
  <div class="quiz-nav" role="navigation" aria-label="Quiz questions">
    <span class="quiz-nav-label">{{$.QuizNavLabel}}</span>
    <ul class="quiz-nav-dots">
      {{range $it := $.QuizItems}}
      <li><form method="POST" style="margin:0"><input type="hidden" name="questionId" value="{{$it.ID}}"><button type="submit" name="jumpToQuestion" class="quiz-nav-dot is-{{$it.NavState}}{{if $it.Current}} is-current{{end}}" title="{{$it.Prompt}}">{{$it.Num}}</button></form></li>
      {{end}}
    </ul>
    <span class="quiz-nav-actions">
      <form method="POST" style="margin:0"><button type="submit" name="toggleQuiz" class="outline" title="Open the quiz overview">Overview</button></form>
      <form method="POST" style="margin:0"><button type="submit" name="dismissQuizNav" class="outline" title="Hide the quiz navigator">×</button></form>
    </span>
  </div>
  {{end}}
  
  {{$fcs := $.FileLevelComments}}
  {{$acs := $.AreaComments}}
  <div class="file-head-marks{{if index $.RowToggled "file"}} row-toggled{{end}}">
    
    {{if gt $.FileHeadAnnotationCount 0}}
    <button type="button" class="line-marks" lvt-on:click="toggleRow" data-row="file" lvt-el:toggleClass:on:click="row-toggled" data-lvt-target="closest:.file-head-marks" aria-label="Show or hide this file's annotations" title="Show/hide this file's annotations"><span class="line-mark{{if $.FileHeadHasOpen}} is-open{{else}} is-done{{end}}" aria-hidden="true">{{$.FileHeadAnnotationCount}}</span></button>
    {{end}}
    <div class="file-head-cards">
      {{range $.FileQuizItems}}{{template "quizCard" .}}{{end}}
  
  {{if or $fcs $acs (eq $.CommentMode "area")}}
  <section class="file-comments" data-key="file-comments-{{.Path}}">
    {{range $fcs}}{{template "commentCardSimple" .}}{{end}}
    {{range $acs}}{{template "commentCardSimple" .}}{{end}}
    {{if eq $.CommentMode "area"}}{{template "composer" $}}{{end}}
  </section>
  {{end}}
    </div>
  </div>
  
  {{if eq $.CommentMode "file"}}
  <div class="fc-modal-backdrop" data-key="fc-modal-backdrop" lvt-on:click="clearSelection" aria-hidden="true"></div>
  <div class="fc-modal" data-key="fc-modal" role="dialog" aria-modal="true" aria-label="Comment on file">
    {{template "composer" $}}
  </div>
  {{end}}
  {{if .IsBinary}}
{{template "binaryView" $}}
  {{else}}{{if $.ShowRenderedHTML}}
{{template "htmlView" $}}
  {{else}}{{if $.ShowRenderedMarkdown}}
{{template "markdownView" $}}
  {{else}}{{if .Lines}}
{{template "diffView" $}}
  {{else}}
  <p class="empty"><small>No diff content.</small></p>
  {{end}}{{end}}{{end}}{{end}}
</article>
{{else}}
  {{if .Files}}
  <p class="empty">Pick a file from the list.</p>
  {{else}}
  <div class="empty empty-diff">
    <h3>No files in this repository</h3>
    <p><small>Add some files and refresh, or relaunch prereview pointed at a different repo.</small></p>
  </div>
  {{end}}
{{end}}
{{end}}{{end}}

{{template "viewerPrompts" $}}
</main>


{{template "tocSidebar" $}}
</div>

{{template "tocOverlay" $}}

{{template "kbdHelp" $}}

{{if not .ExternalMode}}
{{template "searchPalette" $}}
{{end}}
<footer class="app-footer" role="contentinfo">
  prereview{{if ne .Version "dev"}} v{{.Version}}{{end}} · built with <a href="https://github.com/livetemplate/livetemplate" target="_blank" rel="noopener noreferrer">livetemplate</a>
</footer>
{{end}}


{{if .AgentMode}}{{template "endSessionDialog" .}}{{end}}
{{if not .AgentMode}}{{template "quitDialog" .}}{{end}}

</div>
<script defer src="/livetemplate-client.js"></script>

<script defer src="/mermaid-init.js"></script>
</body>
</html>










































=== quitDialog ===
<dialog id="confirm-quit"><article><header><strong>Quit prereview?</strong></header><p><small>Stops the prereview server and closes the review. Saved comments are already written to the CSV; this can't be undone from the browser.</small></p><footer>
    <form method="POST">
      <fieldset role="group">
        <button type="button" command="close" commandfor="confirm-quit" class="secondary">Cancel</button>
        <button type="submit" name="quit" class="contrast">Quit</button>
      </fieldset>
    </form>
  </footer></article></dialog>
=== quizCard ===
<div class="quiz-card{{if .Answered}} is-answered{{end}}" data-key="quiz-{{.ID}}">
  
  <div class="quiz-card-head"{{if .ScrollTo}} lvt-fx:scroll="into-view" tabindex="-1"{{end}}>
    <span class="quiz-probe quiz-probe-{{.Probe}}">{{.Probe}}</span>{{if .Ungrounded}}<span class="quiz-ungrounded" title="This question cites {{.AnchorLabel}}, which is not in this diff — treat it with suspicion">⚠ cites {{.AnchorLabel}}, not in this diff</span>{{end}}
  </div>
  <p class="quiz-prompt">{{.Prompt}}</p>
  <ul class="quiz-options">
    {{$item := .}}
    {{range $i, $opt := .Options}}
    <li>
      {{if $item.Answered}}
      <div class="quiz-option{{if eq $i $item.Answer}} is-correct{{end}}{{if and (eq $i $item.Choice) (ne $i $item.Answer)}} is-wrong{{end}}"><span class="quiz-mark">{{if eq $i $item.Answer}}✓{{else}}{{if eq $i $item.Choice}}✗{{else}} {{end}}{{end}}</span>{{$opt}}</div>
      {{else}}
      <form method="POST" style="margin:0"><input type="hidden" name="quizId" value="{{$item.QuizID}}"><input type="hidden" name="questionId" value="{{$item.ID}}"><input type="hidden" name="choice" value="{{$i}}"><button type="submit" name="answerQuestion" class="quiz-option quiz-option-btn">{{$opt}}</button></form>
      {{end}}
    </li>
    {{end}}
  </ul>
  {{if .Answered}}<p class="quiz-why{{if .Correct}} is-correct{{else}} is-wrong{{end}}"><small>{{.Why}}</small></p>{{end}}{{template "thread" .Thread}}{{if .Replying}}
  <form method="POST" class="reply-form" lvt-on:keydown="postReply" lvt-key="Mod+Enter">
    <input type="hidden" name="id" value="{{.ThreadID}}">
    <textarea name="body" placeholder="Ask the agent to clarify or revise this question…" lvt-on:input="saveReplyDraft" lvt-mod:debounce="200" lvt-autofocus>{{.ReplyDraft}}</textarea>
    <div class="reply-actions">
      <button type="submit" name="cancelReply" class="secondary outline">Cancel</button>
      <button type="submit" name="postReply">Send reply</button>
    </div>
  </form>
  {{else}}
  <form method="POST" class="quiz-card-actions"><input type="hidden" name="id" value="{{.ThreadID}}"><button type="submit" name="openReply" class="outline quiz-reply-btn">Reply</button></form>
  {{end}}
</div>

=== quizView ===
<section class="quiz">
  <header class="quiz-head">
    <strong>Comprehension quiz{{with $.QuizScoreLabel}} <span class="quiz-score">{{.}}</span>{{end}}</strong>
    <form method="POST" style="margin:0">
      <button type="submit" name="toggleQuiz" class="outline contrast" title="Return to the file you were viewing">Back</button>
    </form>
  </header>
  {{if $.HasQuiz}}
  <p class="quiz-sub"><small>on <code>{{$.SelectedFile}}</code> — every question also sits inline next to the code it asks about; this is the overview</small></p>
  <ol class="quiz-list">
    {{range $.QuizItems}}
    <li class="quiz-q{{if .Answered}} is-answered{{end}}" data-key="{{.ID}}">
      <div class="quiz-q-head">
        <span class="quiz-probe quiz-probe-{{.Probe}}">{{.Probe}}</span>
        {{if .Jumpable}}
        <form method="POST" style="margin:0">
          <input type="hidden" name="line" value="{{.FromLine}}">
          <input type="hidden" name="side" value="{{.Side}}">
          <button type="submit" name="jumpToQuizLine" class="quiz-jump" title="Go read the code this asks about">{{.AnchorLabel}}</button>
        </form>
        {{else}}{{if .Ungrounded}}
        <span class="quiz-ungrounded" title="The quiz cited {{.AnchorLabel}}, but that line is not in this diff — treat the question with suspicion">⚠ cited {{.AnchorLabel}}, not in this diff</span>
        {{else}}
        <span class="quiz-absent" title="This question is about something the change does NOT contain, so there is no line to jump to">about something absent</span>
        {{end}}{{end}}
      </div>
      <p class="quiz-prompt">{{.Prompt}}</p>
      <ul class="quiz-options">
        {{$item := .}}
        {{range $i, $opt := .Options}}
        <li>
          {{if $item.Answered}}
          <div class="quiz-option{{if eq $i $item.Answer}} is-correct{{end}}{{if and (eq $i $item.Choice) (ne $i $item.Answer)}} is-wrong{{end}}">
            <span class="quiz-mark">{{if eq $i $item.Answer}}✓{{else}}{{if eq $i $item.Choice}}✗{{else}} {{end}}{{end}}</span>{{$opt}}
          </div>
          {{else}}
          <form method="POST" style="margin:0">
            <input type="hidden" name="quizId" value="{{$.CurrentQuiz.ID}}">
            <input type="hidden" name="questionId" value="{{$item.ID}}">
            <input type="hidden" name="choice" value="{{$i}}">
            <button type="submit" name="answerQuestion" class="quiz-option quiz-option-btn">{{$opt}}</button>
          </form>
          {{end}}
        </li>
        {{end}}
      </ul>
      {{if .Answered}}
      <p class="quiz-why{{if .Correct}} is-correct{{else}} is-wrong{{end}}"><small>{{.Why}}</small></p>
      {{end}}
    </li>
    {{end}}
  </ol>
  <footer class="quiz-foot">
    {{if $.QuizComplete}}<p class="quiz-done"><strong>{{$.QuizScoreLabel}}</strong> — every question answered.</p>{{end}}
    {{if gt $.QuizAnsweredCount 0}}
    <form method="POST" style="margin:0">
      <button type="submit" name="retakeQuiz" class="outline" title="Clear your answers and take it again">Retake</button>
    </form>
    {{end}}
  </footer>
  {{else}}
  <div class="empty quiz-empty">
    <p>No quiz for this file yet.</p>
    <p><small>Use <strong>Quiz me</strong> in the file header to ask the agent for one.</small></p>
    <form method="POST">
      <button type="submit" name="toggleQuiz" class="outline contrast">Back to the file</button>
    </form>
  </div>
  {{end}}
</section>

=== regionToggle ===
<form method="POST" class="region-toggle">
  <button type="submit" name="toggleRegionSelect" class="{{if $.RegionSelectArmed}}contrast{{else}}outline secondary{{end}}" aria-pressed="{{if $.RegionSelectArmed}}true{{else}}false{{end}}">{{if $.RegionSelectArmed}}Selecting region — tap to cancel{{else}}▭ Select a region to comment{{end}}</button>
</form>
=== searchPalette ===
<div class="search-backdrop{{if .SearchOpen}} is-open{{end}}" lvt-on:click="closeSearch" aria-hidden="true"></div>
<div class="search-modal{{if .SearchOpen}} is-open{{end}}" role="dialog" aria-label="Search files" aria-modal="true">
  {{if .SearchOpen}}
  <div class="search-head">
    <span class="search-head-icon">{{template "iconSearch"}}</span>
    <form method="POST" lvt-form:preserve class="search-input-form">
      <input type="text" name="q" value="{{.SearchQuery}}" placeholder="Search file names & contents…" lvt-autofocus lvt-on:input="setSearchQuery" lvt-mod:debounce="200" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" enterkeyhint="search">
    </form>
    <form method="POST">
      <button type="submit" name="toggleSearchScope" class="search-scope outline" title="Toggle search scope (changed files vs all files)">{{.SearchScopeLabel}} <span class="search-scope-count">{{.SearchScopeCount}}</span></button>
    </form>
    <form method="POST">
      <button type="submit" name="closeSearch" class="outline close-btn" aria-label="Close">{{template "iconClose16"}}</button>
    </form>
  </div>
  <div class="search-body">
    {{if .SearchHits}}
    <ul class="search-list">{{range .SearchHits}}
      <li class="search-item{{if eq .Kind "file"}} is-file{{end}}">
        <form method="POST">
          <input type="hidden" name="file" value="{{.File}}">
          <input type="hidden" name="old" value="{{.OldNum}}">
          <input type="hidden" name="new" value="{{.NewNum}}">
          <button type="submit" name="jumpToSearchResult" class="search-hit">
            <span class="search-where"><code>{{.File}}</code>{{if eq .Kind "line"}} <small>L{{.NewNum}}</small>{{else}} <small class="search-filematch">file name</small>{{end}}</span>{{if eq .Kind "line"}}<span class="search-line">{{.Line}}</span>{{end}}</button>
        </form>
      </li>{{end}}
    </ul>
    {{if .SearchTruncated}}<p class="search-note">Showing the first {{len .SearchHits}} matches — narrow your search.</p>{{end}}
    {{else}}{{if .SearchQuery}}
    <p class="search-empty">No matches for “{{.SearchQuery}}”.</p>
    {{else}}
    <p class="search-empty">Type to search file names and contents.</p>
    {{end}}{{end}}
  </div>
  {{end}}
</div>
=== statusBanners ===
{{if .Quitting}}
<div class="banner-stopping" role="status">
  Server stopping… you can close this tab.
</div>
{{end}}

{{if .SessionEnded}}
<div class="banner-stopping" role="status">
  Session ended — Claude has been notified. You can close this tab.
</div>
{{end}}

{{if .Flash}}
<div class="toast flash-toast" role="status" lvt-fx:auto-click="3000:clearFlash">
  <span class="toast-msg">{{.Flash}}</span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="clearFlash" class="toast-dismiss" aria-label="Dismiss">
      {{template "iconClose14"}}
    </button>
  </form>
</div>
{{end}}
{{if and .AgentMode (eq .LLMState "working")}}
<div class="toast llm-working" role="status" aria-live="polite">
  <span class="llm-spinner" aria-hidden="true"></span>
  <span class="toast-msg">{{.AgentWorkingLabel}}</span>
</div>
{{end}}
=== suggestionCard ===
{{$d := index $.DecisionsBySuggestion .ID}}{{$applied := index $.Applied .ID}}{{$g := index $.SuggestionGroups .ID}}<div class="inline-suggestion{{if .AnchorOutdated}} is-outdated{{end}}{{if $g.Total}} is-grouped{{end}}{{if $d.Verdict}} is-decided sg-{{$d.Verdict}}{{end}}{{if $applied}} is-applied{{end}}" data-key="sg-{{.ID}}" lvt-fx:animate="fade"><header><span class="sg-label">{{template "iconSuggestion"}} suggestion</span>{{if $g.Total}} <small class="sg-group-tag" title="{{$g.Total}} alternatives for this text — accepting one auto-rejects the rest">alternative {{$g.Index}} of {{$g.Total}}</small>{{end}} · <small>{{.LineSpan}}</small>{{if .AnchorMoved}} · <small class="moved-badge">moved</small>{{end}}{{if and .AnchorOutdated (not $applied)}} · <small class="outdated-badge">outdated</small>{{end}}{{if eq $d.Verdict "accept"}} · <small class="sg-verdict-badge sg-accept">{{if $applied}}applied{{else}}accepted{{end}}</small>{{end}}{{if eq $d.Verdict "reject"}} · <small class="sg-verdict-badge sg-reject" title="{{if $d.Auto}}not chosen — you accepted another alternative for this text{{else}}rejected by you{{end}}">{{if $d.Auto}}not chosen{{else}}rejected{{end}}</small>{{end}}{{if index $.AwaitingAgent .ID}} · <small class="awaiting-badge" title="you replied — waiting on the agent">awaiting agent</small>{{end}}<span class="sg-hide-actions">{{if $g.Total}}<form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="hideSuggestionGroup" class="sg-hide-btn" title="Hide all {{$g.Total}} alternatives for this text">Hide all</button></form>{{end}}<form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="hideSuggestion" class="sg-hide-btn" title="Hide this suggestion from view">Hide</button></form>
    </span>
  </header>{{if .Note}}<div class="sg-note">{{.Note}}</div>{{end}}<div class="sg-diff">{{if .OriginalText}}<pre class="sg-old">{{.OriginalText}}</pre>{{end}}<pre class="sg-new">{{.ProposedText}}</pre>
  </div>{{if and .AnchorOutdated (not $applied)}}<details class="anchor-orig"><summary>⚠ the document changed here — the original text is gone</summary><pre>{{.OriginalText}}</pre></details>{{end}}{{template "thread" (index $.Threads .ID)}}{{if eq $.ReplyingID .ID}}<form method="POST" class="reply-form" lvt-on:keydown="postReply" lvt-key="Mod+Enter">
    <input type="hidden" name="id" value="{{.ID}}">
    <textarea name="body" placeholder="Reply to the agent…" lvt-on:input="saveReplyDraft" lvt-mod:debounce="200" lvt-autofocus>{{$.ReplyDraft}}</textarea>
    <div class="reply-actions">
      <button type="submit" name="cancelReply" class="secondary outline">Cancel</button>
      <button type="submit" name="postReply">Send reply</button>
    </div>
  </form>{{else}}<div class="sg-reply-open"><form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="openReply" class="outline">Reply</button></form></div>{{end}}{{if $applied}}{{if $d.Revert}}<div class="sg-actions"><small class="sg-applied-status sg-reverting">Reverting — the agent will restore the original text.</small></div>{{else}}<div class="sg-actions">
    <small class="sg-applied-status">Edit applied to the file.</small>
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="requestRevert" class="outline sg-revert-btn">Revert</button></form>
  </div>{{end}}{{else}}{{if not .AnchorOutdated}}{{if $d.Verdict}}<div class="sg-actions">
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="clearSuggestionDecision" class="outline">Undo</button></form>
  </div>{{else}}<div class="sg-actions">
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="acceptSuggestion" class="outline sg-accept-btn">Accept</button></form>
    <form method="POST"><input type="hidden" name="id" value="{{.ID}}"><button type="submit" name="rejectSuggestion" class="outline sg-reject-btn">Reject</button></form>
  </div>{{end}}{{end}}{{end}}</div>
=== thread ===
{{if .}}<div class="thread">{{range .}}<div class="thread-entry thread-{{.Author}}">
    <div class="thread-meta"><span class="thread-author">{{.Author}}</span>{{if .When}} · <small class="thread-when">{{.When}}</small>{{end}}</div>
    <div class="thread-body">{{.Body}}</div>
  </div>{{end}}</div>{{end}}
=== tocOverlay ===
{{with .RenderedHeadings}}
<div class="toc-backdrop{{if $.TOCOpen}} is-open{{end}}" lvt-on:click="closeTOC" aria-hidden="true"></div>
<div class="toc-modal{{if $.TOCOpen}} is-open{{end}}" role="dialog" aria-label="Table of contents" aria-modal="true">
  <div class="toc-modal-head">
    <strong>On this page</strong>
    <form method="POST">
      <button type="submit" name="closeTOC" class="outline close-btn" aria-label="Close">
        {{template "iconClose16"}}
      </button>
    </form>
  </div>
  <nav class="toc-modal-list">
    {{range .}}<a href="#{{.ID}}" lvt-spy-link lvt-on:click="navigateToHeading" data-id="{{.ID}}" class="toc-link toc-l{{.Level}}">{{.Text}}</a>
    {{end}}
  </nav>
</div>
{{end}}
=== tocSidebar ===
{{with .RenderedHeadings}}
<aside class="toc-sidebar" aria-label="Table of contents">
  
  <div class="toc-head">
    <form method="POST">
      <button type="submit" name="toggleTOC" class="collapse-toggle" aria-label="{{if $.TocCollapsed}}Show contents{{else}}Hide contents{{end}}" aria-expanded="{{if $.TocCollapsed}}false{{else}}true{{end}}" title="{{if $.TocCollapsed}}Show contents{{else}}Hide contents{{end}}{{with index $.KeyHint "toggleTOC"}} ({{.}}){{end}}">{{if $.TocCollapsed}}{{template "iconChevronLeft"}}{{else}}{{template "iconChevronRight"}}{{end}}</button>
    </form>
    <strong>On this page</strong>
  </div>
  <nav class="toc-list">
    {{range .}}<a href="#{{.ID}}" lvt-spy-link class="toc-link toc-l{{.Level}}">{{.Text}}</a>
    {{end}}
  </nav>
</aside>
{{end}}
=== toolbar ===
<header class="bar" lvt-fx:url-hash="setURLHash" data-lvt-url-hash="{{.URLHash}}">
  <form method="POST">
    <button type="submit" name="toggleFiles" class="hamburger outline contrast" aria-label="Toggle files">{{template "iconHamburger"}}</button>
  </form>
  
  {{if not .ExternalMode}}
  <form method="POST">
    <button type="submit" name="openSearch" class="search-btn outline contrast" aria-label="Search files" title="Search files (⌘/Ctrl + K)">{{template "iconSearch"}}</button>
  </form>
  {{end}}
  <div class="title">
    <span class="title-main">{{if .ShowAllComments}}{{else}}{{if .CurrentDiff}}<span class="title-file">{{.CurrentDiff.Path}}</span>{{else}}<small>Pick a file from {{len .Files}} file{{if ne (len .Files) 1}}s{{end}}</small>{{end}}{{end}}</span>
  </div>
  
  <div class="toolbar-inline">
    <div class="tb-group tb-counters">
      
      <small class="auto-saved-long">{{len .Files}} files{{if gt .ChangedFilesCount 0}} · {{.ChangedFilesCount}} changed{{end}} · {{.ScopeViewedCount}}/{{.ScopeFileCount}} viewed</small>
    </div>
    {{if .CurrentDiff}}
    <div class="tb-group tb-toggles">
      
      {{if .IsMarkdown}}
      <form method="POST" class="tb-radios" aria-label="Markdown view">
        <label><input type="radio" name="view" value="rendered" {{if not .RawMarkdown}}checked{{end}} lvt-on:change="setMarkdownView">Preview</label>
        <label><input type="radio" name="view" value="raw" {{if .RawMarkdown}}checked{{end}} lvt-on:change="setMarkdownView">Raw</label>
      </form>
      {{end}}
      {{if .IsHTML}}
      <form method="POST" class="tb-radios" aria-label="HTML view">
        <label><input type="radio" name="view" value="rendered" {{if not .RawHTML}}checked{{end}} lvt-on:change="setHTMLView">Preview</label>
        <label><input type="radio" name="view" value="raw" {{if .RawHTML}}checked{{end}} lvt-on:change="setHTMLView">Raw</label>
      </form>
      {{end}}
      
      {{if not .ShowRenderedHTML}}
      <form method="POST" class="tb-radios" aria-label="File view">
        <label><input type="radio" name="view" value="diff" {{if not .FileView}}checked{{end}} lvt-on:change="setFileViewMode">Diff</label>
        <label><input type="radio" name="view" value="file" {{if .FileView}}checked{{end}} lvt-on:change="setFileViewMode">File</label>
      </form>
      {{end}}
    </div>
    {{end}}
    
{{template "viewMenu" $}}
  </div>
  
  {{if gt (len .Files) 1}}
  <form method="POST" class="nav-prev">
    <button type="submit" name="prevFile" title="Previous file" aria-label="Previous file" class="contrast">{{template "iconChevronLeft"}}<span class="nav-label">Prev{{with index $.KeyHint "prevFile"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span></button>
  </form>
  <form method="POST" class="nav-next">
    <button type="submit" name="nextFile" title="Next file" aria-label="Next file" class="contrast"><span class="nav-label">Next{{with index $.KeyHint "nextFile"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>{{template "iconChevronRight"}}</button>
  </form>
  {{end}}
  
  {{if .AgentMode}}
{{template "workQueue" $}}
  {{else}}
  <form method="POST" class="tb-action">
    <button type="button" command="show-modal" commandfor="confirm-quit" class="contrast" title="Stop the prereview server">Quit</button>
  </form>
  {{end}}
  
  <form method="POST" style="margin:0">
    <button type="submit" name="toggleMoreMenu" class="more-trigger" aria-label="More options" aria-haspopup="menu" aria-expanded="{{if .MoreMenuOpen}}true{{else}}false{{end}}">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <circle cx="12" cy="5" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="12" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="19" r="1.8" fill="currentColor"/>
      </svg>
    </button>
  </form>
</header>
=== versionSummary ===
{{if .Initial}}<span class="vs-note">Initial version — the starting point.</span>{{else}}{{if .Deleted}}<span class="vs-note">File removed at this version.</span>{{else}}{{if .Binary}}<span class="vs-note">Binary file changed.</span>{{else}}<span class="vs-stat"><span class="vs-add">+{{.Added}}</span> <span class="vs-rem">−{{.Removed}}</span></span>{{end}}{{end}}{{end}}
=== viewMenu ===
    <div class="tb-dropdown" lvt-el:toggleClass:on:click="open" lvt-el:removeClass:on:click-away="open">
      <button type="button" class="contrast theme-toggle tb-dropdown-trigger" aria-haspopup="menu" title="View options — focus, color scheme &amp; mode, comment filters, help"><span class="tb-label">View</span>{{template "iconChevronDown"}}</button>
      <div class="tb-dropdown-panel" role="menu" aria-label="View options">
        {{if .CurrentDiff}}
        
        <form method="POST">
          <button type="submit" name="toggleFocusMode" class="menu-item{{if .FocusMode}} is-on{{end}}" role="menuitem">
            <span class="menu-icon">{{template "iconFocus"}}</span>
            <span class="menu-label">{{if .FocusMode}}Exit focus{{else}}Focus{{end}}{{with index $.KeyHint "toggleFocusMode"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
          </button>
        </form>
        {{end}}
        
        <form method="POST">
          <button type="submit" name="cycleScheme" class="menu-item" role="menuitem">
            <span class="menu-icon">{{template "iconPalette"}}</span>
            <span class="menu-label">Scheme: {{.SchemeLabel}}</span>
            <span class="menu-meta">{{.NextSchemeLabel}} →</span>
          </button>
        </form>
        <form method="POST">
          <button type="submit" name="cycleTheme" class="menu-item" role="menuitem">
            <span class="menu-icon">{{if eq .ThemeMode "light"}}{{template "iconThemeLight"}}{{else}}{{if eq .ThemeMode "dark"}}{{template "iconThemeDark"}}{{else}}{{template "iconThemeSystem"}}{{end}}{{end}}</span>
            <span class="menu-label">Mode: {{.ThemeModeLabel}}</span>
            <span class="menu-meta">{{.NextThemeModeLabel}} →</span>
          </button>
        </form>
        
        {{if gt .CommentCount 0}}
        <form method="POST">
          <button type="submit" name="toggleCommentList" class="menu-item{{if .ShowAllComments}} is-on{{end}}" role="menuitem">
            <span class="menu-icon">{{template "iconComments"}}</span>
            <span class="menu-label">{{if .ShowAllComments}}Back{{else}}All comments{{end}}{{with index $.KeyHint "toggleCommentList"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
            <span class="menu-meta">{{.CommentCount}}</span>
          </button>
        </form>
        {{end}}
        
        {{if .HasQuiz}}
        <form method="POST">
          <button type="submit" name="toggleQuiz" class="menu-item{{if .ShowQuiz}} is-on{{end}}" role="menuitem">
            <span class="menu-icon">{{template "iconQuiz"}}</span>
            <span class="menu-label">{{if .ShowQuiz}}Back{{else}}Quiz{{end}}{{with index $.KeyHint "toggleQuiz"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
            <span class="menu-meta">{{.QuizScoreLabel}}</span>
          </button>
        </form>
        {{end}}
        
        {{if gt .ResolvedCount 0}}
        <form method="POST">
          <button type="submit" name="toggleShowResolved" class="menu-item{{if .ShowResolved}} is-on{{end}}" role="menuitem">
            <span class="menu-icon">{{if .ShowResolved}}{{template "iconCheck"}}{{else}}{{template "iconCircle16"}}{{end}}</span>
            <span class="menu-label">{{if .ShowResolved}}Hide resolved{{else}}Show resolved{{end}}{{with index $.KeyHint "toggleShowResolved"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
            <span class="menu-meta">{{.ResolvedCount}}</span>
          </button>
        </form>
        {{end}}
        
        {{if and .ShowResolved (gt .HiddenResolvedCount 0)}}
        <form method="POST">
          <button type="submit" name="unhideAllResolved" class="menu-item" role="menuitem">
            <span class="menu-icon">{{template "iconCircle16"}}</span>
            <span class="menu-label">Unhide</span>
            <span class="menu-meta">{{.HiddenResolvedCount}}</span>
          </button>
        </form>
        {{end}}
        
        {{if gt .SuggestionCount 0}}
        <form method="POST">
          <button type="submit" name="toggleSuggestions" class="menu-item{{if not .HideSuggestions}} is-on{{end}}" role="menuitem">
            <span class="menu-icon">{{template "iconSuggestion"}}</span>
            <span class="menu-label">{{if .HideSuggestions}}Show suggestions{{else}}Hide suggestions{{end}}{{with index $.KeyHint "toggleSuggestions"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
            <span class="menu-meta">{{.SuggestionCount}}</span>
          </button>
        </form>
        {{end}}
        
        {{if $.HasMarks}}
        <form method="POST">
          <button type="submit" name="toggleMarks" class="menu-item{{if not .HideMarks}} is-on{{end}}" role="menuitem">
            <span class="menu-icon">{{if .HideMarks}}{{template "iconCircle16"}}{{else}}{{template "iconCheck"}}{{end}}</span>
            <span class="menu-label">{{if .HideMarks}}Show annotations{{else}}Hide annotations{{end}}{{with index $.KeyHint "toggleMarks"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</span>
          </button>
        </form>
        {{end}}
        
        {{if gt .HiddenSuggestionCount 0}}
        <form method="POST">
          <button type="submit" name="showHiddenSuggestions" class="menu-item" role="menuitem">
            <span class="menu-icon">{{template "iconSuggestion"}}</span>
            <span class="menu-label">Show hidden suggestions</span>
            <span class="menu-meta">{{.HiddenSuggestionCount}}</span>
          </button>
        </form>
        {{end}}
        
        {{if gt .DecisionCount 0}}
        <div class="menu-info sg-decision-count">{{.DecisionCount}} suggestion decision{{if ne .DecisionCount 1}}s{{end}} recorded</div>
        {{end}}
        
        {{if and (gt .OutdatedCount 0) (not .ShowAllComments)}}
        <form method="POST">
          <button type="submit" name="toggleCommentList" class="menu-item" role="menuitem" title="{{.OutdatedCount}} comment{{if ne .OutdatedCount 1}}s{{end}} need re-anchoring — open the list to fix">
            <span class="menu-icon">{{template "iconWarning"}}</span>
            <span class="menu-label">Outdated</span>
            <span class="menu-meta">{{.OutdatedCount}}</span>
          </button>
        </form>
        {{end}}
        
        <form method="POST">
          <button type="submit" name="toggleKeyboardHelp" class="menu-item" role="menuitem">
            <span class="menu-icon" aria-hidden="true">?</span>
            <span class="menu-label">Keyboard shortcuts</span>
          </button>
        </form>
        
        <a class="menu-item" role="menuitem" href="/_usage" target="_blank" rel="noopener">
          <span class="menu-icon">{{template "iconBook"}}</span>
          <span class="menu-label">Usage guide</span>
        </a>
      </div>
    </div>
=== viewerPrompts ===
{{if and .LastDeletedComment (not .Quitting)}}
<div class="undo-toast" role="status">
  <span>Comment on <code>{{.LastDeletedComment.File}}</code> {{.LastDeletedComment.LineSpan}} deleted</span>
  <span class="toast-actions">
    <form method="POST" style="margin:0;display:inline">
      <button type="submit" name="undoDelete" class="undo-btn">Undo</button>
    </form>
    <form method="POST" class="toast-dismiss-form">
      <button type="submit" name="dismissUndo" class="toast-dismiss" aria-label="Dismiss">{{template "iconClose14"}}</button>
    </form>
  </span>
</div>
{{end}}

{{if and .ReanchorCommentID (eq .SelectionEndMax 0)}}
<div class="reanchor-prompt" role="status">
  <span>Re-anchoring — tap the line(s) this comment should attach to.</span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="clearSelection" class="toast-dismiss" aria-label="Cancel re-anchoring">{{template "iconClose14"}}</button>
  </form>
</div>
{{end}}
{{if .PendingRefresh}}

<div class="reanchor-prompt refresh-prompt" role="status">
  <span>The agent edited files on disk. This view still shows the earlier version — refresh to see the changes.</span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="refreshDiff" class="refresh-btn">Refresh diff</button>
  </form>
</div>
{{end}}
{{if .AgentPaused}}

<div class="reanchor-prompt paused-prompt" role="status">
  <span>⏸ Batching — comments are held, not sent to the agent yet.</span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="resumeAgent" class="refresh-btn">Resume — send batch</button>
  </form>
</div>
{{end}}
=== workQueue ===
  <div class="tb-dropdown queue-dropdown{{if .AgentPaused}} is-paused{{end}}" lvt-el:toggleClass:on:click="open" lvt-el:removeClass:on:click-away="open">
    <button type="button" id="queue-trigger-{{.EnqueueTick}}" class="contrast tb-dropdown-trigger queue-trigger{{if .AgentWorking}} is-working{{end}}{{if .AgentPaused}} is-paused{{end}}" aria-haspopup="menu" title="{{if .AgentPaused}}Batching — comments held, not sent. {{end}}Work queue: queued, worked-on, drafts; Pause/Resume + End session inside">{{if .AgentPaused}}<span class="queue-paused-dot" aria-hidden="true">⏸</span>{{end}}<span class="tb-label">Queue</span>{{if .AwaitingReplyCount}}<span class="q-num q-awaiting-reply" title="your replies still awaiting the agent (whole review)">{{.AwaitingReplyCount}}</span>{{end}}{{if .HasQueue}}<span class="queue-counts">{{if .AwaitingApplyCount}}<span class="q-num q-awaiting" title="accepted, not yet applied to the file">{{.AwaitingApplyCount}}</span> · {{end}}<span class="q-num q-queued">{{.QueuedCount}}</span>{{if .DoneCount}} · <span class="q-num q-done">{{.DoneCount}}</span>{{end}}{{if .DraftCount}} · <span class="q-num q-draft">{{.DraftCount}}</span>{{end}}</span>{{end}}{{template "iconChevronDown"}}</button>
    <div class="tb-dropdown-panel queue-panel" role="menu" aria-label="Work queue">
      
      <form method="POST" class="queue-pause-form">
        <button type="submit" name="toggleAgentPause" class="queue-pause-btn{{if .AgentPaused}} is-paused{{end}}">{{if .AgentPaused}}▶ Resume — send batch{{if .QueuedCount}} ({{.QueuedCount}}){{end}}{{else}}⏸ Pause — batch comments{{end}}{{with index $.KeyHint "toggleAgentPause"}} <kbd class="kbd-hint" aria-hidden="true">{{.}}</kbd>{{end}}</button>
      </form>
      <div class="queue-mode{{if .AgentPaused}} is-batching{{end}}">{{if .AgentPaused}}Batching: comments are held, not sent. Resume sends them together.{{else}}Live: each comment is sent to the agent as you save it.{{end}}</div>
      {{with .AgentWorkingLabel}}<div class="queue-working">⚡ {{.}}</div>{{end}}
      
      {{if not .SingleFile}}
      <form method="POST" class="queue-scope-form">
        <button type="submit" name="toggleQueueScope" class="queue-scope-btn" role="menuitemcheckbox" aria-checked="{{if .QueueGlobal}}true{{else}}false{{end}}" title="Show this file's work, or the whole review's">
          <span class="queue-scope-opt{{if not .QueueGlobal}} is-on{{end}}">This file</span><span class="queue-scope-opt{{if .QueueGlobal}} is-on{{end}}">All files</span>
        </button>
      </form>
      {{end}}
      
      {{if .AwaitingReplyCount}}<div class="queue-awaiting-reply"><span class="q-num q-awaiting-reply">{{.AwaitingReplyCount}}</span> repl{{if eq .AwaitingReplyCount 1}}y{{else}}ies{{end}} awaiting the agent (whole review)</div>{{end}}
      {{if .HasQueue}}
      <div class="queue-legend"><span class="q-num q-queued">{{.QueuedCount}}</span> queued · <span class="q-num q-done">{{.DoneCount}}</span> done{{if .DraftCount}} · <span class="q-num q-draft">{{.DraftCount}}</span> draft{{end}}{{if .QueueHiddenCount}} · <span class="q-num q-elsewhere">{{.QueueHiddenCount}}</span> on other files{{end}}</div>
      
      {{if .AwaitingApplyCount}}
      <div class="queue-awaiting"><span class="q-num q-awaiting">{{.AwaitingApplyCount}}</span> accepted, awaiting the agent to apply {{if eq .AwaitingApplyCount 1}}it{{else}}them{{end}} to the file</div>
      {{end}}
      {{range .QueueItems}}
      
      <div class="queue-row queue-{{.State}} queue-kind-{{.Kind}}">
        <form method="POST" class="queue-jump-form">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="{{if eq .Kind "suggestion"}}jumpToSuggestion{{else}}jumpToComment{{end}}" class="queue-item" title="Go to this {{.Kind}}">
            {{if eq .Kind "suggestion"}}<span class="queue-kind-icon" aria-hidden="true">✦</span>{{end}}
            <span class="queue-badge queue-badge-{{.State}}">{{.State}}</span>
            <span class="queue-body">{{.Body}}</span>
            <span class="queue-loc" title="{{.File}}{{if .Line}}:{{.Line}}{{end}}">{{.File}}{{if .Line}}:{{.Line}}{{end}}</span>
          </button>
        </form>{{if and (eq .State "done") (eq .Kind "comment")}}
        
        <form method="POST" class="queue-reenqueue-form">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="reenqueueComment" class="queue-reenqueue" title="Re-enqueue — ask the agent to redo this" aria-label="Re-enqueue">↺</button>
        </form>{{end}}
      </div>
      {{end}}
      {{else}}{{if .QueueHiddenCount}}
      
      <div class="queue-empty">Nothing queued on this file — <strong>{{.QueueHiddenCount}}</strong> item{{if ne .QueueHiddenCount 1}}s{{end}} on other files. Switch to <strong>All files</strong> to see {{if eq .QueueHiddenCount 1}}it{{else}}them{{end}}.</div>
      {{else}}
      <div class="queue-empty">Nothing queued yet — comments you add stream to the agent automatically.</div>
      {{end}}{{end}}
      
      <button type="button" command="show-modal" commandfor="confirm-end-session" class="queue-end-btn" role="menuitem">End session</button>
    </div>
  </div>
