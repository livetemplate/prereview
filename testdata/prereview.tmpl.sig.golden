=== prereview ===
<!DOCTYPE html>

<html lang="en" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>prereview · {{.RepoPath}}</title>
<link rel="stylesheet" href="/pico.min.css">
<link rel="stylesheet" href="/livetemplate.css">
<link rel="stylesheet" href="/syntax.css">
<link rel="stylesheet" href="/prereview.css">
</head>
<body data-lvt-loading-debounce-ms="200">

<div class="theme-root" data-scheme="{{.DataScheme}}"{{with .DataMode}} data-mode="{{.}}"{{end}}>

<span class="kbd-esc" hidden aria-hidden="true" lvt-on:window:keydown="clearSelection" lvt-key="Escape"></span>

{{if .ExternalMode}}

<header class="bar bar-external">
  <span class="ext-target">prereview · annotating <code>{{.TargetURL}}</code>{{if .CurrentURL}} <span class="ext-page">{{.CurrentURL}}</span>{{end}}</span>
  <span class="bar-actions"><form method="POST" style="margin:0">
      <button type="submit" name="toggleAnnotations" class="outline secondary anno-toggle" aria-pressed="{{if .AnnoDrawerOpen}}true{{else}}false{{end}}" title="Show/hide annotations">💬 {{len $.AllRegionComments}}</button>
    </form>{{if .StreamMode}}<form method="POST" style="margin:0">
      <button type="submit" name="handOff" class="contrast" title="Send the current annotations to your agent as a handoff event (session stays open)">Hand off →</button>
    </form><form method="POST" style="margin:0">
      <button type="button" command="show-modal" commandfor="confirm-end-session" class="contrast" title="Emit session_end and stop the server — your agent stops consuming the stream">End session</button>
    </form>{{else}}{{if .SkillMode}}<form method="POST" style="margin:0">
      <button type="submit" name="handOff" class="contrast" title="Stop the server and signal your agent to read the CSV">Hand off →</button>
    </form>{{else}}<form method="POST" style="margin:0">
      <button type="button" command="show-modal" commandfor="confirm-quit" class="contrast" title="Stop the prereview server">Quit</button>
    </form>{{end}}{{end}}</span>
</header>
<div class="layout layout-external">
  <main class="viewer ext-viewer">
    {{template "regionToggle" $}}
    <div class="preview-stage ext-stage" lvt-fx:proxy-bridge="setProxyURL" data-key="ext-stage"{{with $.FocusedComment}} data-focus-token="{{$.FocusSeq}}" data-focus-url="{{.URL}}" data-focus-y="{{.Area.Y}}"{{end}}>
      
      <iframe class="ext-frame" src="{{.ProxyBaseURL}}" title="Live preview of {{.TargetURL}}" lvt-ignore></iframe>
      <div class="pin-layer" data-pin-layer data-key="pin-layer">{{range $.RegionComments}}<button type="button" class="area-overlay pin-btn{{if .Resolved}} is-resolved{{end}}{{if eq $.FocusedCommentID .ID}} is-focused{{end}}" lvt-on:click="editComment" data-id="{{.ID}}" data-key="pin-{{.ID}}" style="left:{{.Area.PercentX}};top:{{.Area.PercentY}};width:{{.Area.PercentW}};height:{{.Area.PercentH}};" title="{{.Body}}" aria-label="Edit annotation"></button>{{end}}{{if eq $.CommentMode "region"}}<div class="area-overlay area-overlay-pending" data-key="pin-pending" style="left:{{$.SelectionArea.PercentX}};top:{{$.SelectionArea.PercentY}};width:{{$.SelectionArea.PercentW}};height:{{$.SelectionArea.PercentH}};"></div>{{end}}</div>
      {{if .RegionSelectArmed}}<div class="region-overlay" lvt-fx:region-select="selectRegion" data-surface="page" data-key="ext-region-overlay"></div>{{end}}
    </div>
    {{if eq $.CommentMode "region"}}{{template "composer" $}}{{end}}
  </main>
  <aside class="ext-sidebar{{if .AnnoDrawerOpen}} is-open{{end}}" aria-label="Annotations">
    <header class="ext-sidebar-head"><strong>Annotations ({{len $.AllRegionComments}})</strong><form method="POST" style="margin:0">
        <button type="submit" name="toggleAnnotations" class="outline secondary close-btn" aria-label="Close annotations">{{template "iconClose16"}}</button>
      </form></header>
    <div class="ext-sidebar-body">{{range $.AllRegionComments}}<div class="inline-comment ext-anno{{if .Resolved}} is-resolved{{end}}{{if eq $.FocusedCommentID .ID}} is-focused{{end}}" data-key="{{.ID}}" lvt-fx:animate="fade"><form method="POST" class="anno-locate-form">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="focusComment" class="anno-locate" title="Locate this region on the page"><span class="ext-page-link">📍 {{.URL}}</span>{{if .Resolved}} · <small class="resolved-badge">resolved</small>{{end}}<span class="anno-body">{{.Body}}</span></button>
        </form><div class="ic-actions">
    <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="toggleResolved" class="outline">{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>{{if not .Resolved}}<form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="editComment" class="outline">Edit</button>
    </form>{{end}}<button type="button" class="secondary outline" command="show-modal" commandfor="confirm-delete-{{.ID}}">Delete</button>{{template "deleteDialogTagged" .}}</div></div>{{else}}<p class="empty"><small>No annotations yet — tap “Select a region”, then drag a box on the page.</small></p>{{end}}</div>
  </aside>
</div>
<footer class="app-footer" role="contentinfo"><small>prereview{{if ne .Version "dev"}} v{{.Version}}{{end}} · external mode · <code>{{.TargetURL}}</code></small></footer>
{{else}}

<div class="kbd-bindings" hidden aria-hidden="true">{{range .KeyBindings}}{{$b := .}}{{range $b.Keys}}{{if $b.Action}}<span lvt-on:window:keydown="{{$b.Action}}" lvt-key="{{.}}" lvt-mod:skip-when-typing></span>{{end}}{{end}}{{end}}</div>
<header class="bar{{if .FileDrawerOpen}} files-collapsed{{end}}" lvt-fx:url-hash="setURLHash" data-lvt-url-hash="{{.URLHash}}">
  <form method="POST">
    <button type="submit" name="toggleFiles" class="hamburger outline contrast" aria-label="Toggle files">{{template "iconHamburger"}}</button>
  </form>
  <div class="title">
    <span class="title-main">{{if .ShowAllComments}}{{else}}{{if .CurrentDiff}}<span class="title-file">{{.CurrentDiff.Path}}</span>{{else}}<small>Pick a file from {{len .Files}} file{{if ne (len .Files) 1}}s{{end}}</small>{{end}}{{end}}</span>
  </div>
  
  <div class="toolbar-inline">
    <div class="tb-group tb-counters">
      <small class="auto-saved-long">{{len .Files}} files{{if gt .ChangedFilesCount 0}} · {{.ChangedFilesCount}} changed{{end}} · {{.ScopeViewedCount}}/{{.ScopeFileCount}} viewed</small>
      
      {{if gt .ResolvedCount 0}}
      <form method="POST">
        <label class="tb-checkbox" title="Include resolved comments in the view"><input type="checkbox" {{if .ShowResolved}}checked{{end}} lvt-on:change="toggleShowResolved">Show resolved comments ({{.ResolvedCount}})</label>
      </form>
      {{end}}
      {{if and (gt .OutdatedCount 0) (not .ShowAllComments)}}
      <form method="POST">
        <button type="submit" name="toggleCommentList" class="contrast" title="{{.OutdatedCount}} comment{{if ne .OutdatedCount 1}}s{{end}} need re-anchoring — open the list to fix">⚠ {{.OutdatedCount}} outdated</button>
      </form>
      {{end}}
    </div>
    {{if .CurrentDiff}}
    <div class="tb-group tb-toggles">
      
      {{if .IsMarkdown}}
      <form method="POST" class="tb-radios" aria-label="Markdown view">
        <label><input type="radio" name="view" value="rendered" {{if not .RawMarkdown}}checked{{end}} lvt-on:change="setMarkdownView">Preview</label>
        <label><input type="radio" name="view" value="raw" {{if .RawMarkdown}}checked{{end}} lvt-on:change="setMarkdownView">Raw</label>
      </form>
      {{end}}
      {{if .IsHTML}}
      <form method="POST" class="tb-radios" aria-label="HTML view">
        <label><input type="radio" name="view" value="rendered" {{if not .RawHTML}}checked{{end}} lvt-on:change="setHTMLView">Preview</label>
        <label><input type="radio" name="view" value="raw" {{if .RawHTML}}checked{{end}} lvt-on:change="setHTMLView">Raw</label>
      </form>
      {{end}}
      {{if and (not .ShowRenderedMarkdown) (not .ShowRenderedHTML)}}
      <form method="POST" class="tb-radios" aria-label="File view">
        <label><input type="radio" name="view" value="diff" {{if not .FileView}}checked{{end}} lvt-on:change="setFileViewMode">Diff</label>
        <label><input type="radio" name="view" value="file" {{if .FileView}}checked{{end}} lvt-on:change="setFileViewMode">File</label>
      </form>
      {{end}}
    </div>
    {{end}}
    
    {{if .CurrentDiff}}
    <div class="tb-group tb-focus">
      <form method="POST">
        <button type="submit" name="toggleFocusMode" class="contrast focus-toggle" aria-pressed="{{if .FocusMode}}true{{else}}false{{end}}" title="{{if .FocusMode}}Show the file list and outline columns{{else}}Hide the side columns for distraction-free reading{{end}}">{{if .FocusMode}}Exit focus{{else}}Focus{{end}}</button>
      </form>
    </div>
    {{end}}
    
    <div class="tb-group tb-theme">
      <form method="POST">
        <button type="submit" name="cycleScheme" class="contrast theme-toggle" title="Color scheme: {{.SchemeLabel}} — switch to {{.NextSchemeLabel}}" aria-label="Color scheme: {{.SchemeLabel}}. Switch to {{.NextSchemeLabel}}.">{{template "iconPalette"}}<span class="tb-label">{{.SchemeLabel}}</span></button>
      </form>
      <form method="POST">
        <button type="submit" name="cycleTheme" class="contrast theme-toggle" title="Color mode: {{.ThemeModeLabel}} — switch to {{.NextThemeModeLabel}}" aria-label="Color mode: {{.ThemeModeLabel}}. Switch to {{.NextThemeModeLabel}}.">{{if eq .ThemeMode "light"}}{{template "iconThemeLight"}}{{else}}{{if eq .ThemeMode "dark"}}{{template "iconThemeDark"}}{{else}}{{template "iconThemeSystem"}}{{end}}{{end}}<span class="tb-label">{{.ThemeModeLabel}}</span></button>
      </form>
    </div>
    
    <div class="tb-group tb-help">
      <form method="POST">
        <button type="submit" name="toggleKeyboardHelp" class="contrast kbd-help-btn" aria-pressed="{{if .KeyHelpOpen}}true{{else}}false{{end}}" title="Keyboard shortcuts (press ?)" aria-label="Keyboard shortcuts"><span class="kbd-help-glyph" aria-hidden="true">?</span><span class="tb-label">Help</span></button>
      </form>
    </div>
  </div>
  {{if .CurrentDiff}}
  
  {{if ne .CommentMode "file"}}
  <form method="POST" class="tb-action">
    <button type="submit" name="openFileComment" class="contrast" title="Add a comment about the whole file" aria-label="Comment on file">
      {{template "iconChat14"}}
      <span class="nav-label">Comment on file</span>
    </button>
  </form>
  {{end}}
  {{end}}
  {{if gt (len .Files) 1}}
  <form method="POST" class="nav-prev">
    <button type="submit" name="prevFile" title="Previous file" aria-label="Previous file" class="contrast">{{template "iconChevronLeft"}}<span class="nav-label">Prev</span></button>
  </form>
  <form method="POST" class="nav-next">
    <button type="submit" name="nextFile" title="Next file" aria-label="Next file" class="contrast"><span class="nav-label">Next</span>{{template "iconChevronRight"}}</button>
  </form>
  {{end}}
  <form method="POST" class="tb-action">
    {{if .StreamMode}}
    <button type="submit" name="handOff" class="contrast" title="Send the current comments to your agent as a handoff event (session stays open)">Hand off →</button>
    
    <button type="button" command="show-modal" commandfor="confirm-end-session" class="contrast end-session-inline" title="Emit session_end and stop the server — your agent stops consuming the stream">End session</button>
    {{else}}{{if .SkillMode}}
    <button type="submit" name="handOff" class="contrast" title="Stop the server and signal your agent to read the CSV">Hand off →</button>
    {{else}}
    <button type="button" command="show-modal" commandfor="confirm-quit" class="contrast" title="Stop the prereview server">Quit</button>
    {{end}}{{end}}
  </form>
  
  <form method="POST" style="margin:0">
    <button type="submit" name="toggleMoreMenu" class="more-trigger" aria-label="More options" aria-haspopup="menu" aria-expanded="{{if .MoreMenuOpen}}true{{else}}false{{end}}">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <circle cx="12" cy="5" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="12" r="1.8" fill="currentColor"/>
        <circle cx="12" cy="19" r="1.8" fill="currentColor"/>
      </svg>
    </button>
  </form>
</header>


<div class="more-menu-backdrop{{if .MoreMenuOpen}} is-open{{end}}" lvt-on:click="closeMoreMenu" aria-hidden="true"></div>
<div class="more-menu{{if .MoreMenuOpen}} is-open{{end}}" role="menu" aria-label="More options">
  <div class="menu-info">{{len .Files}} files{{if gt .ChangedFilesCount 0}} · {{.ChangedFilesCount}} changed{{end}} · {{.ScopeViewedCount}}/{{.ScopeFileCount}} viewed{{if gt (len .Comments) 0}} · {{len .Comments}} comment{{if ne (len .Comments) 1}}s{{end}}{{end}}</div>
  
  <form method="POST">
    <button type="submit" name="cycleScheme" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconPalette"}}</span>
      <span class="menu-label">Scheme: {{.SchemeLabel}}</span>
      <span class="menu-meta">{{.NextSchemeLabel}} →</span>
    </button>
  </form>
  <form method="POST">
    <button type="submit" name="cycleTheme" class="menu-item" role="menuitem">
      <span class="menu-icon">{{if eq .ThemeMode "light"}}{{template "iconThemeLight"}}{{else}}{{if eq .ThemeMode "dark"}}{{template "iconThemeDark"}}{{else}}{{template "iconThemeSystem"}}{{end}}{{end}}</span>
      <span class="menu-label">Mode: {{.ThemeModeLabel}}</span>
      <span class="menu-meta">{{.NextThemeModeLabel}} →</span>
    </button>
  </form>
  {{if .CurrentDiff}}
  {{if ne .CommentMode "file"}}
  
  <form method="POST">
    <button type="submit" name="openFileComment" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconChat16"}}</span>
      <span class="menu-label">Comment on file</span>
    </button>
  </form>
  {{end}}
  {{with .RenderedHeadings}}
  
  <form method="POST">
    <button type="submit" name="openTOC" class="menu-item toc-menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconTOC"}}</span>
      <span class="menu-label">Table of contents</span>
      <span class="menu-meta">{{len .}}</span>
    </button>
  </form>
  {{end}}
  {{if .IsMarkdown}}
  <form method="POST">
    <button type="submit" name="toggleRawMarkdown" class="menu-item{{if not .RawMarkdown}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .RawMarkdown}}
        {{template "iconRendered"}}
        {{else}}
        {{template "iconViewRaw"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .RawMarkdown}}Preview{{else}}View raw source{{end}}</span>
    </button>
  </form>
  {{end}}
  {{if .IsHTML}}
  <form method="POST">
    <button type="submit" name="toggleRawHTML" class="menu-item{{if not .RawHTML}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .RawHTML}}
        {{template "iconRendered"}}
        {{else}}
        {{template "iconViewRaw"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .RawHTML}}Preview{{else}}View raw source{{end}}</span>
    </button>
  </form>
  {{end}}
  {{if and (not .ShowRenderedMarkdown) (not .ShowRenderedHTML)}}
  <form method="POST">
    <button type="submit" name="toggleFileView" class="menu-item{{if .FileView}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .FileView}}
        
        {{template "iconDiff"}}
        {{else}}
        
        {{template "iconFile"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .FileView}}Show diff{{else}}View file{{end}}</span>
    </button>
  </form>
  {{end}}
  {{end}}
  {{if gt (len .Comments) 0}}
  <form method="POST">
    <button type="submit" name="toggleCommentList" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconComments"}}</span>
      <span class="menu-label">{{if .ShowAllComments}}Back{{else}}All comments{{end}}</span>
      <span class="menu-meta">{{len .Comments}}</span>
    </button>
  </form>
  {{end}}
  {{if gt .ResolvedCount 0}}
  <form method="POST">
    <button type="submit" name="toggleShowResolved" class="menu-item{{if .ShowResolved}} is-on{{end}}" role="menuitem">
      <span class="menu-icon">
        {{if .ShowResolved}}
        {{template "iconCheck"}}
        {{else}}
        {{template "iconCircle16"}}
        {{end}}
      </span>
      <span class="menu-label">{{if .ShowResolved}}Hide resolved{{else}}Show resolved{{end}}</span>
      <span class="menu-meta">{{.ResolvedCount}}</span>
    </button>
  </form>
  {{end}}
  {{if and (eq (len .Comments) 0) (eq .ResolvedCount 0)}}
  <div class="menu-info" style="border-bottom: 0; margin-bottom: 0; font-style: italic;">No comments yet — tap a line to add one.</div>
  {{end}}
  {{if .StreamMode}}
  
  <form method="POST">
    <button type="button" command="show-modal" commandfor="confirm-end-session" class="menu-item" role="menuitem">
      <span class="menu-icon">{{template "iconStop"}}</span>
      <span class="menu-label">End session</span>
    </button>
  </form>
  {{end}}
  
  <form method="POST">
    <button type="submit" name="toggleKeyboardHelp" class="menu-item" role="menuitem">
      <span class="menu-icon" aria-hidden="true">?</span>
      <span class="menu-label">Keyboard shortcuts</span>
    </button>
  </form>
</div>

{{if .Quitting}}
<div class="banner-stopping" role="status">
  Server stopping… you can close this tab.
</div>
{{end}}

{{if .SessionEnded}}
<div class="banner-stopping" role="status">
  Session ended — Claude has been notified. You can close this tab.
</div>
{{end}}

{{if .Flash}}
<div class="toast flash-toast" role="status" lvt-fx:auto-click="3000:clearFlash">
  <span class="toast-msg">{{.Flash}}</span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="clearFlash" class="toast-dismiss" aria-label="Dismiss">
      {{template "iconClose14"}}
    </button>
  </form>
</div>
{{end}}
{{if .DoneWritten}}
<div class="toast" role="status" lvt-fx:auto-click="5000:dismissBanner">
  <span class="toast-msg">✓ Handed off → Claude is acting on your comments</span>
  <form method="POST" class="toast-dismiss-form">
    <button type="submit" name="dismissBanner" class="toast-dismiss" aria-label="Dismiss">
      {{template "iconClose14"}}
    </button>
  </form>
</div>
{{end}}


<div class="drawer-backdrop{{if .FileDrawerOpen}} open{{end}}" lvt-on:click="closeFiles" aria-label="Close file list"></div>

<div class="layout{{if .FocusMode}} focus-mode{{end}}">
<dialog id="files-drawer" open class="{{if .FileDrawerOpen}}is-open{{end}}" lvt-fx:resize="--pr-drawer-w" data-resize-handle=".resize-handle" data-resize-min="200" data-resize-max="560" data-resize-store="prereview.drawerW">
  <div class="drawer-head">
    <strong>{{len .Files}} file{{if ne (len .Files) 1}}s{{end}}</strong>
    <form method="POST">
      <button type="submit" name="closeFiles" class="outline close-btn" aria-label="Close">{{template "iconClose16"}}</button>
    </form>
  </div>
  
  {{if and (gt (len .Comments) 0) (not .ShowAllComments)}}
  <div class="drawer-all-comments">
    <form method="POST">
      <button type="submit" name="toggleCommentList" class="outline" title="Open the all-comments overview">
        💬 All comments ({{len .Comments}})
      </button>
    </form>
  </div>
  {{end}}
  
  
  {{if not .NoGit}}
  <div class="drawer-base">
    <form method="POST" class="base-select-form">
      <label for="base-input">Base</label>
      <select id="base-input" name="ref" lvt-on:change="setBase">
        {{range .BaseChoices}}
        <option value="{{.}}"{{if eq . $.Base}} selected{{end}}>{{.}}</option>
        {{end}}
      </select>
    </form>
  </div>
  {{end}}
  <div class="drawer-search">
    <form method="POST" lvt-form:preserve>
      <input type="text" name="filter" placeholder="Filter files…" value="{{.FileFilter}}" lvt-on:input="setFileFilter" lvt-mod:debounce="200" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" enterkeyhint="search">
    </form>
  </div>
  
  {{if and (gt .ChangedFilesCount 0) (lt .ChangedFilesCount (len .Files))}}
  <div class="drawer-scope">
    <form method="POST">
      <button type="submit" name="toggleFileScope" class="scope-toggle{{if not .ShowAllFiles}} is-on{{end}}" title="{{if .ShowAllFiles}}Show only files changed vs {{.Base}}{{else}}Show all {{len .Files}} tracked files{{end}}">
        {{if .ShowAllFiles}}All {{len .Files}} files · show changed only{{else}}Changed {{.ChangedFilesCount}} · show all {{len .Files}}{{end}}
      </button>
    </form>
  </div>
  {{end}}
  <div class="drawer-body">
    
    {{.FileBrowserHTML}}
  </div>
  
  <div class="resize-handle" aria-hidden="true"></div>
</dialog>

<main class="viewer">
{{if .ShowAllComments}}
<section class="all-comments">
  <header class="ac-head">
    <strong>All comments ({{len .Comments}})</strong>
    <form method="POST" style="margin:0">
      <button type="submit" name="toggleCommentList" class="outline contrast" title="Return to the file you were viewing">Back</button>
    </form>
  </header>
  {{if .VisibleComments}}
  <ul class="ac-list">
    {{range .VisibleComments}}
    <li class="ac-item{{if .Resolved}} is-resolved{{end}}" data-key="{{.ID}}">
      <form method="POST" class="ac-jump">
        <input type="hidden" name="id" value="{{.ID}}">
        <button type="submit" name="jumpToComment" class="ac-jump-btn">
          <div class="ac-where"><code>{{.File}}</code> · {{.LineSpan}} <small>({{.Side}})</small>{{if .Resolved}} <small class="resolved-badge">resolved</small>{{end}}{{if .AnchorMoved}} <small class="moved-badge">moved</small>{{end}}{{if .AnchorOutdated}} <small class="outdated-badge">outdated</small>{{end}}</div>
          <div class="ac-body">{{.Body}}</div>
        </button>
      </form>
      {{if .AnchorOutdated}}<details class="anchor-orig"><summary>⚠ the document changed here — originally anchored to:</summary><pre>{{.Anchor.Text}}</pre></details>{{end}}
      <div class="ac-actions">
        <form method="POST">
      <input type="hidden" name="id" value="{{.ID}}">
      <button type="submit" name="toggleResolved" class="outline">{{if .Resolved}}Reopen{{else}}Resolve{{end}}</button>
    </form>
        {{if and (not .Resolved) .AnchorOutdated}}<form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="reanchorComment" class="outline">Re-anchor</button>
        </form>{{end}}
        {{if and (not .Resolved) (not .AnchorOutdated)}}<form method="POST">
          <input type="hidden" name="id" value="{{.ID}}">
          <button type="submit" name="editComment" class="outline">Edit</button>
        </form>{{end}}
        <button type="button" class="secondary outline" command="show-modal" commandfor="confirm-delete-{{.ID}}">Delete</button>
        {{template "deleteDialog" .}}
      </div>
    </li>
    {{end}}
  </ul>
  {{else}}
  
  <div class="ac-empty">
    <p class="ac-empty-msg">{{if and (gt (len .Comments) 0) (not .ShowResolved)}}{{len .Comments}} resolved comment{{if ne (len .Comments) 1}}s{{end}} hidden — toggle “Show resolved” to see them.{{else}}No comments yet.{{end}}</p>
    <form method="POST" style="margin:0">
      <button type="submit" name="toggleCommentList" class="contrast ac-empty-back" title="Return to the file you were viewing">← Back to file</button>
    </form>
  </div>
  {{end}}
</section>
{{else}}
{{with .CurrentDiff}}
<article>
  <header class="file-head">
    <strong>{{.Path}}</strong>
    {{if .Note}}<small>{{.Note}}</small>{{end}}
  </header>
  
  {{$fcs := $.FileLevelComments}}
  {{$acs := $.AreaComments}}
  {{if or $fcs $acs (eq $.CommentMode "file") (eq $.CommentMode "area")}}
  <section class="file-comments" data-key="file-comments-{{.Path}}">
    {{range $fcs}}{{template "commentCardSimple" .}}{{end}}
    {{range $acs}}{{template "commentCardSimple" .}}{{end}}
    {{if or (eq $.CommentMode "file") (eq $.CommentMode "area")}}{{template "composer" $}}{{end}}
  </section>
  {{end}}
  {{if .IsBinary}}
  
  {{$kind := $.BinaryKind}}
  {{if eq $kind "image"}}
  
  {{template "regionToggle" $}}{{if not $.RegionSelectArmed}}<small class="region-hint">Pinch or scroll to zoom; use the button above to comment on a region.</small>{{end}}<div class="binary-preview binary-image"><div class="image-with-areas{{if $.RegionSelectArmed}} is-armed{{end}}" data-key="iwa-{{.Path}}">
    <img src="/{{.Path}}" alt="{{.Path}}" {{if $.RegionSelectArmed}}lvt-fx:area-select="selectImageArea" style="touch-action:none;user-select:none;-webkit-user-select:none;"{{else}}style="user-select:none;-webkit-user-select:none;"{{end}}>
    {{range $.AreaComments}}<div class="area-overlay{{if .Resolved}} is-resolved{{end}}" data-key="ao-{{.ID}}" style="left:{{.Area.PercentX}};top:{{.Area.PercentY}};width:{{.Area.PercentW}};height:{{.Area.PercentH}};" title="{{.Body}}"></div>{{end}}
    {{if eq $.CommentMode "area"}}<div class="area-overlay area-overlay-pending" data-key="ao-pending" style="left:{{$.SelectionArea.PercentX}};top:{{$.SelectionArea.PercentY}};width:{{$.SelectionArea.PercentW}};height:{{$.SelectionArea.PercentH}};"></div>{{end}}
  </div></div>
  {{else}}{{if eq $kind "pdf"}}
  
  <div class="binary-preview binary-pdf-card">
    <div class="pdf-card-icon" aria-hidden="true">📄</div>
    <strong class="pdf-card-name">{{.Path}}</strong>
    <a role="button" class="contrast pdf-card-open" href="/{{.Path}}" target="_blank" rel="noopener">Open PDF in new tab →</a>
  </div>
  {{else}}{{if eq $kind "video"}}
  <div class="binary-preview binary-video"><video controls preload="metadata" src="/{{.Path}}"></video></div>
  {{else}}{{if eq $kind "audio"}}
  <div class="binary-preview binary-audio"><audio controls preload="metadata" src="/{{.Path}}"></audio></div>
  {{else}}
  <p class="empty">Binary file — cannot display.</p>
  {{end}}{{end}}{{end}}{{end}}
  {{else}}{{if $.ShowRenderedHTML}}
  
  <div class="html-view" data-key="html-{{.Path}}">{{template "regionToggle" $}}<div class="preview-stage"><iframe class="html-preview" sandbox="allow-scripts" srcdoc="{{$.RenderedHTMLDoc}}" lvt-fx:preview-bridge title="HTML preview of {{.Path}}"></iframe>{{if $.RegionSelectArmed}}<div class="region-overlay" lvt-fx:region-select="selectBlock" data-surface="html" data-key="region-html-{{.Path}}"></div>{{end}}</div>{{range $.RenderedHTML}}{{$bs := .StartLine}}{{$be := .EndLine}}{{$hbkey := printf "HB-%d-%d" $bs $be}}<div class="html-block{{if and (ne $.SelectionEndMax 0) (ge $.SelectionEndMax $bs) (le $.SelectionEndMax $be)}} selected{{end}}" data-key="{{$hbkey}}">{{template "blockComments" .}}</div>{{end}}</div>
  {{else}}{{if $.ShowRenderedMarkdown}}
  
  <div class="md-view" data-key="md-{{.Path}}" lvt-spy="h1, h2, h3">{{range $.RenderedMarkdown}}{{$bs := .StartLine}}{{$be := .EndLine}}{{$mbkey := printf "MB-%d-%d" $bs $be}}<div class="md-block{{if and (ne $.SelectionEndMax 0) (ge $.SelectionEndMax $bs) (le $.SelectionEndMax $be)}} selected{{end}}" data-key="{{$mbkey}}"{{if eq $.ScrollHeadingBlockKey $mbkey}} lvt-fx:scroll="into-view"{{end}}><div class="md-rendered" tabindex="0" lvt-on:click="selectBlock" lvt-on:keydown="selectBlock" lvt-key="Enter" data-from="{{$bs}}" data-to="{{$be}}">{{.HTML}}</div>{{template "blockComments" .}}</div>{{end}}</div>
  {{else}}{{if .Lines}}
  
  <div class="code{{if eq .Note "file added"}} pure-add{{else}}{{if eq .Note "file deleted"}} pure-del{{end}}{{end}}{{if $.FileView}} file-view{{end}}" data-key="code-{{.Path}}" data-path="{{.Path}}" lvt-fx:scroll="reset-on:data-path" style="--diff-min-width: calc({{.MaxLineChars}}ch + 7ch)">{{range $.VisibleLines}}{{if eq .Kind "fold"}}<div class="line-row fold-row" data-key="F{{.OldNum}}-{{.NewNum}}" aria-hidden="true"><span class="fold-label">··· {{.Content}} unchanged line{{if ne .Content "1"}}s{{end}} ···</span></div>{{else}}{{$ln := .NewNum}}{{if not $ln}}{{$ln = .OldNum}}{{end}}<div class="line-row" data-key="row-L{{.OldNum}}-{{.NewNum}}{{if and (ne $.SelectionEndMax 0) (eq $.SelectionEndMax $ln)}}-composing{{end}}">{{$lkey := printf "L%d-%d" .OldNum .NewNum}}<button type="button" lvt-on:click="selectLine" data-line="{{$ln}}" data-side="{{if eq .Kind "del"}}old{{else}}new{{end}}" class="line {{.Kind}}{{if index $.SelectedLines $ln}} selected{{end}}{{if eq $.CursorKey $lkey}} is-cursor{{end}}"{{if eq $.CursorKey $lkey}} lvt-autofocus lvt-fx:scroll="into-view"{{end}} data-key="{{$lkey}}"><span class="gutter"><span class="gutter-mark">{{if eq .Kind "add"}}+{{else}}{{if eq .Kind "del"}}-{{else}}&nbsp;{{end}}{{end}} </span>{{$ln}}</span><span class="content chroma">{{if .HighlightedContent}}{{.HighlightedContent}}{{else}}{{.Content}}{{end}}</span></button>{{range (index $.CommentsByEndLine $ln)}}{{template "commentCardFull" .}}{{end}}{{if and (ne $.SelectionEndMax 0) (eq $.SelectionEndMax $ln)}}{{template "composer" $}}{{end}}</div>
{{end}}{{end}}<div class="code-sentinel" aria-hidden="true"></div></div>
  {{else}}
  <p class="empty"><small>No diff content.</small></p>
  {{end}}{{end}}{{end}}{{end}}
</article>
{{else}}
  {{if .Files}}
  <p class="empty">Pick a file from the list.</p>
  {{else}}
  <div class="empty empty-diff">
    <h3>No files in this repository</h3>
    <p><small>Add some files and refresh, or relaunch prereview pointed at a different repo.</small></p>
  </div>
  {{end}}
{{end}}
{{end}}

{{if and .LastDeletedComment (not .Quitting)}}
<div class="undo-toast" role="status">
  <span>Comment on <code>{{.LastDeletedComment.File}}</code> {{.LastDeletedComment.LineSpan}} deleted</span>
  <form method="POST" style="margin:0;display:inline">
    <button type="submit" name="undoDelete" class="undo-btn">Undo</button>
  </form>
</div>
{{end}}

{{if and .ReanchorCommentID (eq .SelectionEndMax 0)}}
<div class="reanchor-prompt" role="status">
  <span>Re-anchoring — tap the line(s) this comment should attach to.</span>
  <form method="POST" style="margin:0;display:inline">
    <button type="submit" name="clearSelection" class="undo-btn">Cancel</button>
  </form>
</div>
{{end}}
</main>


{{with .RenderedHeadings}}
<aside class="toc-sidebar" aria-label="Table of contents">
  <div class="toc-head"><strong>On this page</strong></div>
  <nav class="toc-list">
    {{range .}}<a href="#{{.ID}}" lvt-spy-link class="toc-link toc-l{{.Level}}">{{.Text}}</a>
    {{end}}
  </nav>
</aside>
{{end}}
</div>

{{with .RenderedHeadings}}
<div class="toc-backdrop{{if $.TOCOpen}} is-open{{end}}" lvt-on:click="closeTOC" aria-hidden="true"></div>
<div class="toc-modal{{if $.TOCOpen}} is-open{{end}}" role="dialog" aria-label="Table of contents" aria-modal="true">
  <div class="toc-modal-head">
    <strong>On this page</strong>
    <form method="POST">
      <button type="submit" name="closeTOC" class="outline close-btn" aria-label="Close">
        {{template "iconClose16"}}
      </button>
    </form>
  </div>
  <nav class="toc-modal-list">
    {{range .}}<a href="#{{.ID}}" lvt-spy-link lvt-on:click="navigateToHeading" data-id="{{.ID}}" class="toc-link toc-l{{.Level}}">{{.Text}}</a>
    {{end}}
  </nav>
</div>
{{end}}

<div class="kbd-help-backdrop{{if .KeyHelpOpen}} is-open{{end}}" lvt-on:click="toggleKeyboardHelp" aria-hidden="true"></div>
<div class="kbd-help-modal{{if .KeyHelpOpen}} is-open{{end}}" role="dialog" aria-label="Keyboard shortcuts" aria-modal="true">
  <div class="kbd-help-head">
    <strong>Keyboard shortcuts</strong>
    <form method="POST">
      <button type="submit" name="toggleKeyboardHelp" class="outline close-btn" aria-label="Close">
        {{template "iconClose16"}}
      </button>
    </form>
  </div>
  <dl class="kbd-help-list">{{range .KeyBindings}}
    <div class="kbd-row"><dt><kbd>{{.Display}}</kbd></dt><dd>{{.Label}}</dd></div>{{end}}
  </dl>
  <p class="kbd-help-note">Drawing a precise region on rendered HTML or an image needs a mouse — from the keyboard, comment on the whole block or image instead.</p>
</div>
<footer class="app-footer" role="contentinfo">
  prereview{{if ne .Version "dev"}} v{{.Version}}{{end}} · built with <a href="https://github.com/livetemplate/livetemplate" target="_blank" rel="noopener noreferrer">livetemplate</a>
</footer>
{{end}}


{{if .StreamMode}}{{template "endSessionDialog" .}}{{end}}
{{if and (not .SkillMode) (not .StreamMode)}}{{template "quitDialog" .}}{{end}}

</div>
<script defer src="/livetemplate-client.js"></script>

<script defer src="/mermaid-init.js"></script>
</body>
</html>























=== quitDialog ===
<dialog id="confirm-quit"><article><header><strong>Quit prereview?</strong></header><p><small>Stops the prereview server and closes the review. Saved comments are already written to the CSV; this can't be undone from the browser.</small></p><footer>
    <form method="POST">
      <fieldset role="group">
        <button type="button" command="close" commandfor="confirm-quit" class="secondary">Cancel</button>
        <button type="submit" name="quit" class="contrast">Quit</button>
      </fieldset>
    </form>
  </footer></article></dialog>
=== regionToggle ===
<form method="POST" class="region-toggle">
  <button type="submit" name="toggleRegionSelect" class="{{if $.RegionSelectArmed}}contrast{{else}}outline secondary{{end}}" aria-pressed="{{if $.RegionSelectArmed}}true{{else}}false{{end}}">{{if $.RegionSelectArmed}}Selecting region — tap to cancel{{else}}▭ Select a region to comment{{end}}</button>
</form>
